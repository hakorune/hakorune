// lower_loop_multi_carrier_box.hako — Multi-carrier loop (fibonacci-style) lowering
// Responsibility:
//   - Detect and lower "multi-carrier" loops (e.g. fib: a,b,t carried variables)
//   - Extract loop metadata (var name, limit, carrier count) from Program(JSON v0)
//   - Delegate to LoopFormBox.build2 with mode="multi_count"
// Scope (Phase 25.1b):
//   - Recognize fibonacci-style loops with 2+ carrier variables
//   - Fail-Fast if pattern doesn't match multi-carrier requirements
//   - Fall back to Rust provider for unsupported patterns

using selfhost.shared.json.utils.json_frag as JsonFragBox
using "hako.mir.builder.internal.loop_scan" as LoopScanBox
using "hako.mir.builder.internal.builder_config" as BuilderConfigBox
using lang.mir.builder.func_lowering.param_list_box as ParamListBox

static box LowerLoopMultiCarrierBox {
  // Try to recognize and lower a multi-carrier loop in Program(JSON v0).
  // Pattern: loop with multiple Local/Assign indicating carried state (fibonacci-style)
  method try_lower(program_json, params_arr) {
    if program_json == null { return null }
    local s = me._coerce_text_compat(program_json)

    // 1) Find Loop with cond Compare
    local k_loop = JsonFragBox.index_of_from(s, "\"type\":\"Loop\"", 0)
    if k_loop < 0 { return null }

    local k_cmp = JsonFragBox.index_of_from(s, "\"type\":\"Compare\"", k_loop)
    if k_cmp < 0 { return null }

    // 2) Discover loop variable name from cond
    local varname = LoopScanBox.find_loop_var_name(s, k_cmp)
    if varname == null { return null }

    // 3) Extract limit facts (accept Int literal or param Var) without a MapBox payload.
    local limit_kind = me._extract_limit_kind(s, k_cmp, varname, params_arr)
    if limit_kind == "" {
      if BuilderConfigBox.trace_enabled() == 1 {
        print("[mirbuilder/internal/loop:multi_carrier:limit:unsupported]")
      }
      return null
    }
    if limit_kind != "const" && limit_kind != "param" { return null }
    local limit_value = "0"
    local limit_param_reg = 0
    if limit_kind == "const" {
      limit_value = me._extract_limit_value_text(s, k_cmp, varname)
    } else {
      limit_param_reg = me._coerce_i64_compat(me._extract_limit_param_reg_text(s, k_cmp, varname, params_arr))
      if limit_param_reg <= 0 { return null }
    }

    // 4) Collect carrier facts without materializing an ArrayBox on the active path.
    local carrier_count = me._carrier_count(s, k_loop, varname)
    if carrier_count < 2 {
      local count = carrier_count
      print("[mirbuilder/internal/loop:multi_carrier:insufficient_carriers:count=" + count + "]")
      return null
    }

    local tag = "[mirbuilder/internal/loop:multi_carrier:detected:limit_kind=" + limit_kind
    if limit_kind == "const" {
      tag = tag + ",value=" + limit_value
    } else {
      tag = tag + ",param_reg=" + limit_param_reg
    }
    tag = tag + ",carriers=" + carrier_count + "]"
    print(tag)

    // 5) Emit the same multi_count layout directly as MIR JSON text.
    local emitted = me._emit_multi_count_json(s, k_loop, varname, limit_kind, limit_value, limit_param_reg, carrier_count)
    if emitted == "" { return null }
    return emitted
  }

  method _carrier_count(body_json, loop_idx, loop_var) {
    if body_json == null { return 0 }
    local count = 0
    local search = 0
    local n = body_json.length()
    loop(search < n) {
      local k_local = JsonFragBox.index_of_from(body_json, "\"type\":\"Local\"", search)
      if k_local < 0 || (loop_idx >= 0 && k_local >= loop_idx) { break }
      local name_idx = JsonFragBox.index_of_from(body_json, "\"name\":", k_local)
      if name_idx < 0 { break }
      local name = JsonFragBox.read_string_after(body_json, name_idx + 7)
      if name == null { break }
      if loop_var != null && name == loop_var {
        search = k_local + 1
        continue
      }
      local expr_idx = JsonFragBox.index_of_from(body_json, "\"expr\":{", k_local)
      if expr_idx < 0 || (loop_idx >= 0 && expr_idx >= loop_idx) {
        search = k_local + 1
        continue
      }
      local int_idx = JsonFragBox.index_of_from(body_json, "\"type\":\"Int\"", expr_idx)
      if int_idx < 0 || (loop_idx >= 0 && int_idx >= loop_idx) {
        search = k_local + 1
        continue
      }
      local val_idx = JsonFragBox.index_of_from(body_json, "\"value\":", int_idx)
      if val_idx < 0 { search = k_local + 1  continue }
      local val = JsonFragBox.read_int_after(body_json, val_idx + 8)
      if val != null { count = count + 1 }
      search = k_local + 1
    }
    return count
  }

  method _carrier_value_text(body_json, loop_idx, loop_var, index) {
    if body_json == null { return "" }
    local wanted = me._coerce_i64_compat(index)
    if wanted < 0 { return "" }
    local current = 0
    local search = 0
    local n = body_json.length()
    loop(search < n) {
      local k_local = JsonFragBox.index_of_from(body_json, "\"type\":\"Local\"", search)
      if k_local < 0 || (loop_idx >= 0 && k_local >= loop_idx) { break }
      local name_idx = JsonFragBox.index_of_from(body_json, "\"name\":", k_local)
      if name_idx < 0 { break }
      local name = JsonFragBox.read_string_after(body_json, name_idx + 7)
      if name == null { break }
      if loop_var != null && name == loop_var {
        search = k_local + 1
        continue
      }
      local expr_idx = JsonFragBox.index_of_from(body_json, "\"expr\":{", k_local)
      if expr_idx < 0 || loop_idx >= 0 && expr_idx >= loop_idx {
        search = k_local + 1
        continue
      }
      local int_idx = JsonFragBox.index_of_from(body_json, "\"type\":\"Int\"", expr_idx)
      if int_idx < 0 || loop_idx >= 0 && int_idx >= loop_idx {
        search = k_local + 1
        continue
      }
      local val_idx = JsonFragBox.index_of_from(body_json, "\"value\":", int_idx)
      if val_idx < 0 { search = k_local + 1  continue }
      local val = JsonFragBox.read_int_after(body_json, val_idx + 8)
      if val != null {
        if current == wanted { return me._coerce_text_compat(val) }
        current = current + 1
      }
      search = k_local + 1
    }
    return ""
  }

  // Extract initial carrier values (Local Int assignments before Loop body)
  method _collect_carrier_initials(body_json, loop_idx, loop_var) {
    local vals = new ArrayBox()
    local count = me._carrier_count(body_json, loop_idx, loop_var)
    local idx = 0
    loop(idx < count) {
      local val = me._carrier_value_text(body_json, loop_idx, loop_var, idx)
      if val != "" { vals.push(me._coerce_i64_compat(val)) }
      idx = idx + 1
    }
    return vals
  }

  method _emit_multi_count_json(body_json, loop_idx, loop_var, limit_kind, limit_value, limit_param_reg, carrier_count) {
    local reg_i_init = 1
    local reg_limit = 2
    local reg_step = me._reg_add2(3, carrier_count)
    local reg_i_curr = me._reg_add2(reg_step, 1)
    local reg_cmp = me._reg_add3(reg_i_curr, carrier_count, 1)
    local reg_i_next = me._reg_add2(reg_cmp, 1)
    local reg_carrier_next_base = me._reg_add2(reg_i_next, 1)
    local next_reg = me._reg_add2(reg_carrier_next_base, carrier_count)
    local last_carrier_offset = me._reg_sub1(carrier_count)
    local last_next = me._reg_add2(reg_carrier_next_base, last_carrier_offset)

    local pre = "{\"id\":0,\"instructions\":["
    pre = pre + "{\"op\":\"const\",\"dst\":" + reg_i_init + ",\"value\":{\"type\":\"i64\",\"value\":0}}"
    if limit_kind == "const" {
      pre = pre + ",{\"op\":\"const\",\"dst\":" + reg_limit + ",\"value\":{\"type\":\"i64\",\"value\":" + limit_value + "}}"
    } else {
      pre = pre + ",{\"op\":\"copy\",\"src\":" + limit_param_reg + ",\"dst\":" + reg_limit + "}"
    }
    local idx = 0
    loop(idx < carrier_count) {
      local reg_carrier_init = me._reg_add2(3, idx)
      local carrier_value = me._carrier_value_text(body_json, loop_idx, loop_var, idx)
      if carrier_value == "" { return "" }
      pre = pre + ",{\"op\":\"const\",\"dst\":" + reg_carrier_init + ",\"value\":{\"type\":\"i64\",\"value\":" + carrier_value + "}}"
      idx = me._reg_add2(idx, 1)
    }
    pre = pre + ",{\"op\":\"const\",\"dst\":" + reg_step + ",\"value\":{\"type\":\"i64\",\"value\":1}}"
    pre = pre + ",{\"op\":\"jump\",\"target\":1}]}"

    local header = "{\"id\":1,\"instructions\":["
    header = header + "{\"op\":\"phi\",\"dst\":" + reg_i_curr + ",\"incoming\":[[" + reg_i_init + ",0],[" + reg_i_next + ",3]]}"
    idx = 0
    loop(idx < carrier_count) {
      local reg_carrier_init2 = me._reg_add2(3, idx)
      local reg_carrier_curr = me._reg_add3(reg_i_curr, idx, 1)
      local reg_carrier_next = me._reg_add2(reg_carrier_next_base, idx)
      header = header + ",{\"op\":\"phi\",\"dst\":" + reg_carrier_curr + ",\"incoming\":[[" + reg_carrier_init2 + ",0],[" + reg_carrier_next + ",3]]}"
      idx = me._reg_add2(idx, 1)
    }
    header = header + ",{\"op\":\"compare\",\"operation\":\"Lt\",\"lhs\":" + reg_i_curr + ",\"rhs\":" + reg_limit + ",\"dst\":" + reg_cmp + "}"
    header = header + ",{\"op\":\"branch\",\"cond\":" + reg_cmp + ",\"then\":2,\"else\":4}]}"

    local body = "{\"id\":2,\"instructions\":["
    local reg_sum = next_reg
    next_reg = me._reg_add2(next_reg, 1)
    local first_carrier_curr = me._reg_add2(reg_i_curr, 1)
    body = body + "{\"op\":\"copy\",\"src\":" + first_carrier_curr + ",\"dst\":" + reg_sum + "}"
    local current_sum = reg_sum
    idx = 1
    loop(idx < carrier_count) {
      local reg_tmp = next_reg
      next_reg = me._reg_add2(next_reg, 1)
      local reg_carrier_curr2 = me._reg_add3(reg_i_curr, idx, 1)
      body = body + ",{\"op\":\"binop\",\"operation\":\"Add\",\"lhs\":" + current_sum + ",\"rhs\":" + reg_carrier_curr2 + ",\"dst\":" + reg_tmp + "}"
      current_sum = reg_tmp
      idx = me._reg_add2(idx, 1)
    }
    local reg_new_value = current_sum
    body = body + ",{\"op\":\"jump\",\"target\":3}]}"

    local latch = "{\"id\":3,\"instructions\":["
    latch = latch + "{\"op\":\"binop\",\"operation\":\"Add\",\"lhs\":" + reg_i_curr + ",\"rhs\":" + reg_step + ",\"dst\":" + reg_i_next + "}"
    idx = 0
    loop(idx < last_carrier_offset) {
      local src_carrier = me._reg_add3(reg_i_curr, idx, 2)
      local dst_carrier = me._reg_add2(reg_carrier_next_base, idx)
      latch = latch + ",{\"op\":\"copy\",\"src\":" + src_carrier + ",\"dst\":" + dst_carrier + "}"
      idx = me._reg_add2(idx, 1)
    }
    latch = latch + ",{\"op\":\"copy\",\"src\":" + reg_new_value + ",\"dst\":" + last_next + "}"
    latch = latch + ",{\"op\":\"jump\",\"target\":1}]}"

    local last_curr = me._reg_add2(reg_i_curr, carrier_count)
    local exit_block = "{\"id\":4,\"instructions\":[{\"op\":\"ret\",\"value\":" + last_curr + "}]}"
    return "{\"kind\":\"MIR\",\"schema_version\":\"1.0\",\"functions\":[{\"name\":\"main\",\"params\":[],\"blocks\":[" + pre + "," + header + "," + body + "," + latch + "," + exit_block + "]}]}"
  }

  method _reg_add2(a, b) {
    return a + b
  }

  method _reg_add3(a, b, c) {
    return a + b + c
  }

  method _reg_sub1(a) {
    return a - 1
  }

  method _extract_limit_kind(body_json, cmp_idx, loop_var, params_arr) {
    local s = me._coerce_text_compat(body_json)
    local has_lhs = JsonFragBox.index_of_from(s, "\"lhs\":{\"type\":\"Var\",\"name\":\"" + loop_var + "\"}", cmp_idx) >= 0
    local has_rhs = JsonFragBox.index_of_from(s, "\"rhs\":{\"type\":\"Var\",\"name\":\"" + loop_var + "\"}", cmp_idx) >= 0
    local trace_on = BuilderConfigBox.trace_enabled()
    if !has_lhs && !has_rhs {
      if trace_on == 1 {
        print("[mirbuilder/internal/loop:multi_carrier:limit:scan:fail] reason=no-loop-var var=" + loop_var)
      }
      return ""
    }
    local target_idx = -1
    if has_lhs {
      target_idx = JsonFragBox.index_of_from(s, "\"rhs\":{", cmp_idx)
    } else {
      target_idx = JsonFragBox.index_of_from(s, "\"lhs\":{", cmp_idx)
    }
    if target_idx < 0 {
      if trace_on == 1 {
        print("[mirbuilder/internal/loop:multi_carrier:limit:scan:fail] reason=no-target")
      }
      return ""
    }
    local type_idx = JsonFragBox.index_of_from(s, "\"type\":\"", target_idx)
    if type_idx < 0 {
      if trace_on == 1 {
        print("[mirbuilder/internal/loop:multi_carrier:limit:scan:fail] reason=no-type")
      }
      return ""
    }
    local typ = JsonFragBox.read_string_after(s, type_idx + 7)
    if typ == null {
      if trace_on == 1 { print("[mirbuilder/internal/loop:multi_carrier:limit:scan:fail] reason=type-null") }
      return ""
    }
    if typ == "Int" {
      local val_idx = JsonFragBox.index_of_from(s, "\"value\":", type_idx)
      if val_idx < 0 {
        if trace_on == 1 { print("[mirbuilder/internal/loop:multi_carrier:limit:scan:fail] reason=no-int-value") }
        return ""
      }
      local val = JsonFragBox.read_int_after(s, val_idx + 8)
      if val == null {
        if trace_on == 1 { print("[mirbuilder/internal/loop:multi_carrier:limit:scan:fail] reason=int-parse") }
        return ""
      }
      return "const"
    }
    if typ == "Var" {
      local name_idx = JsonFragBox.index_of_from(s, "\"name\":\"", type_idx)
      if name_idx < 0 {
        if trace_on == 1 { print("[mirbuilder/internal/loop:multi_carrier:limit:scan:fail] reason=no-var-name") }
        return ""
      }
      local name = JsonFragBox.read_string_after(s, name_idx + 7)
      if name == null {
        if trace_on == 1 { print("[mirbuilder/internal/loop:multi_carrier:limit:scan:fail] reason=var-name-null") }
        return ""
      }
      local param_reg = me._resolve_param_reg(params_arr, name)
      if trace_on == 1 {
        print("[mirbuilder/internal/loop:multi_carrier:limit:param] name=" + name + ",reg=" + param_reg)
      }
      if param_reg <= 0 {
        if trace_on == 1 {
          print("[mirbuilder/internal/loop:multi_carrier:limit:scan:fail] reason=param-unresolved")
        }
        return ""
      }
      return "param"
    }
    if trace_on == 1 {
      print("[mirbuilder/internal/loop:multi_carrier:limit:scan:fail] reason=type-unsupported typ=" + typ)
    }
    return ""
  }

  method _extract_limit_value_text(body_json, cmp_idx, loop_var) {
    local s = me._coerce_text_compat(body_json)
    local type_idx = me._limit_target_type_idx(s, cmp_idx, loop_var)
    if type_idx < 0 { return "" }
    local typ = JsonFragBox.read_string_after(s, type_idx + 7)
    if typ != "Int" { return "" }
    local val_idx = JsonFragBox.index_of_from(s, "\"value\":", type_idx)
    if val_idx < 0 { return "" }
    local val = JsonFragBox.read_int_after(s, val_idx + 8)
    if val == null { return "" }
    return me._coerce_text_compat(val)
  }

  method _extract_limit_param_reg_text(body_json, cmp_idx, loop_var, params_arr) {
    local s = me._coerce_text_compat(body_json)
    local type_idx = me._limit_target_type_idx(s, cmp_idx, loop_var)
    if type_idx < 0 { return "" }
    local typ = JsonFragBox.read_string_after(s, type_idx + 7)
    if typ != "Var" { return "" }
    local name_idx = JsonFragBox.index_of_from(s, "\"name\":\"", type_idx)
    if name_idx < 0 { return "" }
    local name = JsonFragBox.read_string_after(s, name_idx + 7)
    if name == null { return "" }
    return me._coerce_text_compat(me._resolve_param_reg(params_arr, name))
  }

  method _limit_target_type_idx(body_json, cmp_idx, loop_var) {
    local s = me._coerce_text_compat(body_json)
    local has_lhs = JsonFragBox.index_of_from(s, "\"lhs\":{\"type\":\"Var\",\"name\":\"" + loop_var + "\"}", cmp_idx) >= 0
    local has_rhs = JsonFragBox.index_of_from(s, "\"rhs\":{\"type\":\"Var\",\"name\":\"" + loop_var + "\"}", cmp_idx) >= 0
    if !has_lhs && !has_rhs { return -1 }
    local target_idx = -1
    if has_lhs {
      target_idx = JsonFragBox.index_of_from(s, "\"rhs\":{", cmp_idx)
    } else {
      target_idx = JsonFragBox.index_of_from(s, "\"lhs\":{", cmp_idx)
    }
    if target_idx < 0 { return -1 }
    return JsonFragBox.index_of_from(s, "\"type\":\"", target_idx)
  }

  method _extract_limit_info(body_json, cmp_idx, loop_var, params_arr) {
    local kind = me._extract_limit_kind(body_json, cmp_idx, loop_var, params_arr)
    if kind == "" { return null }
    local info = new MapBox()
    info.set("kind", kind)
    if kind == "const" {
      info.set("value", me._coerce_i64_compat(me._extract_limit_value_text(body_json, cmp_idx, loop_var)))
    } else {
      info.set("param_reg", me._coerce_i64_compat(me._extract_limit_param_reg_text(body_json, cmp_idx, loop_var, params_arr)))
    }
    return info
  }

  method _resolve_param_reg(params_arr, name) {
    if params_arr == null || name == null { return 0 }
    local idx = 0
    local total = ParamListBox.count(params_arr)
    loop(idx < total) {
      local pname = me._coerce_text_compat(ParamListBox.get(params_arr, idx))
      if pname == name {
        return me._coerce_i64_compat(idx + 1)
      }
      idx = idx + 1
    }
    return 0
  }
  method _coerce_text_compat(value) {
    return "" + value
  }
  method _coerce_i64_compat(value) {
    return JsonFragBox._str_to_int(me._coerce_text_compat(value))
  }
}
