using selfhost.vm.hakorune-vm.hakorune_vm_core as HakoruneVmCore

static box Main {
  // Usage: hakorune-vm-exe <mir.json>
  main(args) {
    local path = null
    if args { if args.length() > 0 { @p = args.get(0) if p { path = p } } }
    if path == null {
      print("usage: hakorune-vm-exe <mir.json>")
      return -1
    }
    return HakoruneVmCore.run_from_file(path)
  }
}
