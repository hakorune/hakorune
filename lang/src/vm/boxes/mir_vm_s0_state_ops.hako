// mir_vm_s0_state_ops.hako — state helpers split from mir_vm_s0
// Responsibility: small state operations for array length, handle maps, and FileBox state.

using selfhost.shared.common.string_helpers as StringHelpers
using selfhost.vm.helpers.mir_s0_reg_utils as MirVmS0RegUtilsBox

static box MirVmS0StateOpsBox {
  _missing_prefix() { return "[map/missing]" }
  _missing_prefix_len() { return me._missing_prefix().length() }

  _is_missing_map_value(v) {
    if v == null { return 1 }
    local s = "" + v
    local n = me._missing_prefix_len()
    if s.length() < n { return 0 }
    if s.substring(0, n) == me._missing_prefix() { return 1 }
    return 0
  }

  map_get_or_null(m, key) {
    local v = m.get("" + key)
    if me._is_missing_map_value(v) == 1 { return null }
    return v
  }

  storage_get_or_null(m, key) {
    if m == null { return null }
    local skey = "" + key
    local present = m.has(skey)
    if present == null { return null }
    local ptext = "" + present
    if present == 0 || ptext == "0" || ptext == "false" || ptext == "" { return null }
    return m.get(skey)
  }

  _to_i64(x) {
    if x == null { return 0 }
    return StringHelpers.to_i64("" + x)
  }

  reg_i64_get(regs, id) {
    local v = me.map_get_or_null(regs, id)
    if v == null { return 0 }
    return me._to_i64(v)
  }

  box_len_get(array_lens, id) {
    local v = me.map_get_or_null(array_lens, id)
    if v == null { return 0 }
    return me._to_i64(v)
  }

  box_len_set(array_lens, id, len) {
    array_lens.set("" + id, "" + me._to_i64(len))
  }

  box_len_copy(array_lens, dst, src) {
    me.box_len_set(array_lens, dst, me.box_len_get(array_lens, src))
  }

  _array_val_key(box_id, index) {
    return "v:" + box_id + ":" + me._to_i64(index)
  }

  array_val_set(array_lens, box_id, index, value) {
    array_lens.set(me._array_val_key(box_id, index), "" + me._to_i64(value))
  }

  array_val_get(array_lens, box_id, index) {
    local v = me.map_get_or_null(array_lens, me._array_val_key(box_id, index))
    if v == null { return 0 }
    return me._to_i64(v)
  }

  handle_get(handle_regs, id) {
    return me.storage_get_or_null(handle_regs, id)
  }

  handle_set(handle_regs, id, text) {
    handle_regs.set("" + id, "" + text)
  }

  handle_copy(handle_regs, dst, src) {
    local v = me.handle_get(handle_regs, src)
    if v != null {
      me.handle_set(handle_regs, dst, v)
    }
  }

  file_box_get(file_boxes, id) {
    return me.storage_get_or_null(file_boxes, id)
  }

  file_box_set(file_boxes, id, file_obj) {
    file_boxes.set("" + id, file_obj)
  }

  file_box_clear(file_boxes, id) {
    file_boxes.set("" + id, null)
  }

  file_box_copy(file_boxes, dst, src) {
    local obj = me.file_box_get(file_boxes, src)
    if obj != null {
      me.file_box_set(file_boxes, dst, obj)
    }
  }

  copy_reg_payload(regs, kinds, array_lens, handle_regs, file_boxes, dst, src) {
    MirVmS0RegUtilsBox._reg_set(regs, dst, MirVmS0RegUtilsBox._reg_get(regs, src))
    MirVmS0RegUtilsBox._reg_kind_copy(kinds, dst, src)
    me.box_len_copy(array_lens, dst, src)
    me.handle_copy(handle_regs, dst, src)
    me.file_box_copy(file_boxes, dst, src)
  }

  copy_reg_payload_between(src_regs, src_kinds, src_array_lens, src_handle_regs, src_file_boxes, dst_regs, dst_kinds, dst_array_lens, dst_handle_regs, dst_file_boxes, dst, src) {
    MirVmS0RegUtilsBox._reg_set(dst_regs, dst, MirVmS0RegUtilsBox._reg_get(src_regs, src))
    MirVmS0RegUtilsBox._reg_kind_set(dst_kinds, dst, MirVmS0RegUtilsBox._reg_kind_get(src_kinds, src))
    me.box_len_set(dst_array_lens, dst, me.box_len_get(src_array_lens, src))
    local handle_text = me.handle_get(src_handle_regs, src)
    if handle_text != null {
      me.handle_set(dst_handle_regs, dst, handle_text)
    }
    local file_obj = me.file_box_get(src_file_boxes, src)
    if file_obj != null {
      me.file_box_set(dst_file_boxes, dst, file_obj)
    }
  }

  filebox_token_for_newbox(box_type, dst) {
    if box_type == "FileBox" { return dst }
    return 0
  }
}
