// segment_arena_backing_modeled_allocation_ledger_release_recycle_execution_unsupported_outcome_ledger_diagnostic_box.hako -- MIMAP-321A
// Responsibility:
// - observe MIMAP-320A unsupported outcome ledger facts and publish scalar/model
//   diagnostic facts
// - keep diagnostics observer-only before any real release/recycle execution
//   opens
// Non-responsibility:
// - recording unsupported outcome rows, executing real release/recycle,
//   lifecycle generation, pointer residence, segment-map mutation, atomic
//   bitmap execution, OSVM calls, scheduling, providers, or backend shortcuts

record HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionUnsupportedOutcomeLedgerDiagnosticReportFields {
    observed: i64
    reason: i64
    diagnostic_present: i64
    outcome_accepted: i64
    outcome_reason: i64
    outcome_present: i64
    marker_accepted: i64
    marker_reason: i64
    execution_intent_requested: i64
    execution_supported: i64
    unsupported_execution_requirement: i64
    outcome_count: i64
    accepted_count: i64
    reject_count: i64
    observed_count: i64
    accepted_outcome_count: i64
    rejected_outcome_count: i64
    unsupported_outcome_count: i64
    missing_ledger_reject_count: i64
    missing_report_reject_count: i64
    last_reason: i64
    report_segment_id: i64
    report_arena_id: i64
    report_lifetime_generation: i64
    report_release_applied_recycle_token: i64
    report_continuation_token: i64
    report_application_token: i64
    report_applied_backing_bytes: usize
    report_applied_committed_bytes: usize
    report_remaining_source_bytes: usize
    would_create_lifecycle_generation: i64
    would_create_pointer_residence: i64
    would_lookup_by_pointer: i64
    would_release_arena_backing: i64
    would_recycle_arena_backing: i64
    would_use_segment_map: i64
    would_execute_atomic_bitmap: i64
    would_call_osvm: i64
    would_run_thread: i64
    would_activate_provider: i64
    would_add_backend_matcher: i64
}

box HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionUnsupportedOutcomeLedgerDiagnosticReport {
    observed: i64 = 0
    reason: i64 = 0
    diagnostic_present: i64 = 1
    outcome_accepted: i64 = 0
    outcome_reason: i64 = 0
    outcome_present: i64 = 0
    marker_accepted: i64 = 0
    marker_reason: i64 = 0
    execution_intent_requested: i64 = 0
    execution_supported: i64 = 0
    unsupported_execution_requirement: i64 = 0
    outcome_count: i64 = 0
    accepted_count: i64 = 0
    reject_count: i64 = 0
    observed_count: i64 = 0
    accepted_outcome_count: i64 = 0
    rejected_outcome_count: i64 = 0
    unsupported_outcome_count: i64 = 0
    missing_ledger_reject_count: i64 = 0
    missing_report_reject_count: i64 = 0
    last_reason: i64 = 0
    report_segment_id: i64 = -1
    report_arena_id: i64 = -1
    report_lifetime_generation: i64 = 0
    report_release_applied_recycle_token: i64 = 0
    report_continuation_token: i64 = 0
    report_application_token: i64 = 0
    report_applied_backing_bytes: usize = 0
    report_applied_committed_bytes: usize = 0
    report_remaining_source_bytes: usize = 0
    would_create_lifecycle_generation: i64 = 0
    would_create_pointer_residence: i64 = 0
    would_lookup_by_pointer: i64 = 0
    would_release_arena_backing: i64 = 0
    would_recycle_arena_backing: i64 = 0
