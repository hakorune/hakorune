box HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionReadinessMatrixInventory {
    inventory_count: i64 = 0
    accepted_count: i64 = 0
    reject_count: i64 = 0
    missing_summary_reject_count: i64 = 0
    rejected_summary_reject_count: i64 = 0
    not_ready_reject_count: i64 = 0
    closed_substrate_reject_count: i64 = 0
    lifecycle_requirement_reject_count: i64 = 0
