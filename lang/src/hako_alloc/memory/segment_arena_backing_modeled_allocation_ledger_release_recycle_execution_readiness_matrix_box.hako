    arena_release_requirement_reject_count: i64 = 0
    arena_recycle_requirement_reject_count: i64 = 0
    segment_map_requirement_reject_count: i64 = 0
    atomic_bitmap_requirement_reject_count: i64 = 0
    osvm_requirement_reject_count: i64 = 0
    worker_requirement_reject_count: i64 = 0
    provider_requirement_reject_count: i64 = 0
    backend_matcher_requirement_reject_count: i64 = 0
    last_reason: i64 = 0
    last_segment_id: i64 = -1
    last_arena_id: i64 = -1

    blockedCount(requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher): i64 {
        local count = 0
        if requires_lifecycle_generation != 0 {
            count += 1
        }
        if requires_pointer_residence != 0 {
            count += 1
        }
        if requires_pointer_lookup != 0 {
            count += 1
        }
        if requires_arena_backing_release != 0 {
            count += 1
        }
        if requires_arena_backing_recycle != 0 {
            count += 1
        }
        if requires_segment_map != 0 {
            count += 1
        }
        if requires_atomic_bitmap != 0 {
            count += 1
        }
        if requires_osvm != 0 {
            count += 1
        }
        if requires_worker != 0 {
            count += 1
        }
        if requires_provider != 0 {
            count += 1
        }
        if requires_backend_matcher != 0 {
            count += 1
        }
        return count
    }

    makeExecutionReadinessMatrixReport(fields: HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionReadinessMatrixReportFields): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionReadinessMatrixReport {
        local result = new HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionReadinessMatrixReport()
        result.accepted = fields.accepted
        result.reason = fields.reason
        result.matrix_present = fields.matrix_present
        result.summary_present = fields.summary_present
        result.summary_summarized = fields.summary_summarized
        result.summary_reason = fields.summary_reason
        result.row_index = fields.row_index
        result.segment_id = fields.segment_id
        result.arena_id = fields.arena_id
        result.lifetime_generation = fields.lifetime_generation
        result.release_applied_recycle_token = fields.release_applied_recycle_token
        result.continuation_token = fields.continuation_token
        result.application_token = fields.application_token
        result.applied_backing_bytes = fields.applied_backing_bytes
        result.applied_committed_bytes = fields.applied_committed_bytes
        result.remaining_source_bytes = fields.remaining_source_bytes
        result.applied_state_ready = fields.applied_state_ready
        result.closed_substrate_summary = fields.closed_substrate_summary
        result.requires_lifecycle_generation = fields.requires_lifecycle_generation
        result.requires_pointer_residence = fields.requires_pointer_residence
        result.requires_pointer_lookup = fields.requires_pointer_lookup
        result.requires_arena_backing_release = fields.requires_arena_backing_release
        result.requires_arena_backing_recycle = fields.requires_arena_backing_recycle
        result.requires_segment_map = fields.requires_segment_map
        result.requires_atomic_bitmap = fields.requires_atomic_bitmap
        result.requires_osvm = fields.requires_osvm
        result.requires_worker = fields.requires_worker
        result.requires_provider = fields.requires_provider
        result.requires_backend_matcher = fields.requires_backend_matcher
        result.blocked_requirement_count = fields.blocked_requirement_count
        result.would_create_lifecycle_generation = fields.would_create_lifecycle_generation
        result.would_create_pointer_residence = fields.would_create_pointer_residence
        result.would_lookup_by_pointer = fields.would_lookup_by_pointer
        result.would_release_arena_backing = fields.would_release_arena_backing
        result.would_recycle_arena_backing = fields.would_recycle_arena_backing
        result.would_use_segment_map = fields.would_use_segment_map
        result.would_execute_atomic_bitmap = fields.would_execute_atomic_bitmap
        result.would_call_osvm = fields.would_call_osvm
        result.would_run_thread = fields.would_run_thread
        result.would_activate_provider = fields.would_activate_provider
        result.would_add_backend_matcher = fields.would_add_backend_matcher
        return result
    }

    makeReport(accepted, reason, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionReadinessMatrixReport {
        local fields = HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionReadinessMatrixReportFields {
            accepted: accepted,
            reason: reason,
            matrix_present: 1,
            summary_present: summary_report.applied_state_summary_present,
            summary_summarized: summary_report.summarized,
            summary_reason: summary_report.reason,
            row_index: summary_report.row_index,
            segment_id: summary_report.segment_id,
            arena_id: summary_report.arena_id,
            lifetime_generation: summary_report.lifetime_generation,
            release_applied_recycle_token: summary_report.release_applied_recycle_token,
            continuation_token: summary_report.continuation_token,
            application_token: summary_report.application_token,
            applied_backing_bytes: summary_report.applied_backing_bytes,
            applied_committed_bytes: summary_report.applied_committed_bytes,
            remaining_source_bytes: summary_report.remaining_source_bytes,
            applied_state_ready: summary_report.applied_state_ready,
            closed_substrate_summary: summary_report.closed_substrate_summary,
            requires_lifecycle_generation: requires_lifecycle_generation,
            requires_pointer_residence: requires_pointer_residence,
            requires_pointer_lookup: requires_pointer_lookup,
            requires_arena_backing_release: requires_arena_backing_release,
            requires_arena_backing_recycle: requires_arena_backing_recycle,
            requires_segment_map: requires_segment_map,
            requires_atomic_bitmap: requires_atomic_bitmap,
            requires_osvm: requires_osvm,
            requires_worker: requires_worker,
            requires_provider: requires_provider,
            requires_backend_matcher: requires_backend_matcher,
            blocked_requirement_count: me.blockedCount(requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher),
            would_create_lifecycle_generation: 0,
            would_create_pointer_residence: 0,
            would_lookup_by_pointer: 0,
            would_release_arena_backing: 0,
            would_recycle_arena_backing: 0,
            would_use_segment_map: 0,
            would_execute_atomic_bitmap: 0,
            would_call_osvm: 0,
            would_run_thread: 0,
            would_activate_provider: 0,
            would_add_backend_matcher: 0,
        }
        me.last_reason = reason
        me.last_segment_id = summary_report.segment_id
        me.last_arena_id = summary_report.arena_id
        return me.makeExecutionReadinessMatrixReport(fields)
    }

    reject(reason, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionReadinessMatrixReport {
        me.reject_count += 1
        if reason == 1 {
            me.missing_summary_reject_count += 1
        }
        if reason == 2 {
            me.rejected_summary_reject_count += 1
        }
        if reason == 3 {
            me.not_ready_reject_count += 1
        }
        if reason == 4 {
            me.closed_substrate_reject_count += 1
        }
        if reason == 5 {
            me.lifecycle_requirement_reject_count += 1
        }
        if reason == 6 {
            me.pointer_residence_requirement_reject_count += 1
        }
        if reason == 7 {
            me.pointer_lookup_requirement_reject_count += 1
        }
        if reason == 8 {
            me.arena_release_requirement_reject_count += 1
        }
        if reason == 9 {
            me.arena_recycle_requirement_reject_count += 1
        }
        if reason == 10 {
            me.segment_map_requirement_reject_count += 1
        }
        if reason == 11 {
            me.atomic_bitmap_requirement_reject_count += 1
        }
        if reason == 12 {
            me.osvm_requirement_reject_count += 1
        }
        if reason == 13 {
            me.worker_requirement_reject_count += 1
        }
        if reason == 14 {
            me.provider_requirement_reject_count += 1
        }
        if reason == 15 {
            me.backend_matcher_requirement_reject_count += 1
        }
        return me.makeReport(0, reason, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
    }

    recordExecutionReadinessMatrix(summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionReadinessMatrixReport {
        me.inventory_count += 1

        if summary_report.applied_state_summary_present != 1 {
            return me.reject(1, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if summary_report.summarized != 1 {
            return me.reject(2, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if summary_report.applied_state_ready != 1 {
            return me.reject(3, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if summary_report.application_token <= 0 {
            return me.reject(3, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if summary_report.closed_substrate_summary != 0 {
            return me.reject(4, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if requires_lifecycle_generation != 0 {
            return me.reject(5, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if requires_pointer_residence != 0 {
            return me.reject(6, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if requires_pointer_lookup != 0 {
            return me.reject(7, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if requires_arena_backing_release != 0 {
            return me.reject(8, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if requires_arena_backing_recycle != 0 {
            return me.reject(9, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if requires_segment_map != 0 {
            return me.reject(10, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if requires_atomic_bitmap != 0 {
            return me.reject(11, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if requires_osvm != 0 {
            return me.reject(12, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if requires_worker != 0 {
            return me.reject(13, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if requires_provider != 0 {
            return me.reject(14, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }
        if requires_backend_matcher != 0 {
            return me.reject(15, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
        }

        me.accepted_count += 1
        return me.makeReport(1, 0, summary_report, requires_lifecycle_generation, requires_pointer_residence, requires_pointer_lookup, requires_arena_backing_release, requires_arena_backing_recycle, requires_segment_map, requires_atomic_bitmap, requires_osvm, requires_worker, requires_provider, requires_backend_matcher)
    }
}
