// segment_arena_backing_modeled_allocation_apply_diagnostic_box.hako -- MIMAP-273A
// Responsibility:
// - observe MIMAP-272A modeled allocation-apply inventory counters
// - publish scalar diagnostic summary facts for allocation-apply reject
//   categories
// Non-responsibility:
// - recording allocation-apply rows, creating real pointer residence,
//   pointer-derived lookup, arena backing, segment-map mutation, atomic bitmap
//   execution, OSVM calls, scheduling, providers, or backend shortcuts

record HakoAllocSegmentArenaBackingModeledAllocationApplyDiagnosticReportFields {
    observed: i64
    reason: i64
    diagnostic_present: i64
    inventory_count: i64
    accepted_count: i64
    reject_count: i64
    missing_plan_reject_count: i64
    rejected_plan_reject_count: i64
    invalid_apply_token_reject_count: i64
    invalid_apply_geometry_reject_count: i64
    closed_substrate_reject_count: i64
    last_reason: i64
    last_segment_id: i64
    last_arena_id: i64
    last_apply_token: i64
    last_report_accepted: i64
    last_report_reason: i64
    last_report_allocation_plan_present: i64
    last_report_modeled_allocation_apply_present: i64
    last_report_closed_substrate_blocker_count: i64
    last_report_plan_token: i64
    last_report_apply_token: i64
    last_report_applied_backing_bytes: usize
    last_report_applied_committed_bytes: usize
    last_report_remaining_source_bytes: usize
    allocation_apply_present: i64
    modeled_allocation_apply_present: i64
    missing_plan_reject_seen: i64
    rejected_plan_reject_seen: i64
    invalid_apply_token_reject_seen: i64
    invalid_apply_geometry_reject_seen: i64
    closed_substrate_reject_seen: i64
}

box HakoAllocSegmentArenaBackingModeledAllocationApplyDiagnosticReport {
    observed: i64 = 0
    reason: i64 = 0
    diagnostic_present: i64 = 1
    inventory_count: i64 = 0
    accepted_count: i64 = 0
    reject_count: i64 = 0
    missing_plan_reject_count: i64 = 0
    rejected_plan_reject_count: i64 = 0
    invalid_apply_token_reject_count: i64 = 0
    invalid_apply_geometry_reject_count: i64 = 0
    closed_substrate_reject_count: i64 = 0
    last_reason: i64 = 0
    last_segment_id: i64 = -1
    last_arena_id: i64 = -1
    last_apply_token: i64 = 0
    last_report_accepted: i64 = 0
    last_report_reason: i64 = 0
    last_report_allocation_plan_present: i64 = 0
    last_report_modeled_allocation_apply_present: i64 = 0
    last_report_closed_substrate_blocker_count: i64 = 0
    last_report_plan_token: i64 = 0
    last_report_apply_token: i64 = 0
    last_report_applied_backing_bytes: usize = 0
    last_report_applied_committed_bytes: usize = 0
    last_report_remaining_source_bytes: usize = 0
    allocation_apply_present: i64 = 0
    modeled_allocation_apply_present: i64 = 0
    missing_plan_reject_seen: i64 = 0
    rejected_plan_reject_seen: i64 = 0
    invalid_apply_token_reject_seen: i64 = 0
    invalid_apply_geometry_reject_seen: i64 = 0
    closed_substrate_reject_seen: i64 = 0
    would_create_pointer_residence: i64 = 0
    would_lookup_by_pointer: i64 = 0
    would_allocate_arena_backing: i64 = 0
    would_use_segment_map: i64 = 0
    would_execute_atomic_bitmap: i64 = 0
    would_call_osvm: i64 = 0
    would_run_thread: i64 = 0
    would_activate_provider: i64 = 0
    would_add_backend_matcher: i64 = 0
}

box HakoAllocSegmentArenaBackingModeledAllocationApplyDiagnostic {
    observe_count: i64 = 0
    accepted_summary_count: i64 = 0
    reject_summary_count: i64 = 0
    missing_inventory_reject_count: i64 = 0
    last_reason: i64 = 0

    markSeen(count): i64 {
        if count > 0 {
            return 1
        }
        return 0
    }

    makeAllocationApplyDiagnosticReport(fields: HakoAllocSegmentArenaBackingModeledAllocationApplyDiagnosticReportFields): HakoAllocSegmentArenaBackingModeledAllocationApplyDiagnosticReport {
        local result = new HakoAllocSegmentArenaBackingModeledAllocationApplyDiagnosticReport()
        result.observed = fields.observed
        result.reason = fields.reason
        result.diagnostic_present = fields.diagnostic_present
        result.inventory_count = fields.inventory_count
        result.accepted_count = fields.accepted_count
        result.reject_count = fields.reject_count
        result.missing_plan_reject_count = fields.missing_plan_reject_count
        result.rejected_plan_reject_count = fields.rejected_plan_reject_count
        result.invalid_apply_token_reject_count = fields.invalid_apply_token_reject_count
        result.invalid_apply_geometry_reject_count = fields.invalid_apply_geometry_reject_count
        result.closed_substrate_reject_count = fields.closed_substrate_reject_count
        result.last_reason = fields.last_reason
        result.last_segment_id = fields.last_segment_id
        result.last_arena_id = fields.last_arena_id
        result.last_apply_token = fields.last_apply_token
        result.last_report_accepted = fields.last_report_accepted
        result.last_report_reason = fields.last_report_reason
        result.last_report_allocation_plan_present = fields.last_report_allocation_plan_present
        result.last_report_modeled_allocation_apply_present = fields.last_report_modeled_allocation_apply_present
        result.last_report_closed_substrate_blocker_count = fields.last_report_closed_substrate_blocker_count
        result.last_report_plan_token = fields.last_report_plan_token
        result.last_report_apply_token = fields.last_report_apply_token
        result.last_report_applied_backing_bytes = fields.last_report_applied_backing_bytes
        result.last_report_applied_committed_bytes = fields.last_report_applied_committed_bytes
        result.last_report_remaining_source_bytes = fields.last_report_remaining_source_bytes
        result.allocation_apply_present = fields.allocation_apply_present
        result.modeled_allocation_apply_present = fields.modeled_allocation_apply_present
        result.missing_plan_reject_seen = fields.missing_plan_reject_seen
        result.rejected_plan_reject_seen = fields.rejected_plan_reject_seen
        result.invalid_apply_token_reject_seen = fields.invalid_apply_token_reject_seen
        result.invalid_apply_geometry_reject_seen = fields.invalid_apply_geometry_reject_seen
        result.closed_substrate_reject_seen = fields.closed_substrate_reject_seen
        return result
    }

    makeReport(observed, reason, inventory, last_report): HakoAllocSegmentArenaBackingModeledAllocationApplyDiagnosticReport {
        local allocation_apply_present = 0
        local modeled_allocation_apply_present = 0
        if observed == 1 {
            allocation_apply_present = last_report.allocation_apply_present
            modeled_allocation_apply_present = last_report.modeled_allocation_apply_present
        }

        local fields = HakoAllocSegmentArenaBackingModeledAllocationApplyDiagnosticReportFields {
            observed: observed,
            reason: reason,
            diagnostic_present: 1,
            inventory_count: inventory.inventory_count,
            accepted_count: inventory.accepted_count,
            reject_count: inventory.reject_count,
            missing_plan_reject_count: inventory.missing_plan_reject_count,
            rejected_plan_reject_count: inventory.rejected_plan_reject_count,
            invalid_apply_token_reject_count: inventory.invalid_apply_token_reject_count,
            invalid_apply_geometry_reject_count: inventory.invalid_apply_geometry_reject_count,
            closed_substrate_reject_count: inventory.closed_substrate_reject_count,
            last_reason: inventory.last_reason,
            last_segment_id: inventory.last_segment_id,
            last_arena_id: inventory.last_arena_id,
            last_apply_token: inventory.last_apply_token,
            last_report_accepted: last_report.accepted,
            last_report_reason: last_report.reason,
            last_report_allocation_plan_present: last_report.allocation_plan_present,
            last_report_modeled_allocation_apply_present: last_report.modeled_allocation_apply_present,
            last_report_closed_substrate_blocker_count: last_report.closed_substrate_blocker_count,
            last_report_plan_token: last_report.plan_token,
            last_report_apply_token: last_report.apply_token,
            last_report_applied_backing_bytes: last_report.applied_backing_bytes,
            last_report_applied_committed_bytes: last_report.applied_committed_bytes,
            last_report_remaining_source_bytes: last_report.remaining_source_bytes,
            allocation_apply_present: allocation_apply_present,
            modeled_allocation_apply_present: modeled_allocation_apply_present,
            missing_plan_reject_seen: me.markSeen(inventory.missing_plan_reject_count),
            rejected_plan_reject_seen: me.markSeen(inventory.rejected_plan_reject_count),
            invalid_apply_token_reject_seen: me.markSeen(inventory.invalid_apply_token_reject_count),
            invalid_apply_geometry_reject_seen: me.markSeen(inventory.invalid_apply_geometry_reject_count),
            closed_substrate_reject_seen: me.markSeen(inventory.closed_substrate_reject_count),
        }
        me.last_reason = reason
        return me.makeAllocationApplyDiagnosticReport(fields)
    }

    reject(reason, inventory, last_report): HakoAllocSegmentArenaBackingModeledAllocationApplyDiagnosticReport {
        me.reject_summary_count += 1
        if reason == 1 {
            me.missing_inventory_reject_count += 1
        }
        return me.makeReport(0, reason, inventory, last_report)
    }

    observeAllocationApplyDiagnostics(inventory, last_report): HakoAllocSegmentArenaBackingModeledAllocationApplyDiagnosticReport {
        me.observe_count += 1

        if inventory.inventory_count <= 0 {
            return me.reject(1, inventory, last_report)
        }
        if last_report.allocation_apply_present != 1 {
            return me.reject(1, inventory, last_report)
        }
        if last_report.modeled_allocation_apply_present != 1 {
            return me.reject(1, inventory, last_report)
        }

        me.accepted_summary_count += 1
        me.last_reason = 0
        return me.makeReport(1, last_report.reason, inventory, last_report)
    }
}
