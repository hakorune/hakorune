        result.would_use_segment_map = fields.would_use_segment_map
        result.would_execute_atomic_bitmap = fields.would_execute_atomic_bitmap
        result.would_call_osvm = fields.would_call_osvm
        result.would_run_thread = fields.would_run_thread
        result.would_activate_provider = fields.would_activate_provider
        result.would_add_backend_matcher = fields.would_add_backend_matcher
        return result
    }

    makeReport(observed, reason, matrix_inventory, matrix_report): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportRequirementMatrixDiagnosticReport {
        local fields = HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportRequirementMatrixDiagnosticReportFields {
            observed: observed,
            reason: reason,
            diagnostic_present: 1,
            matrix_accepted: matrix_report.accepted,
            matrix_reason: matrix_report.reason,
            matrix_present: matrix_report.matrix_present,
            requirements_satisfied: matrix_report.requirements_satisfied,
            requirement_count: matrix_report.requirement_count,
            unsatisfied_requirement_count: matrix_report.requirement_count,
            lifecycle_generation_required: matrix_report.lifecycle_generation_required,
            pointer_residence_required: matrix_report.pointer_residence_required,
            pointer_lookup_required: matrix_report.pointer_lookup_required,
            arena_release_required: matrix_report.arena_release_required,
            arena_recycle_required: matrix_report.arena_recycle_required,
            segment_map_required: matrix_report.segment_map_required,
            atomic_bitmap_required: matrix_report.atomic_bitmap_required,
            osvm_required: matrix_report.osvm_required,
            worker_tls_required: matrix_report.worker_tls_required,
            provider_required: matrix_report.provider_required,
            backend_matcher_required: matrix_report.backend_matcher_required,
            matrix_count: matrix_inventory.matrix_count,
            accepted_count: matrix_inventory.accepted_count,
            reject_count: matrix_inventory.reject_count,
            observed_count: me.observed_count,
            accepted_matrix_count: me.accepted_matrix_count,
            rejected_matrix_count: me.rejected_matrix_count,
            unsatisfied_matrix_count: me.unsatisfied_matrix_count,
            missing_inventory_reject_count: me.missing_inventory_reject_count,
            missing_report_reject_count: me.missing_report_reject_count,
            last_reason: me.last_reason,
            report_segment_id: matrix_report.report_segment_id,
            report_arena_id: matrix_report.report_arena_id,
            report_release_applied_recycle_token: matrix_report.report_release_applied_recycle_token,
            report_continuation_token: matrix_report.report_continuation_token,
            report_application_token: matrix_report.report_application_token,
            report_applied_backing_bytes: matrix_report.report_applied_backing_bytes,
            report_applied_committed_bytes: matrix_report.report_applied_committed_bytes,
            report_remaining_source_bytes: matrix_report.report_remaining_source_bytes,
            would_create_lifecycle_generation: matrix_report.would_create_lifecycle_generation,
            would_create_pointer_residence: matrix_report.would_create_pointer_residence,
            would_lookup_by_pointer: matrix_report.would_lookup_by_pointer,
            would_release_arena_backing: matrix_report.would_release_arena_backing,
            would_recycle_arena_backing: matrix_report.would_recycle_arena_backing,
            would_use_segment_map: matrix_report.would_use_segment_map,
            would_execute_atomic_bitmap: matrix_report.would_execute_atomic_bitmap,
            would_call_osvm: matrix_report.would_call_osvm,
            would_run_thread: matrix_report.would_run_thread,
            would_activate_provider: matrix_report.would_activate_provider,
            would_add_backend_matcher: matrix_report.would_add_backend_matcher,
        }
        return me.makeExecutionSupportRequirementMatrixDiagnosticReport(fields)
    }

    observeExecutionSupportRequirementMatrix(matrix_inventory, matrix_report): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportRequirementMatrixDiagnosticReport {
        me.observed_count += 1

        if matrix_inventory.matrix_count == 0 {
            me.rejected_matrix_count += 1
            me.missing_inventory_reject_count += 1
            me.last_reason = 1
            return me.makeReport(0, 1, matrix_inventory, matrix_report)
        }

        if matrix_report.matrix_present != 1 {
            me.rejected_matrix_count += 1
            me.missing_report_reject_count += 1
            me.last_reason = 2
            return me.makeReport(0, 2, matrix_inventory, matrix_report)
        }

        if matrix_report.accepted != 1 {
            me.rejected_matrix_count += 1
            me.last_reason = 3
            return me.makeReport(0, 3, matrix_inventory, matrix_report)
        }

        me.accepted_matrix_count += 1
        if matrix_report.requirements_satisfied == 0 {
            me.unsatisfied_matrix_count += 1
        }
        me.last_reason = 0
        return me.makeReport(1, 0, matrix_inventory, matrix_report)
    }
}
