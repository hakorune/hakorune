        result.matrix_accepted = fields.matrix_accepted
        result.matrix_reason = fields.matrix_reason
        result.matrix_present = fields.matrix_present
        result.requirements_satisfied = fields.requirements_satisfied
        result.requirement_count = fields.requirement_count
        result.unsatisfied_requirement_count = fields.unsatisfied_requirement_count
        result.lifecycle_generation_required = fields.lifecycle_generation_required
        result.pointer_residence_required = fields.pointer_residence_required
        result.pointer_lookup_required = fields.pointer_lookup_required
        result.arena_release_required = fields.arena_release_required
