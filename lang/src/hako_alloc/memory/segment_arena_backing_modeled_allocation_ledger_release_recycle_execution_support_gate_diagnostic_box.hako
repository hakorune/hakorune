box HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportGateDiagnostic {
    observed_count: i64 = 0
    accepted_gate_count: i64 = 0
    rejected_gate_count: i64 = 0
    closed_gate_count: i64 = 0
    blocked_gate_count: i64 = 0
    missing_inventory_reject_count: i64 = 0
    missing_report_reject_count: i64 = 0
    last_reason: i64 = 0

    makeExecutionSupportGateDiagnosticReport(fields: HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportGateDiagnosticReportFields): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportGateDiagnosticReport {
        local result = new HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportGateDiagnosticReport()
        result.observed = fields.observed
        result.reason = fields.reason
        result.diagnostic_present = fields.diagnostic_present
        result.gate_accepted = fields.gate_accepted
        result.gate_reason = fields.gate_reason
        result.gate_present = fields.gate_present
        result.outcome_present = fields.outcome_present
        result.outcome_accepted = fields.outcome_accepted
        result.outcome_reason = fields.outcome_reason
        result.execution_intent_requested = fields.execution_intent_requested
        result.execution_supported = fields.execution_supported
        result.execution_gate_open = fields.execution_gate_open
        result.blocked_by_unsupported_outcome = fields.blocked_by_unsupported_outcome
        result.gate_count = fields.gate_count
        result.accepted_count = fields.accepted_count
        result.reject_count = fields.reject_count
        result.observed_count = fields.observed_count
        result.accepted_gate_count = fields.accepted_gate_count
        result.rejected_gate_count = fields.rejected_gate_count
        result.closed_gate_count = fields.closed_gate_count
        result.blocked_gate_count = fields.blocked_gate_count
        result.missing_inventory_reject_count = fields.missing_inventory_reject_count
        result.missing_report_reject_count = fields.missing_report_reject_count
        result.last_reason = fields.last_reason
        result.report_segment_id = fields.report_segment_id
        result.report_arena_id = fields.report_arena_id
        result.report_lifetime_generation = fields.report_lifetime_generation
        result.report_release_applied_recycle_token = fields.report_release_applied_recycle_token
        result.report_continuation_token = fields.report_continuation_token
        result.report_application_token = fields.report_application_token
        result.report_applied_backing_bytes = fields.report_applied_backing_bytes
        result.report_applied_committed_bytes = fields.report_applied_committed_bytes
        result.report_remaining_source_bytes = fields.report_remaining_source_bytes
        result.would_create_lifecycle_generation = fields.would_create_lifecycle_generation
        result.would_create_pointer_residence = fields.would_create_pointer_residence
        result.would_lookup_by_pointer = fields.would_lookup_by_pointer
        result.would_release_arena_backing = fields.would_release_arena_backing
        result.would_recycle_arena_backing = fields.would_recycle_arena_backing
        result.would_use_segment_map = fields.would_use_segment_map
        result.would_execute_atomic_bitmap = fields.would_execute_atomic_bitmap
        result.would_call_osvm = fields.would_call_osvm
        result.would_run_thread = fields.would_run_thread
        result.would_activate_provider = fields.would_activate_provider
        result.would_add_backend_matcher = fields.would_add_backend_matcher
        return result
    }

    makeReport(observed, reason, gate_inventory, gate_report): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportGateDiagnosticReport {
        local fields = HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportGateDiagnosticReportFields {
            observed: observed,
            reason: reason,
            diagnostic_present: 1,
            gate_accepted: gate_report.accepted,
            gate_reason: gate_report.reason,
            gate_present: gate_report.gate_present,
            outcome_present: gate_report.outcome_present,
            outcome_accepted: gate_report.outcome_accepted,
            outcome_reason: gate_report.outcome_reason,
            execution_intent_requested: gate_report.execution_intent_requested,
            execution_supported: gate_report.execution_supported,
            execution_gate_open: gate_report.execution_gate_open,
            blocked_by_unsupported_outcome: gate_report.blocked_by_unsupported_outcome,
            gate_count: gate_inventory.gate_count,
            accepted_count: gate_inventory.accepted_count,
            reject_count: gate_inventory.reject_count,
            observed_count: me.observed_count,
            accepted_gate_count: me.accepted_gate_count,
            rejected_gate_count: me.rejected_gate_count,
            closed_gate_count: me.closed_gate_count,
            blocked_gate_count: me.blocked_gate_count,
            missing_inventory_reject_count: me.missing_inventory_reject_count,
            missing_report_reject_count: me.missing_report_reject_count,
            last_reason: me.last_reason,
            report_segment_id: gate_report.report_segment_id,
            report_arena_id: gate_report.report_arena_id,
            report_lifetime_generation: gate_report.report_lifetime_generation,
            report_release_applied_recycle_token: gate_report.report_release_applied_recycle_token,
            report_continuation_token: gate_report.report_continuation_token,
            report_application_token: gate_report.report_application_token,
            report_applied_backing_bytes: gate_report.report_applied_backing_bytes,
            report_applied_committed_bytes: gate_report.report_applied_committed_bytes,
            report_remaining_source_bytes: gate_report.report_remaining_source_bytes,
            would_create_lifecycle_generation: gate_report.would_create_lifecycle_generation,
            would_create_pointer_residence: gate_report.would_create_pointer_residence,
            would_lookup_by_pointer: gate_report.would_lookup_by_pointer,
            would_release_arena_backing: gate_report.would_release_arena_backing,
            would_recycle_arena_backing: gate_report.would_recycle_arena_backing,
            would_use_segment_map: gate_report.would_use_segment_map,
            would_execute_atomic_bitmap: gate_report.would_execute_atomic_bitmap,
            would_call_osvm: gate_report.would_call_osvm,
            would_run_thread: gate_report.would_run_thread,
            would_activate_provider: gate_report.would_activate_provider,
            would_add_backend_matcher: gate_report.would_add_backend_matcher,
        }
        return me.makeExecutionSupportGateDiagnosticReport(fields)
    }

    observeExecutionSupportGate(gate_inventory, gate_report): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportGateDiagnosticReport {
        me.observed_count += 1

        if gate_inventory.gate_count == 0 {
            me.rejected_gate_count += 1
            me.missing_inventory_reject_count += 1
            me.last_reason = 1
            return me.makeReport(0, 1, gate_inventory, gate_report)
        }

        if gate_report.gate_present != 1 {
            me.rejected_gate_count += 1
            me.missing_report_reject_count += 1
            me.last_reason = 2
            return me.makeReport(0, 2, gate_inventory, gate_report)
        }

        if gate_report.accepted != 1 {
            me.rejected_gate_count += 1
            me.last_reason = 3
            return me.makeReport(0, 3, gate_inventory, gate_report)
        }

        me.accepted_gate_count += 1
        if gate_report.execution_gate_open == 0 {
            me.closed_gate_count += 1
        }
        if gate_report.blocked_by_unsupported_outcome != 0 {
            me.blocked_gate_count += 1
        }
        me.last_reason = 0
        return me.makeReport(1, 0, gate_inventory, gate_report)
    }
}
