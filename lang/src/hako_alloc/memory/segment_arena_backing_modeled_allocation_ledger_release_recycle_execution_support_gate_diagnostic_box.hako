// segment_arena_backing_modeled_allocation_ledger_release_recycle_execution_support_gate_diagnostic_box.hako -- MIMAP-325A
// Responsibility:
// - observe MIMAP-324A support gate facts and publish scalar/model diagnostic
//   facts
// - keep diagnostics observer-only before any real release/recycle execution
//   opens
// Non-responsibility:
// - recording support gate rows, executing real release/recycle, lifecycle
//   generation, pointer residence, segment-map mutation, atomic bitmap
//   execution, OSVM calls, scheduling, providers, or backend shortcuts

record HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportGateDiagnosticReportFields {
    observed: i64
    reason: i64
    diagnostic_present: i64
    gate_accepted: i64
    gate_reason: i64
    gate_present: i64
    outcome_present: i64
    outcome_accepted: i64
