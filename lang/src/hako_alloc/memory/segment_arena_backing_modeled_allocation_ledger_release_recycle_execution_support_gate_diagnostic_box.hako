    reject_count: i64 = 0
    observed_count: i64 = 0
    accepted_gate_count: i64 = 0
    rejected_gate_count: i64 = 0
    closed_gate_count: i64 = 0
    blocked_gate_count: i64 = 0
    missing_inventory_reject_count: i64 = 0
    missing_report_reject_count: i64 = 0
    last_reason: i64 = 0
    report_segment_id: i64 = -1
    report_arena_id: i64 = -1
