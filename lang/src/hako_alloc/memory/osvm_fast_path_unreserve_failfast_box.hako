// osvm_fast_path_unreserve_failfast_box.hako -- MIMAP-046A diagnostics owner
// Responsibility:
// - wrap the MIMAP-045A success route with scalar diagnostics for duplicate,
//   unknown, and not-decommitted fast-path unreserve requests
// - reject invalid requests before the page-source unreserve adapter executes
// Non-responsibility:
// - direct page-source calls, direct OSVM calls, success-route ownership,
//   post-unreserve reuse, OS release route, provider
//   activation, allocator replacement, hooks, atomics, TLS, remote-free
//   execution, scheduler policy changes, or user-facing concurrency semantics

using selfhost.hako_alloc.memory.osvm_fast_path_unreserve_route_box as HakoAllocOsVmFastPathUnreserveRouteBox

box HakoAllocOsVmFastPathUnreserveFailFastReport {
    status: i64 = 0
    reason: i64 = 0
    page_id: i64 = -1
    unreserve_attempted: i64 = 0
    unreserve_ok: i64 = 0
    adapter_call_count: i64 = 0
    adapter_success_count: i64 = 0
    adapter_reject_count: i64 = 0
}

box HakoAllocOsVmFastPathUnreserveFailFastRoute {
    route: HakoAllocOsVmFastPathUnreserveRoute
    unreserved_page_ids: ArrayBox = new ArrayBox()
    attempt_count: i64 = 0
    success_count: i64 = 0
    reject_count: i64 = 0
    duplicate_reject_count: i64 = 0
    unknown_reject_count: i64 = 0
    stale_reject_count: i64 = 0
    last_status: i64 = 0
    last_reason: i64 = 0
    last_page_id: i64 = -1

    birth(bin, block_size, page_capacity, max_decommit_bytes, max_recommit_bytes) {
        me.route = new HakoAllocOsVmFastPathUnreserveRoute(bin, block_size, page_capacity, max_decommit_bytes, max_recommit_bytes)
    }

    ok_reason() {
        return 0
    }

    duplicate_reason() {
        return 1
    }

    unknown_reason() {
        return 2
    }

    not_decommitted_reason() {
        return 3
    }

    route_reject_reason() {
        return 4
    }

    allocate(size) {
        return me.route.allocate(size)
    }

    release(handle) {
        return me.route.release(handle)
    }

    purgeOne(max_scan_pages) {
        return me.route.purgeOne(max_scan_pages)
    }

    report(status, reason, page_id, unreserve_attempted, unreserve_ok) {
        local result = new HakoAllocOsVmFastPathUnreserveFailFastReport()
        result.status = status
        result.reason = reason
        result.page_id = page_id
        result.unreserve_attempted = unreserve_attempted
        result.unreserve_ok = unreserve_ok
        result.adapter_call_count = me.route.unreserve_adapter.call_count
        result.adapter_success_count = me.route.unreserve_adapter.success_count
        result.adapter_reject_count = me.route.unreserve_adapter.reject_count
        return result
    }

    pageIsKnown(page_id) {
        if page_id < 0 {
            return 0
        }
        if page_id >= me.route.reuse_route.purge_route.heap.next_page_id {
            return 0
        }
        return 1
    }

    alreadyUnreserved(page_id) {
        local count = me.unreserved_page_ids.length()
        local i = 0
        loop(i < count) {
            local seen = me.unreserved_page_ids.get(i)
            if seen == page_id {
                return 1
            }
            i = i + 1
        }
        return 0
    }

    rememberUnreserved(page_id) {
        me.unreserved_page_ids.push(page_id)
        return 1
    }

    reject(reason, page_id) {
        me.reject_count = me.reject_count + 1
        me.last_status = 0
        me.last_reason = reason
        me.last_page_id = page_id
        if reason == me.duplicate_reason() {
            me.duplicate_reject_count = me.duplicate_reject_count + 1
        }
        if reason == me.unknown_reason() {
            me.unknown_reject_count = me.unknown_reject_count + 1
        }
        if reason == me.not_decommitted_reason() {
            me.stale_reject_count = me.stale_reject_count + 1
        }
        return me.report(0, reason, page_id, 0, 0)
    }

    unreservePurgedPage(page_id) {
        me.attempt_count = me.attempt_count + 1

        if me.pageIsKnown(page_id) != 1 {
            return me.reject(me.unknown_reason(), page_id)
        }

        if me.alreadyUnreserved(page_id) == 1 {
            return me.reject(me.duplicate_reason(), page_id)
        }

        if me.route.markerIsMarked(page_id) != 1 {
            return me.reject(me.not_decommitted_reason(), page_id)
        }

        local unreserve_report = me.route.unreservePurgedPage(page_id)
        if unreserve_report.status == 0 {
            me.rememberUnreserved(page_id)
            me.success_count = me.success_count + 1
            me.last_status = 1
            me.last_reason = me.ok_reason()
            me.last_page_id = page_id
            return me.report(1, me.ok_reason(), page_id, unreserve_report.unreserve_attempted, unreserve_report.unreserve_ok)
        }

        me.reject_count = me.reject_count + 1
        me.last_status = 0
        me.last_reason = me.route_reject_reason()
        me.last_page_id = page_id
        return me.report(0, me.route_reject_reason(), page_id, unreserve_report.unreserve_attempted, unreserve_report.unreserve_ok)
    }
}
