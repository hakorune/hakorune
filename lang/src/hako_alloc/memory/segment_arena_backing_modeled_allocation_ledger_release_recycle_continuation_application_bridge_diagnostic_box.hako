box HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleContinuationApplicationBridgeDiagnostic {
    observe_count: i64 = 0
    accepted_summary_count: i64 = 0
    rejected_summary_count: i64 = 0
    missing_inventory_reject_count: i64 = 0
    missing_report_reject_count: i64 = 0
    rejected_application_summary_count: i64 = 0
    missing_token_reject_count: i64 = 0
    last_reason: i64 = 0

    makeContinuationApplicationDiagnosticReport(fields: HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleContinuationApplicationBridgeDiagnosticReportFields): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleContinuationApplicationBridgeDiagnosticReport {
        local result = new HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleContinuationApplicationBridgeDiagnosticReport()
        result.observed = fields.observed
        result.reason = fields.reason
        result.diagnostic_present = fields.diagnostic_present
        result.application_accepted = fields.application_accepted
        result.application_reason = fields.application_reason
        result.existing_index = fields.existing_index
        result.inventory_count = fields.inventory_count
        result.accepted_count = fields.accepted_count
        result.reject_count = fields.reject_count
        result.missing_continuation_reject_count = fields.missing_continuation_reject_count
        result.rejected_continuation_reject_count = fields.rejected_continuation_reject_count
        result.invalid_application_token_reject_count = fields.invalid_application_token_reject_count
        result.duplicate_application_token_reject_count = fields.duplicate_application_token_reject_count
        result.closed_substrate_reject_count = fields.closed_substrate_reject_count
        result.rejected_application_summary_count = fields.rejected_application_summary_count
        result.last_reason = fields.last_reason
        result.last_segment_id = fields.last_segment_id
        result.last_arena_id = fields.last_arena_id
        result.last_continuation_token = fields.last_continuation_token
        result.last_application_token = fields.last_application_token
        result.report_accepted = fields.report_accepted
        result.report_reason = fields.report_reason
        result.report_row_index = fields.report_row_index
        result.report_segment_id = fields.report_segment_id
        result.report_arena_id = fields.report_arena_id
        result.report_lifetime_generation = fields.report_lifetime_generation
        result.report_release_applied_recycle_token = fields.report_release_applied_recycle_token
        result.report_continuation_token = fields.report_continuation_token
        result.report_application_token = fields.report_application_token
        result.report_applied_backing_bytes = fields.report_applied_backing_bytes
        result.report_applied_committed_bytes = fields.report_applied_committed_bytes
        result.report_remaining_source_bytes = fields.report_remaining_source_bytes
        result.continuation_application_present = fields.continuation_application_present
        result.modeled_continuation_application_present = fields.modeled_continuation_application_present
        result.lifecycle_continuation_present = fields.lifecycle_continuation_present
        result.lifecycle_continuation_reason = fields.lifecycle_continuation_reason
        result.closed_substrate_blocker_count = fields.closed_substrate_blocker_count
        result.would_create_pointer_residence = fields.would_create_pointer_residence
        result.would_lookup_by_pointer = fields.would_lookup_by_pointer
        result.would_release_arena_backing = fields.would_release_arena_backing
        result.would_use_segment_map = fields.would_use_segment_map
        result.would_execute_atomic_bitmap = fields.would_execute_atomic_bitmap
        result.would_call_osvm = fields.would_call_osvm
        result.would_run_thread = fields.would_run_thread
        result.would_activate_provider = fields.would_activate_provider
        result.would_add_backend_matcher = fields.would_add_backend_matcher
        return result
    }

    makeReport(observed, reason, application_accepted, existing_index, inventory, application_report): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleContinuationApplicationBridgeDiagnosticReport {
        local continuation_application_present = 0
        local modeled_continuation_application_present = 0
        if observed == 1 {
            continuation_application_present = application_report.continuation_application_present
            modeled_continuation_application_present = application_report.modeled_continuation_application_present
        }

        local fields = HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleContinuationApplicationBridgeDiagnosticReportFields {
            observed: observed,
            reason: reason,
            diagnostic_present: 1,
            application_accepted: application_accepted,
            application_reason: application_report.reason,
            existing_index: existing_index,
            inventory_count: inventory.inventory_count,
            accepted_count: inventory.accepted_count,
            reject_count: inventory.reject_count,
            missing_continuation_reject_count: inventory.missing_continuation_reject_count,
            rejected_continuation_reject_count: inventory.rejected_continuation_reject_count,
            invalid_application_token_reject_count: inventory.invalid_application_token_reject_count,
            duplicate_application_token_reject_count: inventory.duplicate_application_token_reject_count,
            closed_substrate_reject_count: inventory.closed_substrate_reject_count,
            rejected_application_summary_count: me.rejected_application_summary_count,
            last_reason: inventory.last_reason,
            last_segment_id: inventory.last_segment_id,
            last_arena_id: inventory.last_arena_id,
            last_continuation_token: inventory.last_continuation_token,
            last_application_token: inventory.last_application_token,
            report_accepted: application_report.accepted,
            report_reason: application_report.reason,
            report_row_index: application_report.row_index,
            report_segment_id: application_report.segment_id,
            report_arena_id: application_report.arena_id,
            report_lifetime_generation: application_report.lifetime_generation,
            report_release_applied_recycle_token: application_report.release_applied_recycle_token,
            report_continuation_token: application_report.continuation_token,
            report_application_token: application_report.application_token,
            report_applied_backing_bytes: application_report.applied_backing_bytes,
            report_applied_committed_bytes: application_report.applied_committed_bytes,
            report_remaining_source_bytes: application_report.remaining_source_bytes,
            continuation_application_present: continuation_application_present,
            modeled_continuation_application_present: modeled_continuation_application_present,
            lifecycle_continuation_present: application_report.lifecycle_continuation_present,
            lifecycle_continuation_reason: application_report.lifecycle_continuation_reason,
            closed_substrate_blocker_count: application_report.closed_substrate_blocker_count,
            would_create_pointer_residence: 0,
            would_lookup_by_pointer: 0,
            would_release_arena_backing: 0,
            would_use_segment_map: 0,
            would_execute_atomic_bitmap: 0,
            would_call_osvm: 0,
            would_run_thread: 0,
            would_activate_provider: 0,
            would_add_backend_matcher: 0,
        }
        me.last_reason = reason
        return me.makeContinuationApplicationDiagnosticReport(fields)
    }

    reject(reason, inventory, application_report): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleContinuationApplicationBridgeDiagnosticReport {
        me.rejected_summary_count += 1
        if reason == 1 {
            me.missing_inventory_reject_count += 1
        }
        if reason == 2 {
            me.missing_report_reject_count += 1
        }
        if reason == 4 {
            me.missing_token_reject_count += 1
        }
        return me.makeReport(0, reason, 0, -1, inventory, application_report)
    }

    observeContinuationApplicationBridge(inventory, application_report): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleContinuationApplicationBridgeDiagnosticReport {
        me.observe_count += 1

        if inventory.inventory_count <= 0 {
            return me.reject(1, inventory, application_report)
        }
        if application_report.continuation_application_present != 1 {
            return me.reject(2, inventory, application_report)
        }
        if application_report.modeled_continuation_application_present != 1 {
            return me.reject(2, inventory, application_report)
        }
        if application_report.accepted != 1 {
            me.rejected_summary_count += 1
            me.rejected_application_summary_count += 1
            return me.makeReport(1, 3, 0, application_report.row_index, inventory, application_report)
        }
        if application_report.application_token <= 0 {
            return me.reject(4, inventory, application_report)
        }
        if inventory.hasApplicationToken(application_report.application_token) != 1 {
            return me.reject(4, inventory, application_report)
        }

        me.accepted_summary_count += 1
        return me.makeReport(1, 0, 1, application_report.row_index, inventory, application_report)
    }
}
