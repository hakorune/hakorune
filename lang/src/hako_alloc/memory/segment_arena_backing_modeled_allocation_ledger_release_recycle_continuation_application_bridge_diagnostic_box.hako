// segment_arena_backing_modeled_allocation_ledger_release_recycle_continuation_application_bridge_diagnostic_box.hako -- MIMAP-305A
// Responsibility:
// - observe MIMAP-304A release/recycle continuation application bridge facts
//   and publish scalar/model diagnostic summary facts
// - keep the diagnostic observer-only; it does not create another application
//   row or run real arena backing release/recycle behavior
// Non-responsibility:
// - creating real lifecycle generation, pointer residence, pointer-derived
//   lookup, arena backing release/allocation, segment-map mutation, atomic
//   bitmap execution, OSVM calls, scheduling, providers, or backend shortcuts

record HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleContinuationApplicationBridgeDiagnosticReportFields {
    observed: i64
    reason: i64
    diagnostic_present: i64
    application_accepted: i64
    application_reason: i64
    existing_index: i64
    inventory_count: i64
    accepted_count: i64
    reject_count: i64
    missing_continuation_reject_count: i64
    rejected_continuation_reject_count: i64
    invalid_application_token_reject_count: i64
    duplicate_application_token_reject_count: i64
    closed_substrate_reject_count: i64
    rejected_application_summary_count: i64
    last_reason: i64
    last_segment_id: i64
    last_arena_id: i64
    last_continuation_token: i64
    last_application_token: i64
    report_accepted: i64
    report_reason: i64
    report_row_index: i64
    report_segment_id: i64
    report_arena_id: i64
    report_lifetime_generation: i64
    report_release_applied_recycle_token: i64
    report_continuation_token: i64
    report_application_token: i64
    report_applied_backing_bytes: usize
    report_applied_committed_bytes: usize
    report_remaining_source_bytes: usize
    continuation_application_present: i64
    modeled_continuation_application_present: i64
    lifecycle_continuation_present: i64
    lifecycle_continuation_reason: i64
    closed_substrate_blocker_count: i64
    would_create_pointer_residence: i64
    would_lookup_by_pointer: i64
    would_release_arena_backing: i64
    would_use_segment_map: i64
    would_execute_atomic_bitmap: i64
    would_call_osvm: i64
    would_run_thread: i64
    would_activate_provider: i64
    would_add_backend_matcher: i64
}

box HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleContinuationApplicationBridgeDiagnosticReport {
    observed: i64 = 0
    reason: i64 = 0
    diagnostic_present: i64 = 1
    application_accepted: i64 = 0
    application_reason: i64 = 0
    existing_index: i64 = -1
    inventory_count: i64 = 0
