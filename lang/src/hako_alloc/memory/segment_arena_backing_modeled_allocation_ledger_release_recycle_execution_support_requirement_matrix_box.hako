        result.would_run_thread = fields.would_run_thread
        result.would_activate_provider = fields.would_activate_provider
        result.would_add_backend_matcher = fields.would_add_backend_matcher
        return result
    }

    makeReport(accepted, reason, matrix_present, gate_report): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportRequirementMatrixReport {
        local fields = HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportRequirementMatrixReportFields {
            accepted: accepted,
            reason: reason,
            matrix_present: matrix_present,
            gate_present: gate_report.gate_present,
            gate_accepted: gate_report.accepted,
            gate_reason: gate_report.reason,
            execution_gate_open: gate_report.execution_gate_open,
            blocked_by_unsupported_outcome: gate_report.blocked_by_unsupported_outcome,
            requirements_satisfied: 0,
            requirement_count: 11,
            lifecycle_generation_required: matrix_present,
            pointer_residence_required: matrix_present,
            pointer_lookup_required: matrix_present,
            arena_release_required: matrix_present,
            arena_recycle_required: matrix_present,
            segment_map_required: matrix_present,
            atomic_bitmap_required: matrix_present,
            osvm_required: matrix_present,
            worker_tls_required: matrix_present,
            provider_required: matrix_present,
            backend_matcher_required: matrix_present,
            matrix_count: me.matrix_count,
            accepted_count: me.accepted_count,
            reject_count: me.reject_count,
            missing_gate_reject_count: me.missing_gate_reject_count,
            rejected_gate_reject_count: me.rejected_gate_reject_count,
            open_gate_reject_count: me.open_gate_reject_count,
            last_reason: me.last_reason,
            report_segment_id: gate_report.report_segment_id,
            report_arena_id: gate_report.report_arena_id,
            report_lifetime_generation: gate_report.report_lifetime_generation,
            report_release_applied_recycle_token: gate_report.report_release_applied_recycle_token,
            report_continuation_token: gate_report.report_continuation_token,
            report_application_token: gate_report.report_application_token,
            report_applied_backing_bytes: gate_report.report_applied_backing_bytes,
            report_applied_committed_bytes: gate_report.report_applied_committed_bytes,
            report_remaining_source_bytes: gate_report.report_remaining_source_bytes,
            would_create_lifecycle_generation: 0,
            would_create_pointer_residence: 0,
            would_lookup_by_pointer: 0,
            would_release_arena_backing: 0,
            would_recycle_arena_backing: 0,
            would_use_segment_map: 0,
            would_execute_atomic_bitmap: 0,
            would_call_osvm: 0,
            would_run_thread: 0,
            would_activate_provider: 0,
            would_add_backend_matcher: 0,
        }
        return me.makeExecutionSupportRequirementMatrixReport(fields)
    }

    recordExecutionSupportRequirementMatrix(gate_report): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportRequirementMatrixReport {
        me.matrix_count += 1

        if gate_report.gate_present != 1 {
            me.reject_count += 1
            me.missing_gate_reject_count += 1
            me.last_reason = 1
            return me.makeReport(0, 1, 0, gate_report)
        }

        if gate_report.accepted != 1 {
            me.reject_count += 1
            me.rejected_gate_reject_count += 1
            me.last_reason = 2
            return me.makeReport(0, 2, 0, gate_report)
        }

        if gate_report.execution_gate_open != 0 {
            me.reject_count += 1
            me.open_gate_reject_count += 1
            me.last_reason = 3
            return me.makeReport(0, 3, 0, gate_report)
        }

        me.accepted_count += 1
        me.last_reason = 0
        return me.makeReport(1, 0, 1, gate_report)
    }
}
