box HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportRequirementMatrixInventory {
    matrix_count: i64 = 0
    accepted_count: i64 = 0
    reject_count: i64 = 0
    missing_gate_reject_count: i64 = 0
    rejected_gate_reject_count: i64 = 0
    open_gate_reject_count: i64 = 0
    last_reason: i64 = 0

    makeExecutionSupportRequirementMatrixReport(fields: HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportRequirementMatrixReportFields): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportRequirementMatrixReport {
        local result = new HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionSupportRequirementMatrixReport()
        result.accepted = fields.accepted
        result.reason = fields.reason
        result.matrix_present = fields.matrix_present
        result.gate_present = fields.gate_present
