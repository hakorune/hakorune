// aligned_small_meta_store_box.hako -- C205c aligned-small metadata store
// Responsibility: own aligned-small allocation metadata behind a record-shaped
// append/read seam. Storage remains scalar columns until ArrayBox packed-record
// compiler auto-use is explicitly enabled by a later row.

using selfhost.hako_alloc.memory.allocator_metadata_records as HakoAllocMetadataRecords

box HakoAllocAlignedSmallMetaStore {
    ptrs: ArrayBox = new ArrayBox()
    alignments: ArrayBox = new ArrayBox()
    padded_sizes: ArrayBox = new ArrayBox()
    count: i64 = 0

    append(ptr, alignment, padded_size) {
        local meta = new HakoAllocAlignedSmallMeta(ptr, alignment, padded_size)
        me.ptrs.push(meta.ptr)
        me.alignments.push(meta.alignment)
        me.padded_sizes.push(meta.padded_size)
        me.count = me.count + 1
        return 1
    }

    findIndex(ptr) {
        local i = 0
        loop(i < me.count) {
            local meta_ptr = me.ptrs.get(i)
            if meta_ptr == ptr {
                return i
            }
            i = i + 1
        }
        return -1
    }

    alignmentFor(ptr) {
        local index = me.findIndex(ptr)
        return me.alignmentAt(index)
    }

    alignmentAt(index) {
        if index < 0 {
            return 0
        }

        if index >= me.count {
            return 0
        }

        return me.alignments.get(index)
    }

    paddedSizeFor(ptr) {
        local index = me.findIndex(ptr)
        return me.paddedSizeAt(index)
    }

    paddedSizeAt(index) {
        if index < 0 {
            return 0
        }

        if index >= me.count {
            return 0
        }

        return me.padded_sizes.get(index)
    }
}
