// segment_arena_backing_modeled_allocation_ledger_release_recycle_execution_intent_marker_box.hako -- MIMAP-316A
// Responsibility:
// - record explicit model-only release/recycle execution intent after the
//   execution readiness matrix closeout
// - keep execution unsupported and visible as scalar facts
// Non-responsibility:
// - executing real arena backing release/recycle, creating real lifecycle
//   generation, pointer residence, segment-map mutation, atomic bitmap
//   execution, OSVM calls, workers, providers, or backend shortcuts

record HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionIntentMarkerReportFields {
    accepted: i64
    reason: i64
    intent_marker_present: i64
    matrix_present: i64
    matrix_accepted: i64
    matrix_reason: i64
    blocked_requirement_count: i64
    row_index: i64
    segment_id: i64
    arena_id: i64
    lifetime_generation: i64
    release_applied_recycle_token: i64
    continuation_token: i64
    application_token: i64
    applied_backing_bytes: usize
    applied_committed_bytes: usize
    remaining_source_bytes: usize
    execution_intent_requested: i64
    execution_supported: i64
    unsupported_execution_requirement: i64
    would_create_lifecycle_generation: i64
    would_create_pointer_residence: i64
    would_lookup_by_pointer: i64
    would_release_arena_backing: i64
    would_recycle_arena_backing: i64
    would_use_segment_map: i64
    would_execute_atomic_bitmap: i64
    would_call_osvm: i64
    would_run_thread: i64
    would_activate_provider: i64
    would_add_backend_matcher: i64
}

box HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionIntentMarkerReport {
    accepted: i64 = 0
    reason: i64 = 0
    intent_marker_present: i64 = 0
    matrix_present: i64 = 0
    matrix_accepted: i64 = 0
    matrix_reason: i64 = 0
    blocked_requirement_count: i64 = 0
    row_index: i64 = -1
    segment_id: i64 = -1
    arena_id: i64 = -1
    lifetime_generation: i64 = 0
    release_applied_recycle_token: i64 = 0
    continuation_token: i64 = 0
    application_token: i64 = 0
    applied_backing_bytes: usize = 0
    applied_committed_bytes: usize = 0
    remaining_source_bytes: usize = 0
    execution_intent_requested: i64 = 0
    execution_supported: i64 = 0
    unsupported_execution_requirement: i64 = 1
    would_create_lifecycle_generation: i64 = 0
    would_create_pointer_residence: i64 = 0
    would_lookup_by_pointer: i64 = 0
    would_release_arena_backing: i64 = 0
    would_recycle_arena_backing: i64 = 0
    would_use_segment_map: i64 = 0
    would_execute_atomic_bitmap: i64 = 0
    would_call_osvm: i64 = 0
    would_run_thread: i64 = 0
    would_activate_provider: i64 = 0
    would_add_backend_matcher: i64 = 0
}

box HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionIntentMarker {
    marker_count: i64 = 0
    accepted_count: i64 = 0
    reject_count: i64 = 0
    missing_marker_reject_count: i64 = 0
    missing_matrix_reject_count: i64 = 0
    rejected_matrix_reject_count: i64 = 0
    blocked_matrix_reject_count: i64 = 0
    unsupported_execution_count: i64 = 0
    last_reason: i64 = 0
    last_segment_id: i64 = -1
    last_arena_id: i64 = -1

    makeExecutionIntentMarkerReport(fields: HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionIntentMarkerReportFields): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionIntentMarkerReport {
        local result = new HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionIntentMarkerReport()
        result.accepted = fields.accepted
        result.reason = fields.reason
        result.intent_marker_present = fields.intent_marker_present
        result.matrix_present = fields.matrix_present
        result.matrix_accepted = fields.matrix_accepted
        result.matrix_reason = fields.matrix_reason
        result.blocked_requirement_count = fields.blocked_requirement_count
        result.row_index = fields.row_index
        result.segment_id = fields.segment_id
        result.arena_id = fields.arena_id
        result.lifetime_generation = fields.lifetime_generation
        result.release_applied_recycle_token = fields.release_applied_recycle_token
        result.continuation_token = fields.continuation_token
        result.application_token = fields.application_token
        result.applied_backing_bytes = fields.applied_backing_bytes
        result.applied_committed_bytes = fields.applied_committed_bytes
        result.remaining_source_bytes = fields.remaining_source_bytes
        result.execution_intent_requested = fields.execution_intent_requested
        result.execution_supported = fields.execution_supported
        result.unsupported_execution_requirement = fields.unsupported_execution_requirement
        result.would_create_lifecycle_generation = fields.would_create_lifecycle_generation
        result.would_create_pointer_residence = fields.would_create_pointer_residence
        result.would_lookup_by_pointer = fields.would_lookup_by_pointer
        result.would_release_arena_backing = fields.would_release_arena_backing
        result.would_recycle_arena_backing = fields.would_recycle_arena_backing
        result.would_use_segment_map = fields.would_use_segment_map
        result.would_execute_atomic_bitmap = fields.would_execute_atomic_bitmap
        result.would_call_osvm = fields.would_call_osvm
        result.would_run_thread = fields.would_run_thread
        result.would_activate_provider = fields.would_activate_provider
        result.would_add_backend_matcher = fields.would_add_backend_matcher
        return result
    }

    makeReport(accepted, reason, intent_marker_present, matrix_report): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionIntentMarkerReport {
        local fields = HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionIntentMarkerReportFields {
            accepted: accepted,
            reason: reason,
            intent_marker_present: intent_marker_present,
            matrix_present: matrix_report.matrix_present,
            matrix_accepted: matrix_report.accepted,
            matrix_reason: matrix_report.reason,
            blocked_requirement_count: matrix_report.blocked_requirement_count,
            row_index: matrix_report.row_index,
            segment_id: matrix_report.segment_id,
            arena_id: matrix_report.arena_id,
            lifetime_generation: matrix_report.lifetime_generation,
            release_applied_recycle_token: matrix_report.release_applied_recycle_token,
            continuation_token: matrix_report.continuation_token,
            application_token: matrix_report.application_token,
            applied_backing_bytes: matrix_report.applied_backing_bytes,
            applied_committed_bytes: matrix_report.applied_committed_bytes,
            remaining_source_bytes: matrix_report.remaining_source_bytes,
            execution_intent_requested: intent_marker_present,
            execution_supported: 0,
            unsupported_execution_requirement: 1,
            would_create_lifecycle_generation: 0,
            would_create_pointer_residence: 0,
            would_lookup_by_pointer: 0,
            would_release_arena_backing: 0,
            would_recycle_arena_backing: 0,
            would_use_segment_map: 0,
            would_execute_atomic_bitmap: 0,
            would_call_osvm: 0,
            would_run_thread: 0,
            would_activate_provider: 0,
            would_add_backend_matcher: 0,
        }
        return me.makeExecutionIntentMarkerReport(fields)
    }

    recordExecutionIntentMarker(matrix_report, intent_marker_present: i64): HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionIntentMarkerReport {
        me.marker_count += 1
        me.last_segment_id = matrix_report.segment_id
        me.last_arena_id = matrix_report.arena_id

        if intent_marker_present != 1 {
            me.reject_count += 1
            me.missing_marker_reject_count += 1
            me.last_reason = 1
            return me.makeReport(0, 1, 0, matrix_report)
        }

        if matrix_report.matrix_present != 1 {
            me.reject_count += 1
            me.missing_matrix_reject_count += 1
            me.last_reason = 2
            return me.makeReport(0, 2, 1, matrix_report)
        }

        if matrix_report.blocked_requirement_count != 0 {
            me.reject_count += 1
            me.blocked_matrix_reject_count += 1
            me.last_reason = 4
            return me.makeReport(0, 4, 1, matrix_report)
        }

        if matrix_report.accepted != 1 {
            me.reject_count += 1
            me.rejected_matrix_reject_count += 1
            me.last_reason = 3
            return me.makeReport(0, 3, 1, matrix_report)
        }

        me.accepted_count += 1
        me.unsupported_execution_count += 1
        me.last_reason = 0
        return me.makeReport(1, 0, 1, matrix_report)
    }
}
