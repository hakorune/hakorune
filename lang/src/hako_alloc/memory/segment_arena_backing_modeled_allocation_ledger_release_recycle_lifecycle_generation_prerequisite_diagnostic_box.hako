// segment_arena_backing_modeled_allocation_ledger_release_recycle_lifecycle_generation_prerequisite_diagnostic_box.hako -- MIMAP-333A
// Responsibility:
// - observe model-only lifecycle generation prerequisite reports and publish
//   scalar diagnostics
// Non-responsibility:
// - recording prerequisite rows, generating lifecycle tokens, opening pointer
//   residence, mutating segment maps, executing atomics, calling OSVM,
//   scheduling workers, activating providers, or adding backend matchers

record HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleLifecycleGenerationPrerequisiteDiagnosticReportFields {
    observed: i64
    reason: i64
    diagnostic_present: i64
    prerequisite_accepted: i64
    prerequisite_reason: i64
    prerequisite_present: i64
    lifecycle_generation_required: i64
    lifecycle_generation_supported: i64
    lifecycle_generation_ready: i64
    lifecycle_generation_token_created: i64
    observed_count: i64
    accepted_prerequisite_count: i64
    rejected_prerequisite_count: i64
    unsupported_prerequisite_count: i64
    missing_inventory_reject_count: i64
    missing_report_reject_count: i64
    last_reason: i64
    report_segment_id: i64
    report_arena_id: i64
    report_lifetime_generation: i64
    report_release_applied_recycle_token: i64
    report_continuation_token: i64
    report_application_token: i64
    report_applied_backing_bytes: usize
    report_applied_committed_bytes: usize
    report_remaining_source_bytes: usize
    would_create_lifecycle_generation: i64
    would_create_pointer_residence: i64
    would_lookup_by_pointer: i64
    would_release_arena_backing: i64
    would_recycle_arena_backing: i64
    would_use_segment_map: i64
    would_execute_atomic_bitmap: i64
    would_call_osvm: i64
    would_run_thread: i64
    would_activate_provider: i64
    would_add_backend_matcher: i64
}

