    observed: i64 = 0
    reason: i64 = 0
    diagnostic_present: i64 = 0
    prerequisite_accepted: i64 = 0
    prerequisite_reason: i64 = 0
    prerequisite_present: i64 = 0
    lifecycle_generation_required: i64 = 0
    lifecycle_generation_supported: i64 = 0
    lifecycle_generation_ready: i64 = 0
