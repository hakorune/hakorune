// segment_arena_backing_modeled_allocation_ledger_release_recycle_pointer_derived_lookup_prerequisite_box.hako -- MIMAP-340A
// Responsibility:
// - record a model-only pointer-derived lookup prerequisite from the pointer
//   residence prerequisite facts
// - keep pointer-derived lookup and real release/recycle execution closed
// Non-responsibility:
// - creating raw pointer residence, pointer-derived lookup, real arena backing
//   release/recycle, segment-map mutation, atomics, OSVM, workers, providers,
//   or backend matchers

record HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecyclePointerDerivedLookupPrerequisiteReportFields {
    accepted: i64
    reason: i64
    prerequisite_present: i64
    pointer_residence_prerequisite_present: i64
    pointer_residence_prerequisite_accepted: i64
    pointer_residence_prerequisite_reason: i64
    pointer_residence_required: i64
    pointer_residence_supported: i64
    pointer_residence_ready: i64
    pointer_residence_created: i64
    pointer_lookup_required: i64
    pointer_lookup_supported: i64
    pointer_lookup_ready: i64
    pointer_lookup_executed: i64
    prerequisite_count: i64
    accepted_count: i64
    reject_count: i64
    missing_residence_reject_count: i64
    rejected_residence_reject_count: i64
    requirement_absent_reject_count: i64
    last_reason: i64
    report_segment_id: i64
    report_arena_id: i64
    report_lifetime_generation: i64
    report_release_applied_recycle_token: i64
    report_continuation_token: i64
    report_application_token: i64
    report_applied_backing_bytes: usize
    report_applied_committed_bytes: usize
    report_remaining_source_bytes: usize
    would_create_lifecycle_generation: i64
    would_create_pointer_residence: i64
    would_lookup_by_pointer: i64
    would_release_arena_backing: i64
    would_recycle_arena_backing: i64
    would_use_segment_map: i64
    would_execute_atomic_bitmap: i64
    would_call_osvm: i64
    would_run_thread: i64
    would_activate_provider: i64
    would_add_backend_matcher: i64
}

