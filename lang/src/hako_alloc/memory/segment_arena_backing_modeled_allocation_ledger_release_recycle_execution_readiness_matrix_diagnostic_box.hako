// segment_arena_backing_modeled_allocation_ledger_release_recycle_execution_readiness_matrix_diagnostic_box.hako -- MIMAP-313A
// Responsibility:
// - observe MIMAP-312A execution readiness matrix facts and publish
//   scalar/model diagnostic facts
// - keep diagnostics observer-only before any real arena backing release or
//   recycle execution opens
// Non-responsibility:
// - recording readiness matrix rows, creating real lifecycle generation,
//   pointer residence, pointer-derived lookup, arena backing release/recycle,
//   segment-map mutation, atomic bitmap execution, OSVM calls, scheduling,
//   providers, or backend shortcuts

record HakoAllocSegmentArenaBackingModeledAllocationLedgerReleaseRecycleExecutionReadinessMatrixDiagnosticReportFields {
    observed: i64
    reason: i64
    diagnostic_present: i64
    matrix_accepted: i64
    matrix_reason: i64
    matrix_present: i64
    blocked_requirement_count: i64
    inventory_count: i64
    accepted_count: i64
    reject_count: i64
    observed_count: i64
    accepted_matrix_count: i64
    rejected_matrix_count: i64
    blocked_matrix_count: i64
    missing_inventory_reject_count: i64
    missing_matrix_reject_count: i64
    last_reason: i64
    report_segment_id: i64
    report_arena_id: i64
    report_lifetime_generation: i64
    report_release_applied_recycle_token: i64
    report_continuation_token: i64
    report_application_token: i64
    report_applied_backing_bytes: usize
    report_applied_committed_bytes: usize
    report_remaining_source_bytes: usize
    report_applied_state_ready: i64
    report_closed_substrate_summary: i64
    report_requires_lifecycle_generation: i64
    report_requires_pointer_residence: i64
    report_requires_pointer_lookup: i64
    report_requires_arena_backing_release: i64
    report_requires_arena_backing_recycle: i64
    report_requires_segment_map: i64
    report_requires_atomic_bitmap: i64
    report_requires_osvm: i64
    report_requires_worker: i64
    report_requires_provider: i64
    report_requires_backend_matcher: i64
    would_create_lifecycle_generation: i64
    would_create_pointer_residence: i64
    would_lookup_by_pointer: i64
    would_release_arena_backing: i64
    would_recycle_arena_backing: i64
    would_use_segment_map: i64
    would_execute_atomic_bitmap: i64
    would_call_osvm: i64
    would_run_thread: i64
    would_activate_provider: i64
    would_add_backend_matcher: i64
}

