// ParserStmtBox — statement parser coordinator (thin wrapper)
//
// Keep this file thin so large statement parsing logic can be split under
// `parser_stmt_box/*` without changing module import paths.

using lang.compiler.parser.stmt.parser_stmt_box.core as ParserStmtCoreBox

static box ParserStmtBox {
  // API: parse(src, i, ctx) -> JSON string (or contract error string)
  parse(src, i, ctx) {
    return ParserStmtCoreBox.parse(src, i, ctx)
  }
}
