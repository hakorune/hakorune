// build_box.hako — BuildBox (Phase‑20.33 minimal)

using lang.compiler.parser.box as ParserBox
using lang.compiler.parser.using.using_collector_box as UsingCollectorBox
using lang.compiler.entry.bundle_resolver as BundleResolver
using lang.compiler.entry.body_extraction_box as BodyExtractionBox
using lang.compiler.entry.func_scanner as FuncScannerBox
using lang.compiler.entry.stageb.stageb_json_builder_box as StageBJsonBuilderBox
using sh_core as StringHelpers

static box BuildBox {
  // Return: Program(JSON v0) string or tagged error
  method emit_program_json_v0(src, opts) {
    if src == null { return "[build/input/missing] src" }
    // Minimal Stage‑B emit:
    // - scan_src keeps the full source for defs/imports scans
    // - parse_src narrows to Main.main body when available, and only then falls back
    //   to full-source parse for non-box / non-main inputs
    local prepared = me._prepare_scan_src(src, opts)
    if prepared.has("error") == true { return me._coerce_text(prepared.get("error")) }
    local scan_src = prepared.get("scan_src")
    return me._emit_program_json_from_scan_src(scan_src)
  }

  method _coerce_text(value) {
    return "" + value
  }

  method _coerce_array_item_text(items, index) {
    return me._coerce_text(items.get(index))
  }

  method _non_empty_text(value) {
    if value == null { return 0 }
    if me._coerce_text(value) == "" { return 0 }
    return 1
  }

  method _prepare_scan_src(src, opts) {
    local result = me._new_prepare_scan_src_result(src)
    // Optional: env-driven alias/require bundling (lightweight)
    // HAKO_BUNDLE_ALIAS_TABLE='Name:code|||Name2:code2', HAKO_REQUIRE_MODS='U1,U2'
    // BuildBox では BundleResolver.resolve を使って前置連結のみを行う（Fail‑Fastタグは箱外へ伝播）
    local bundle_ctx = me._collect_bundle_inputs(opts)
    if bundle_ctx.has("error") == true {
      return me._fail_prepare_scan_src(result, bundle_ctx.get("error"))
    }
    me._apply_env_bundle_inputs(bundle_ctx)
    me._normalize_bundle_inputs(bundle_ctx)
    return me._resolve_prepare_scan_src_if_needed(result, src, bundle_ctx)
  }

  method _new_prepare_scan_src_result(src) {
    local result = new MapBox()
    result.set("scan_src", src)
    return result
  }

  method _fail_prepare_scan_src(result, error_tag) {
    result.set("error", error_tag)
    return result
  }

  method _apply_prepare_scan_src_result(result, scan_src) {
    result.set("scan_src", scan_src)
    return result
  }

  method _resolve_prepare_scan_src_if_needed(result, src, bundle_ctx) {
    if me._bundle_inputs_requested(bundle_ctx) != 1 { return result }
    local scan_src = me._resolve_scan_src_from_bundle_ctx(src, bundle_ctx)
    if scan_src == null {
      return me._fail_prepare_scan_src(result, "[build/resolve/failed]")
    }
    return me._apply_prepare_scan_src_result(result, scan_src)
  }

  method _bundle_inputs_requested(bundle_ctx) {
    if me._bundle_input_present(bundle_ctx, "bundles") == 1 { return 1 }
    if me._bundle_input_present(bundle_ctx, "bundle_names") == 1 { return 1 }
    if me._bundle_input_present(bundle_ctx, "bundle_srcs") == 1 { return 1 }
    if me._bundle_input_present(bundle_ctx, "require_mods") == 1 { return 1 }
    return 0
  }

  method _resolve_scan_src_from_bundle_ctx(src, bundle_ctx) {
    local merged = BundleResolver.resolve(bundle_ctx.get("bundles"), bundle_ctx.get("bundle_names"), bundle_ctx.get("bundle_srcs"), bundle_ctx.get("require_mods"))
    if merged == null { return null }
    return merged + src
  }

  method _collect_bundle_inputs(opts) {
    local bundle_ctx = new MapBox()
    bundle_ctx.set("bundles", null)
    bundle_ctx.set("bundle_names", null)
    bundle_ctx.set("bundle_srcs", null)
    bundle_ctx.set("require_mods", null)
    if opts == null { return bundle_ctx }

    local b = opts.get("bundles")
    if b != null {
      me._collect_plain_bundle_inputs(bundle_ctx, b)
      if bundle_ctx.has("error") == true { return bundle_ctx }
    }

    local bn = opts.get("bundle_names")
    local bs = opts.get("bundle_srcs")
    if bn != null && bs != null {
      return me._collect_named_bundle_inputs(bundle_ctx, bn, bs)
    }

    local at = opts.get("alias_table")
    if at != null && at != "" {
      me._ensure_bundle_alias_arrays(bundle_ctx)
      me._append_alias_pairs(bundle_ctx.get("bundle_names"), bundle_ctx.get("bundle_srcs"), at)
    }

    local rm = opts.get("require_mods")
    if rm != null {
      me._collect_require_mod_inputs(bundle_ctx, rm)
      if bundle_ctx.has("error") == true { return bundle_ctx }
    }

    return bundle_ctx
  }

  method _apply_env_bundle_inputs(bundle_ctx) {
    local table = env.get("HAKO_BUNDLE_ALIAS_TABLE")
    if table == null || table == "" { table = env.get("NYASH_BUNDLE_ALIAS_TABLE") }
    if table != null && table != "" {
      me._ensure_bundle_alias_arrays(bundle_ctx)
      me._append_alias_pairs(bundle_ctx.get("bundle_names"), bundle_ctx.get("bundle_srcs"), table)
    }

    local requires = env.get("HAKO_REQUIRE_MODS")
    if requires == null || requires == "" { requires = env.get("NYASH_REQUIRE_MODS") }
    if requires != null && requires != "" {
      me._ensure_require_mods_array(bundle_ctx)
      me._append_require_mods_csv(bundle_ctx.get("require_mods"), requires)
    }
  }

  method _collect_named_bundle_inputs(bundle_ctx, bundle_names, bundle_srcs) {
    if bundle_names.length() != bundle_srcs.length() {
      return me._fail_bundle_ctx(bundle_ctx, "[build/opts/mismatch] bundle_names vs bundle_srcs")
    }
    local i0 = 0; loop(i0 < bundle_names.length()) {
      local n = me._coerce_array_item_text(bundle_names, i0)
      local c = me._coerce_array_item_text(bundle_srcs, i0)
      if me._non_empty_text(n) != 1 || me._non_empty_text(c) != 1 {
        return me._fail_bundle_ctx(bundle_ctx, "[build/opts/bundle-pair/bad] index=" + i0)
      }
      local j = i0 + 1; loop(j < bundle_names.length()) {
        if me._coerce_array_item_text(bundle_names, j) == n {
          return me._fail_bundle_ctx(bundle_ctx, "[build/opts/duplicate] " + n)
        }
        j = j + 1
      }
      i0 = i0 + 1
    }
    bundle_ctx.set("bundle_names", bundle_names)
    bundle_ctx.set("bundle_srcs", bundle_srcs)
    return bundle_ctx
  }

  method _collect_plain_bundle_inputs(bundle_ctx, bundles) {
    local i = 0; loop(i < bundles.length()) {
      local s = me._coerce_array_item_text(bundles, i)
      if me._non_empty_text(s) != 1 {
        return me._fail_bundle_ctx(bundle_ctx, "[build/opts/bad-bundle] index=" + i)
      }
      i = i + 1
    }
    bundle_ctx.set("bundles", bundles)
    return bundle_ctx
  }

  method _collect_require_mod_inputs(bundle_ctx, require_mods) {
    local k0 = 0; loop(k0 < require_mods.length()) {
      if me._non_empty_text(me._coerce_array_item_text(require_mods, k0)) != 1 {
        return me._fail_bundle_ctx(bundle_ctx, "[build/opts/bad-require] index=" + k0)
      }
      k0 = k0 + 1
    }
    bundle_ctx.set("require_mods", require_mods)
    return bundle_ctx
  }

  method _ensure_bundle_alias_arrays(bundle_ctx) {
    if bundle_ctx.get("bundle_names") == null { bundle_ctx.set("bundle_names", new ArrayBox()) }
    if bundle_ctx.get("bundle_srcs") == null { bundle_ctx.set("bundle_srcs", new ArrayBox()) }
  }

  method _ensure_require_mods_array(bundle_ctx) {
    if bundle_ctx.get("require_mods") == null { bundle_ctx.set("require_mods", new ArrayBox()) }
  }

  method _append_alias_pairs(bundle_names, bundle_srcs, table) {
    local i = 0
    loop(i < table.length()) {
      local j = table.indexOf("|||", i)
      local seg = ""
      if j >= 0 { seg = table.substring(i, j) } else { seg = table.substring(i, table.length()) }
      if seg != "" {
        local pos = -1
        local k = 0
        loop(k < seg.length()) {
          if seg.substring(k, k+1) == ":" {
            pos = k
            break
          }
          k = k + 1
        }
        if pos >= 0 {
          local name = seg.substring(0, pos)
          local code = seg.substring(pos+1, seg.length())
          if name != "" && code != "" {
            bundle_names.push(name)
            bundle_srcs.push(code)
          }
        }
      }
      if j < 0 { break } else { i = j + 3 }
    }
  }

  method _append_require_mods_csv(require_mods, requires) {
    local i = 0
    loop(i < requires.length()) {
      local j = requires.indexOf(",", i)
      local seg = ""
      if j >= 0 { seg = requires.substring(i, j) } else { seg = requires.substring(i, requires.length()) }
      if seg != "" { require_mods.push(seg) }
      if j < 0 { break } else { i = j + 1 }
    }
  }

  method _normalize_bundle_inputs(bundle_ctx) {
    me._clear_bundle_input_if_empty(bundle_ctx, "bundles")
    me._clear_bundle_input_if_empty(bundle_ctx, "bundle_names")
    me._clear_bundle_input_if_empty(bundle_ctx, "bundle_srcs")
    me._clear_bundle_input_if_empty(bundle_ctx, "require_mods")
  }

  method _bundle_input_present(bundle_ctx, key) {
    if bundle_ctx.get(key) != null { return 1 }
    return 0
  }

  method _fail_bundle_ctx(bundle_ctx, error_tag) {
    bundle_ctx.set("error", error_tag)
    return bundle_ctx
  }

  method _clear_bundle_input_if_empty(bundle_ctx, key) {
    local current = bundle_ctx.get(key)
    if current != null && current.length() == 0 { bundle_ctx.set(key, null) }
  }

  method _parse_program_json(parse_src) {
    local p = new ParserBox()
    p.stage3_enable(1)
    return p.parse_program2(parse_src)
  }

  method _emit_program_json_from_scan_src(scan_src) {
    local ast_json = me._parse_program_json_from_scan_src(scan_src)
    if me._is_freeze_tag(ast_json) == 1 { return ast_json }
    return me._inject_stageb_fragments_json(ast_json, scan_src)
  }

  method _parse_program_json_from_scan_src(scan_src) {
    local parse_src = me._resolve_parse_src(scan_src)
    return me._parse_program_json(parse_src)
  }

  method _inject_stageb_fragments_json(ast_json, scan_src) {
    local enriched = me._inject_defs_json(ast_json, scan_src)
    if me._is_freeze_tag(enriched) == 1 { return enriched }
    return me._inject_imports_json(enriched, scan_src)
  }

  method _inject_defs_json(ast_json, scan_src) {
    if me._defs_scan_enabled() != 1 { return ast_json }

    local defs_json = me._build_defs_fragment_json(scan_src, ast_json)
    if me._is_freeze_tag(defs_json) == 1 { return defs_json }
    return me._inject_defs_fragment_if_present(ast_json, defs_json)
  }

  method _defs_scan_enabled() {
    local func_scan_env = env.get("HAKO_STAGEB_FUNC_SCAN")
    if func_scan_env != null && me._coerce_text(func_scan_env) == "0" { return 0 }
    return 1
  }

  method _inject_defs_fragment_if_present(ast_json, defs_json) {
    if defs_json == "" || defs_json.length() <= 0 { return ast_json }
    return StageBJsonBuilderBox.inject_json_fragment(ast_json, defs_json)
  }

  method _build_defs_fragment_json(scan_src, ast_json) {
    // defs は parser に渡した merged source と同じ境界で収集する。
    // 元の src だけを見ると using/prefix helper boxes が defs に載らず、
    // bridge-first Stage2 build で helper symbol closure が崩れる。
    local methods = FuncScannerBox.scan_all_boxes(scan_src)
    return StageBJsonBuilderBox.build_defs_json_with_source(methods, scan_src, ast_json)
  }

  method _inject_imports_json(ast_json, scan_src) {
    local imports_frag = me._build_imports_fragment_json(scan_src)
    return me._inject_imports_fragment_if_present(ast_json, imports_frag)
  }

  method _build_imports_fragment_json(scan_src) {
    local usings_json = UsingCollectorBox.collect(scan_src)
    if usings_json == null || usings_json == "[]" || usings_json == "" { return "" }

    local imports_obj = StageBJsonBuilderBox.convert_usings_to_imports(usings_json)
    if imports_obj == null || imports_obj == "{}" || imports_obj == "" { return "" }
    return ",\"imports\":" + imports_obj
  }

  method _inject_imports_fragment_if_present(ast_json, imports_frag) {
    if imports_frag == "" || imports_frag.length() <= 0 { return ast_json }
    return StageBJsonBuilderBox.inject_json_fragment(ast_json, imports_frag)
  }

  method _is_freeze_tag(text) {
    if text == null { return 0 }
    if StringHelpers.starts_with("" + text, 0, "[freeze:contract]") == 1 { return 1 }
    return 0
  }

  method _resolve_parse_src(scan_src) {
    local body_src = me._main_body_parse_src_if_present(scan_src)
    if body_src != null { return body_src }
    return scan_src
  }

  method _main_body_parse_src_if_present(scan_src) {
    local body_src = BodyExtractionBox.extract_main_body(scan_src)
    if body_src != null && body_src != "" { return body_src }
    return null
  }

  method verify_program_json_v0(json) {
    if json == null { return false }
    // Minimal header check
    return json.indexOf("\"version\":0") >= 0 && json.indexOf("\"kind\":\"Program\"") >= 0
  }

  method plan() {
    return "Stage‑B emit(JSON v0) → (future) Bridge→MIR → ny-llvmc"
  }
}
