// launcher/payload_contract.hako — Program(JSON) and MIR contract helpers

using lang.runner.launcher.artifact_io as LauncherArtifactIoBox
using lang.runner.launcher.compile_facade_impl as LauncherCompileFacadeImplBox

static box LauncherPayloadContractBox {
  method emit_program_json_from_source_path_checked(tag, source_path){
    local src = LauncherArtifactIoBox.read_file(tag, source_path)
    if src == null { return null }
    return me.emit_program_json_checked(tag, src)
  }

  method load_program_json_from_path_or_source(tag, prog_path, source_path){
    if prog_path != null && prog_path != "" {
      return LauncherArtifactIoBox.read_file(tag, prog_path)
    }
    return me.emit_program_json_from_source_path_checked(tag, source_path)
  }

  method emit_program_json_checked(tag, source_text){
    local prog = LauncherCompileFacadeImplBox.emit_program_json_v0(source_text)
    if prog == null { return null }
    return me._coerce_program_json_output_checked(tag, prog)
  }

  method emit_mir_json_checked(tag, program_json){
    local prog = me._coerce_program_json_for_emit_mir_checked(tag, program_json)
    if prog == null { return null }
    local mir = LauncherCompileFacadeImplBox.emit_from_program_json_v0(prog)
    if mir == null { return null }
    return me._coerce_mir_output_checked(tag, mir)
  }

  method emit_mir_json_from_source_path_checked(tag, source_path){
    local prog_json = me.emit_program_json_from_source_path_checked(tag, source_path)
    if prog_json == null { return null }
    return me.emit_mir_json_checked(tag, prog_json)
  }

  method _coerce_program_json_output_checked(tag, prog){
    local ps = me._coerce_text_compat(prog)
    if me._program_json_has_markers(ps) != 1 {
      print(tag + ": unexpected Program(JSON) output (missing version/kind)")
      return null
    }
    return ps
  }

  method _coerce_program_json_for_emit_mir_checked(tag, program_json){
    if program_json == null {
      print(tag + ": program_json is null")
      return null
    }
    local prog = me._coerce_text_compat(program_json)
    if me._program_json_has_markers(prog) != 1 {
      print(tag + ": input missing Program(JSON v0) markers")
      return null
    }
    return prog
  }

  method _program_json_text_present(input_text){
    if input_text != null && input_text != "" { return 1 }
    return 0
  }

  method _program_json_has_markers(program_json_text){
    if me._program_json_text_present(program_json_text) != 1 { return 0 }
    if program_json_text.indexOf("\"version\":0") < 0 || program_json_text.indexOf("\"kind\":\"Program\"") < 0 {
      return 0
    }
    return 1
  }

  method _coerce_mir_output_checked(tag, mir){
    local ms = me._coerce_text_compat(mir)
    if ms.indexOf("\"functions\"") < 0 {
      print(tag + ": output missing MIR functions marker")
      return null
    }
    return ms
  }

  method _coerce_text_compat(value){
    return "" + value
  }
}
