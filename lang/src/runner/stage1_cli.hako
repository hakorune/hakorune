// stage1_cli.hako — thin stage1 facade wrapper
//
// Canonical compat owner lives under `compat/stage1_cli.hako`.
// Top-level stage1_cli.hako stays as a facade path and delegates to the
// current env authority entry.

using lang.runner.stage1_cli_env as Stage1CliEnvBox

static box Main {
  main() {
    return Stage1CliEnvBox.main()
  }
}
