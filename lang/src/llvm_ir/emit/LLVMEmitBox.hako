// LLVMEmitBox — legacy shim only
// Actual compat/proof implementation lives in
// `selfhost.compat.codegen.llvm_emit_compat`.

using selfhost.compat.codegen.llvm_emit_compat as LLVMEmitCompatBox

static box LLVMEmitProviderBox {
  // Availability probe (for canaries)
  is_available() {
    return LLVMEmitCompatBox.is_available()
  }

  // Main entry
  method emit_object(mir_json, opts) {
    return LLVMEmitCompatBox.emit_object(mir_json, opts)
  }
}
