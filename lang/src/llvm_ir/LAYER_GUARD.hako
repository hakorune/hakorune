// LAYER_GUARD — このフォルダは llvm_ir compat helper だけを担当します
// 禁止: daily backend caller / link / run / raw LLVM surface の導入
// 許可: AotPrep / normalize / compat emit のみ

static box LLVM_IR_LAYER_GUARD {
  name(){ return "llvm_ir" }
  allowed(){ return ["aot_prep","normalize","instructions","compat_emit"] }
  forbidden(){ return ["runtime","parser","resolver","linker","run","daily_backend_boundary"] }
}
