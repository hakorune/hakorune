// BackendRouteEnvBox — backend route env mirror helper.
// Responsibility:
//   - Set HAKO_BACKEND_* route evidence around codegen calls.
//   - Restore prior env values after the call returns.
//   - Keep env juggling out of LlvmBackendBox.

static box BackendRouteEnvBox {
  with_backend_route_env(acceptance_case, transport_owner, legacy_daily_allowed, json_path, out_path, recipe, compat) {
    local prev_acceptance_case = env.get("HAKO_BACKEND_ACCEPTANCE_CASE")
    local prev_transport_owner = env.get("HAKO_BACKEND_TRANSPORT_OWNER")
    local prev_legacy_daily_allowed = env.get("HAKO_BACKEND_LEGACY_DAILY_ALLOWED")
    env.set("HAKO_BACKEND_ACCEPTANCE_CASE", me._env_text_or_empty(acceptance_case))
    env.set("HAKO_BACKEND_TRANSPORT_OWNER", me._env_text_or_empty(transport_owner))
    env.set("HAKO_BACKEND_LEGACY_DAILY_ALLOWED", me._env_text_or_empty(legacy_daily_allowed))
    local result = env.codegen.compile_json_path(json_path, out_path, recipe, compat)
    env.set("HAKO_BACKEND_ACCEPTANCE_CASE", me._env_text_or_empty(prev_acceptance_case))
    env.set("HAKO_BACKEND_TRANSPORT_OWNER", me._env_text_or_empty(prev_transport_owner))
    env.set("HAKO_BACKEND_LEGACY_DAILY_ALLOWED", me._env_text_or_empty(prev_legacy_daily_allowed))
    return result
  }

  _env_text_or_empty(value) {
    if value == null { return "" }
    return "" + value
  }
}
