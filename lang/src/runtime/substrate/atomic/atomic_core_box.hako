// AtomicCoreBox — first live `hako.atomic` capability facade for phase-29ct.
// Responsibility:
// - expose the narrowest truthful atomic-adjacent row under `runtime/substrate/`
// - keep barrier/fence proof separate from future generic atomics
// Non-responsibility:
// - pointer CAS or memory-order arguments on CAS
// - pointer load/store/fetch_add or memory-order arguments on load/store/fetch_add
// - TLS policy
// - allocator policy

static box AtomicCoreBox {
  order_relaxed_i64() {
    return 0
  }

  order_acquire_i64() {
    return 1
  }

  order_release_i64() {
    return 2
  }

  order_acq_rel_i64() {
    return 3
  }

  order_seq_cst_i64() {
    return 4
  }

  is_valid_order_i64(order) {
    if order == me.order_relaxed_i64() { return 1 }
    if order == me.order_acquire_i64() { return 1 }
    if order == me.order_release_i64() { return 1 }
    if order == me.order_acq_rel_i64() { return 1 }
    if order == me.order_seq_cst_i64() { return 1 }
    return 0
  }

  _trace(tag) {
    if env.get("HAKO_VM_MIRCALL_TRACE") == "1" { print(tag) }
  }

  fence_i64() {
    externcall "hako_barrier_touch_i64"(0)
    me._trace("[vm/adapter/atomic:fence_i64]")
    return 0
  }

  fence_order_i64(order) {
    if me.is_valid_order_i64(order) == 0 {
      print("[freeze:contract][atomic/order] invalid memory order")
      return -1
    }
    externcall "hako_barrier_touch_i64"(order)
    me._trace("[vm/adapter/atomic:fence_order_i64]")
    return 0
  }

  cas_i64(slot, expected, desired) {
    local out = externcall "hako_atomic_slot_cas_i64"(slot, expected, desired)
    me._trace("[vm/adapter/atomic:cas_i64]")
    return out
  }

  load_i64(slot) {
    local out = externcall "hako_atomic_slot_load_i64"(slot)
    me._trace("[vm/adapter/atomic:load_i64]")
    return out
  }

  store_i64(slot, value) {
    local out = externcall "hako_atomic_slot_store_i64"(slot, value)
    me._trace("[vm/adapter/atomic:store_i64]")
    return out
  }

  fetch_add_i64(slot, delta) {
    local out = externcall "hako_atomic_slot_fetch_add_i64"(slot, delta)
    me._trace("[vm/adapter/atomic:fetch_add_i64]")
    return out
  }
}
