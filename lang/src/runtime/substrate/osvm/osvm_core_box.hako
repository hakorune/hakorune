// OsVmCoreBox — first live `hako.osvm` capability facade for phase-29ct.
// Responsibility:
// - expose the narrowest truthful OS VM page-size/reserve/commit/decommit rows under `runtime/substrate/`
// - keep direct OS VM symbol knowledge out of future owner/policy boxes
// Non-responsibility:
// - allocator policy
// - final platform VM strategy

using selfhost.runtime.substrate.value_repr.current_lane_box as CurrentLaneBox

static box OsVmCoreBox {
  _trace(tag) {
    if env.get("HAKO_VM_MIRCALL_TRACE") == "1" { print(tag) }
  }

  page_size_i64() {
    local out = externcall "hako_osvm_page_size_i64"()
    me._trace("[vm/adapter/osvm:page_size_i64]")
    return out
  }

  page_size_usize() {
    local out = me.page_size_i64()
    me._trace("[vm/adapter/osvm:page_size_usize]")
    return out
  }

  reserve_bytes_i64(len_bytes) {
    local out = externcall "hako_osvm_reserve_bytes_i64"(len_bytes)
    me._trace("[vm/adapter/osvm:reserve_bytes_i64]")
    return out
  }

  reserve_bytes_usize(len_bytes: usize) {
    if CurrentLaneBox.is_usize_i64(len_bytes) != 1 {
      return 0
    }
    local out = me.reserve_bytes_i64(len_bytes)
    me._trace("[vm/adapter/osvm:reserve_bytes_usize]")
    return out
  }

  commit_bytes_i64(base, len_bytes) {
    local out = externcall "hako_osvm_commit_bytes_i64"(base, len_bytes)
    me._trace("[vm/adapter/osvm:commit_bytes_i64]")
    return out
  }

  commit_bytes_usize(base: i64, len_bytes: usize) {
    if CurrentLaneBox.is_usize_i64(len_bytes) != 1 {
      return 0
    }
    local out = me.commit_bytes_i64(base, len_bytes)
    me._trace("[vm/adapter/osvm:commit_bytes_usize]")
    return out
  }

  decommit_bytes_i64(base, len_bytes) {
    local out = externcall "hako_osvm_decommit_bytes_i64"(base, len_bytes)
    me._trace("[vm/adapter/osvm:decommit_bytes_i64]")
    return out
  }

  decommit_bytes_usize(base: i64, len_bytes: usize) {
    if CurrentLaneBox.is_usize_i64(len_bytes) != 1 {
      return 0
    }
    local out = me.decommit_bytes_i64(base, len_bytes)
    me._trace("[vm/adapter/osvm:decommit_bytes_usize]")
    return out
  }
}
