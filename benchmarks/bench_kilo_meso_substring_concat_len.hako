// kilo/text meso benchmark:
// substring + concat + len only, without store or loop-carry.
static box Main {
  main() {
    local ops = 180000
    local text = "line-seed-abcdef"
    local len = 16
    local i = 0
    local acc = 0

    loop (i < ops) {
      local split = len / 2
      local left = text.substring(0, split)
      local right = text.substring(split, len)
      local out = left + "xx" + right
      acc = acc + out.length()
      i = i + 1
    }

    return acc + len
  }
}
