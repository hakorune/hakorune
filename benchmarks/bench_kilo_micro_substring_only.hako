// kilo/text structural hotspot microbench:
// substring-only loop with no concat and no loop-carry.
static box Main {
  main() {
    local ops = 300000
    local text = "line-seed-abcdef"
    local len = text.length()
    local split = len / 2
    local i = 0
    local acc = 0

    loop (i < ops) {
      local left = text.substring(0, split)
      local right = text.substring(split, len)
      acc = acc + left.length() + right.length()
      i = i + 1
    }

    return acc + len
  }
}
