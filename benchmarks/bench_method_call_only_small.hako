// Interpreter-level microbench: method call only (small loop for time-boxed runs)
static box Main {
  main() {
    local i = 0
    local s = new StringBox("nyash")
    local total = 0
    loop(i < 5000) { // 5e3 method calls per run (faster per-run)
      total = total + s.length()
      i = i + 1
    }
    return total
  }
}
