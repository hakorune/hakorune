// kilo/text exact microbench:
// generic string concat_hh + len_h without substring carry.
static box Main {
  main() {
    local ops = 800000
    local text = "line-seed-abcdef"
    local suffix = "xy"
    local i = 0
    local acc = 0

    loop (i < ops) {
      local out = text + suffix
      acc = acc + out.length()
      i = i + 1
    }

    return acc + text.length() + suffix.length()
  }
}
