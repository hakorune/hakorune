// APP-PERF-02: kilo kernel benchmark (small)
// Deterministic text-buffer workload inspired by enhanced_kilo_editor
// 60,000 iterations with string edit + replace scan

static box Main {
  main() {
    local rows = 64
    local ops = 60000
    local i = 0
    local lines = new ArrayBox()
    local undo = 0

    loop (i < rows) {
      lines.push("line-seed")
      i = i + 1
    }

    i = 0
    loop (i < ops) {
      local row = i % rows
      local line = lines.get(row)
      local len = line.length()

      local split = len / 2
      local prefix = line.substring(0, split)
      local suffix = line.substring(split, len)
      lines.set(row, prefix + "xx" + suffix)
      undo = undo + 1

      if (i % 8 == 0) {
        local j = 0
        loop (j < rows) {
          local current = lines.get(j)
          if current.indexOf("line") >= 0 {
            lines.set(j, current + "ln")
          }
          j = j + 1
        }
      }

      i = i + 1
    }

    local total = 0
    local j = 0
    loop (j < rows) {
      local out_line = lines.get(j)
      local out_len = out_line.length()
      total = total + out_len
      j = j + 1
    }

    return total + undo
  }
}
