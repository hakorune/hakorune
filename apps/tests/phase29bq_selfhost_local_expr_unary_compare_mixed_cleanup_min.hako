// Phase 29bq parser handoff Tier-2: local init with ! + unary - + compare + && + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local a = 6
      local b = 9
      local c = 2

      local cond1 = !((-a) == b) && ((-b) < (-c))
      if cond1 {
        out = out + 47
      } else {
        out = out + 1
      }

      local cond2 = !((-(a + c)) != -8) && ((-b) < (-a))
      if cond2 {
        out = out + 59
      } else {
        out = out + 2
      }

      local cond3 = !((-(b - c)) == -7) && ((-a) > (-b))
      if cond3 {
        out = out + 71
      } else {
        out = out + 3
      }
    } cleanup {
      out = out + 2300
    }
    print(out)
    return 0
  }
}
