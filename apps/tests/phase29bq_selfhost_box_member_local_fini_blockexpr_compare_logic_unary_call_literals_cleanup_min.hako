// Phase 29bq parser handoff Tier-11: box method + local/fini + blockexpr + compare/logic + unary/call + null/array-map literal + cleanup cross.
box Counter {
  step(delta) {
    return delta + 1
  }

  cleanup_bonus() {
    return 101
  }
}

static box Main {
  main() {
    local counter = new Counter()
    local out = 0

    {
      local i = 0
      local token = {
        local arr = [10, 20]
        local m = %{"k" => 1}
        local n = null
        local cond = (!(counter.step(0) == 2) && (arr.length() == 2)) || (m == n)
        local score = 0
        if cond {
          score = 1
        } else {
          score = 4
        }
        score
      } fini {
        out = out + token
      }

      loop(i < 3) {
        i = i + 1

        local mid = {
          local base = counter.step(i)
          local arr2 = [base, i]
          arr2.length() + base
        }
        local m2 = %{"x" => mid}
        local cond2 = (!(counter.step(i) == 5) && ((-mid) < -2)) || (m2 == null)
        if cond2 {
          out = out + counter.step(mid)

          if i == 2 {
            continue
          }

          if i == 3 {
            break
          }
        }

        out = out + counter.step(1)
      }
    } cleanup {
      out = out + counter.cleanup_bonus()
    }

    print(out)
    return 0
  }
}
