// Phase 29x X10: continue cleanup minimal fixture
// Contract:
// - Contains loop(cond) with continue path and break path.
// - Runtime behavior must stay stable (exit 0).
// - continue-path cleanup correctness is pinned by rc_insertion_selfcheck in smoke.

static box Main {
  main() {
    local i = 0
    local n = 3
    local out = 0
    loop(i < n) {
      if i == 2 { break }

      local ch = 0
      local j = 0
      loop(j < 2) {
        if j == 0 { j = j + 1  continue }
        break
      }

      if ch == 1 { i = i + 1  continue }
      out = out + i
      i = i + 1
    }

    print(out)
    return 0
  }
}
