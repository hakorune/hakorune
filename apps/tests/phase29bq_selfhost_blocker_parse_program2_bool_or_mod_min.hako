// parse_program2 bool-or + mod shape (no print side effects)
// Expected: stdout=1, RC=0
static box Main {
  main() {
    local i = 0
    local n = 2
    local out = 1
    local ws_loop_count = 0

    loop(i < n) {
      local trace = 0
      if ws_loop_count < 10 || ws_loop_count % 1000 == 0 {
        if trace == 1 { print("P") }
      }
      i = i + 1
      ws_loop_count = ws_loop_count + 1
    }

    print(out)
    return 0
  }
}
