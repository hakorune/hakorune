static box Main {
    main() {
        local i = 1
        local sum = 0
        local count = 0

        loop(i <= 5) {
            if(i % 2 == 1) {
                sum = sum + i
                count = count + 1
            } else {
                sum = sum + 0
                count = count + 0
            }
            i = i + 1
        }

        // Expected: sum=9 (1+3+5), count=3
        local result = sum * 10 + count  // 93
        print(result)
        return 0
    }
}
