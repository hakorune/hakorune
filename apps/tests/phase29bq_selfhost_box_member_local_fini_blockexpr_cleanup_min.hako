// Phase 29bq parser handoff Tier-8: box method + local/fini + blockexpr + cleanup cross.
box Counter {
  step(delta) {
    return delta + 1
  }

  cleanup_bonus() {
    return 101
  }
}

static box Main {
  main() {
    local counter = new Counter()
    local out = 0

    {
      local i = 0
      local token = {
        local seed = counter.step(2)
        seed + 3
      } fini {
        out = out + token
      }

      loop(i < 3) {
        i = i + 1

        local mid = {
          local t = counter.step(i)
          t + 1
        }

        if i == 2 {
          out = out + mid
          continue
        }

        if i == 3 {
          out = out + counter.step(20)
          break
        }

        out = out + counter.step(mid)
      }
    } cleanup {
      out = out + counter.cleanup_bonus()
    }

    print(out)
    return 0
  }
}
