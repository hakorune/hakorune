// Phase 29bq: generic_loop_v1 recipe loop-if-loop (pure structure)
// - loop -> if -> nested loop
// - no break/continue/return
static box Main {
  main() {
    local i = 0
    local sum = 0

    loop(i < 3) {
      if i == 1 {
        local j = 0
        loop(j < 2) {
          sum = sum + 5
          j = j + 1
        }
      }
      i = i + 1
    }

    print(sum)
    return 0
  }
}
