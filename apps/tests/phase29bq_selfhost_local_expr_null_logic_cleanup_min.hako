// Phase 29bq parser handoff Tier-2: local init with null compare/logical ops + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local s = null
      local t = "ok"

      local cond1 = (s == null) && (t != null)
      if cond1 {
        out = out + 5
      } else {
        out = out + 1
      }

      local cond2 = (s != null) || (t == "ok")
      if cond2 {
        out = out + 50
      } else {
        out = out + 2
      }
    } cleanup {
      out = out + 400
    }
    print(out)
    return 0
  }
}
