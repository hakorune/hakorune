// Phase 29bq parser handoff Tier-2: local init with null comparisons (==/!= null) + mixed &&/|| + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local n = null
      local s = "ok"
      local t = null

      local cond1 = ((n == null) && (s != null)) || (t != null)
      if cond1 {
        out = out + 16
      } else {
        out = out + 1
      }

      local cond2 = ((n != null) && (s == null)) || (t == null)
      if cond2 {
        out = out + 3
      } else {
        out = out + 30
      }

      local cond3 = ((n != null) || (s == null)) && (t != null)
      if cond3 {
        out = out + 4
      } else {
        out = out + 40
      }
    } cleanup {
      out = out + 1600
    }
    print(out)
    return 0
  }
}
