// Phase 104: read_digits_from loop(true) + break-only minimal fixture
// Expect numeric output lines: 2 then 1

static box Main {
  main() {
    local src_a = "12x"
    local a = 0
    local ai = 0
    loop(true) {
      local ch = src_a.substring(ai, ai + 1)
      if ch == "" { break }
      local is_digit = 0
      if ch == "0" { is_digit = 1 }
      if ch == "1" { is_digit = 1 }
      if ch == "2" { is_digit = 1 }
      if ch == "3" { is_digit = 1 }
      if ch == "4" { is_digit = 1 }
      if ch == "5" { is_digit = 1 }
      if ch == "6" { is_digit = 1 }
      if ch == "7" { is_digit = 1 }
      if ch == "8" { is_digit = 1 }
      if ch == "9" { is_digit = 1 }
      if is_digit == 1 {
        a = a + 1
        ai = ai + 1
      } else {
        break
      }
    }

    local src_b = "9"
    local b = 0
    local bi = 0
    loop(true) {
      local ch = src_b.substring(bi, bi + 1)
      if ch == "" { break }
      local is_digit = 0
      if ch == "0" { is_digit = 1 }
      if ch == "1" { is_digit = 1 }
      if ch == "2" { is_digit = 1 }
      if ch == "3" { is_digit = 1 }
      if ch == "4" { is_digit = 1 }
      if ch == "5" { is_digit = 1 }
      if ch == "6" { is_digit = 1 }
      if ch == "7" { is_digit = 1 }
      if ch == "8" { is_digit = 1 }
      if ch == "9" { is_digit = 1 }
      if is_digit == 1 {
        b = b + 1
        bi = bi + 1
      } else {
        break
      }
    }

    print(a)
    print(b)
    return 0
  }
}
