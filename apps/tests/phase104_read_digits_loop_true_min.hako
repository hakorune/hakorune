// Phase 104: read_digits_from loop(true) + break-only minimal fixture
// Expect numeric output lines: 2 then 1

static box Main {
  main() {
    local src_a = "12x"
    local a = 0
    local ai = 0
    loop(true) {
      local ch = src_a.substring(ai, ai + 1)
      if ch == "" { break }
      if ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4" ||
         ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9" {
        a = a + 1
        ai = ai + 1
      } else {
        break
      }
    }

    local src_b = "9"
    local b = 0
    local bi = 0
    loop(true) {
      local ch = src_b.substring(bi, bi + 1)
      if ch == "" { break }
      if ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4" ||
         ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9" {
        b = b + 1
        bi = bi + 1
      } else {
        break
      }
    }

    print(a)
    print(b)
    return 0
  }
}
