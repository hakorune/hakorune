// Phase 29bq BoxCount: nested exit-if tree (minimal fixture)
// Pattern: loop(cond) { stmt*; if { exit } else { if { exit } else { exit } } }
// All branches of the exit-if tree must end with exit (break only, no continue)
// Note: continue in exit-if tree triggers generic_loop_v0 freeze (in-body step + continue)

static box Main {
    main() {
        local i = 0
        local out = 0
        loop(i < 5) {
            // Work before exit-if tree
            out = out + 1
            i = i + 1

            // Exit-if tree: all branches are break (no continue)
            if i >= 5 {
                break
            } else {
                if i == 3 {
                    break
                } else {
                    // Use break (not continue) to avoid generic_loop_v0 freeze
                    if out < 10 {
                        break
                    } else {
                        break
                    }
                }
            }
        }
        print(out)
        return 0
    }
}
