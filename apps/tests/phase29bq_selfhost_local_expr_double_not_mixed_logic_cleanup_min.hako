// Phase 29bq parser handoff Tier-2: local init with !! + (==/!=) + || + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local a = 5
      local b = 8
      local c = 5

      local cond1 = !!(a == c) || (b != 8)
      if cond1 {
        out = out + 61
      } else {
        out = out + 1
      }

      local cond2 = !!(a != c) || (b == 8)
      if cond2 {
        out = out + 73
      } else {
        out = out + 2
      }

      local cond3 = !!(b == 0) || (a != b)
      if cond3 {
        out = out + 89
      } else {
        out = out + 3
      }
    } cleanup {
      out = out + 2300
    }
    print(out)
    return 0
  }
}
