// Phase 291x vm-hako source-route fixture for MapBox.keys().
// Contract:
// - `keys()` returns an ArrayBox-like box whose size matches the map size.

static box Main {
  main() {
    local m = new MapBox()
    m.set("a", 1)
    m.set("b", 2)
    local ks = m.keys()
    print(ks.size())
    return 0
  }
}
