// Phase 29bq: generic_loop_v1 recipe loop-if-loop (callguard)
// - loop -> if -> loop (then-only)
// - dead-branch call to avoid LoopCondBreak
static box Main {
  main() {
    local i = 0
    local sum = 0

    loop(i < 3) {
      if i == 1 {
        local j = 0
        loop(j < 2) {
          sum = sum + 5
          // Call in dead branch to avoid LoopCondBreak
          if i < 0 {
            print(0)
          }
          j = j + 1
        }
      }
      i = i + 1
    }

    print(sum)
    return 0
  }
}
