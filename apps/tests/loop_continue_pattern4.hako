// Pattern 4: Loop with Continue
// Expected output: sum = 25 (1+3+5+7+9, skip even numbers)
static box Main {
  main() {
    local i = 0
    local sum = 0
    loop(i < 10) {
      i = i + 1
      if (i % 2 == 0) {
        continue
      }
      sum = sum + i
    }
    print(sum)
    return 0
  }
}
