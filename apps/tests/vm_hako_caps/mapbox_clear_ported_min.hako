// RVP-C23 ported fixture
// Contract:
// - vm-hako route accepts `MapBox.clear()` and resets visible `size/has/keys` state.

static box Main {
  main() {
    local m = new MapBox()
    m.set("a", 1)
    m.set("b", 2)
    m.clear()
    print(m.size())
    print(m.has("a"))
    local ks = m.keys()
    print(ks.size())
    return 0
  }
}
