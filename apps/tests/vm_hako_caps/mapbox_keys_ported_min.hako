// RVP-C22 ported fixture
// Contract:
// - vm-hako route accepts `MapBox.keys()` and returns an ArrayBox-like box whose size matches the map size.

static box Main {
  main() {
    local m = new MapBox()
    m.set("a", 1)
    m.set("b", 2)
    local ks = m.keys()
    print(ks.size())
    return 0
  }
}
