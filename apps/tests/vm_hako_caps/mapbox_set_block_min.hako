// RVP-C17 legacy filename retained for old references.
// Contract:
// - vm-hako route accepts `MapBox.set(key, value)` even when Unified MIR
//   passes a duplicate receiver alias as the first BoxCall arg.

static box Main {
  main() {
    local m = new MapBox()
    m.set("a", 42)
    return 0
  }
}
