static box Main {
    f(x) { return x + 1 }
    g(a, b) {
        local v = 0
        if a == 1 {
            if b == 1 { v = f(1) } else { v = f(2) }
        } else {
            v = f(3)
        }
        print(v)
    }
    main() {
        g(1, 1)  // → 2 (f(1) = 1+1)
        g(1, 0)  // → 3 (f(2) = 2+1)
        g(0, 0)  // → 4 (f(3) = 3+1)
        return "OK"
    }
}
