// Phase 29ab P8: Pattern6 scan_with_init OK minimal
// Expect: return index of "b" -> 1

static box Main {
    find_ok(s, ch) {
        local i = 0
        loop(i < s.length()) {
            if s.substring(i, i + 1) == ch {
                return i
            }
            i = i + 1
        }
        return -1
    }

    main() {
        return Main.find_ok("abc", "b")
    }
}
