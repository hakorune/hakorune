// Minimal loop(cond) with depth-1 nested loop for LoopCondBreakContinue
// Expected: stdout=2, RC=0
static box Main {
  main() {
    local i = 0
    local n = 3
    local m = 3

    loop(i < n) {
      local j = 0
      loop(j < m) {
        if j == m - 1 { break }
        j = j + 1
      }

      if i == n - 1 { break }
      i = i + 1
    }

    print(i)
    return 0
  }
}
