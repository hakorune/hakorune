// loop(cond) continue-if with else fallthrough minimal (owned by loop_cond_break_continue)
// Expected: stdout=a, RC=0
static box Main {
  main() {
    local src = " a"
    local i = 0
    local n = src.length()
    local out = ""

    loop(i < n) {
      local ch = src.substring(i, i + 1)
      if ch == " " {
        i = i + 1
        continue
      } else {
        out = out + ch
      }
      i = i + 1
    }

    print(out)
    return 0
  }
}

