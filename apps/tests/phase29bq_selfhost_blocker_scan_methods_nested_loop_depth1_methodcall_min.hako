// Minimal nested loop (depth1) with method call inside inner loop
// Expected: stdout=0, RC=0
static box Main {
  main() {
    local s = "method foo() {}"
    local pat = "method "
    local n = 15
    local m = 7
    local i = 0
    local k = -1

    loop(i < n) {
      local j = i
      loop(j + m <= n) {
        if s.substring(j, j + m) == pat { k = j  break }
        j = j + 1
      }
      k = k
      if k < 0 { break }
      if i == 0 { break }
    }

    print(i)
    return 0
  }
}
