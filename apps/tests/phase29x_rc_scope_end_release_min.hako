// Phase 29x X4/X5: scope-end release minimal fixture
// Contract (X4-min1):
// - One local bind remains alive until function return.
// - Setup uses `x = null; x = 1` so explicit/overwrite release does not fire.
// - With `rc-insertion-minimal`, Return terminator gets one `release_strong`.

static box Main {
    main() {
        local x = null
        x = 1
        return 0
    }
}
