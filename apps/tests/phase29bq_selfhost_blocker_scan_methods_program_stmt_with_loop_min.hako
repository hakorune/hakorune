// selfhost _scan_methods minimal: Program stmt with nested loop in loop(cond)
// Expected: stdout=0, RC=0

static box Main {
  main() {
    local n = 3
    local i = 0

    loop(i < n) {
      if i == 2 { break }
      {
        local j = 0
        loop(j < n) {
          if j == 1 { break }
          j = j + 1
        }
      }
      i = i + 1
    }

    print(0)
    return 0
  }
}
