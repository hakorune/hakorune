// parse_program2 nested loop + inner if-else fallthrough join return-local (local from BlockExpr) shape (return exits func)
// Expected: stdout="", RC=0
static box Main {
  main() {
    local i = 0
    loop(i < 1) {
      local j = 0
      loop(j < 2) {
        if j == 0 {
          local t = {
            local u = 0
            u
          }
          return t
        } else {
          // fallthrough
        }
        j = j + 1
      }
      i = i + 1
    }
    return 0
  }
}
