// Phase 29bq: generic_loop_v1 recipe acceptance (then-only if with nested loop)
// Goal: accept a loop body with then-only if + nested loop (no break/continue/return)
// Expected output: 2
static box Main {
  main() {
    local i = 0
    local j = 0
    local sum = 0

    loop(i < 2) {
      if i == 0 {
        j = 0
        loop(j < 2) {
          sum = sum + 1
          j = j + 1
        }
      }
      i = i + 1
    }

    print(sum)
    return 0
  }
}
