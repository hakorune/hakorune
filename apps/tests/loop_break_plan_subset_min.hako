// Semantic fixture alias for the minimal loop_break plan-subset route.
// Expect: exit 15

static box Main {
    main() {
        local sum = 0
        local i = 0

        loop(i < 10) {
            if i == 5 {
                sum = sum + 10
                break
            }
            sum = sum + 1
            i = i + 1
        }

        return sum
    }
}
