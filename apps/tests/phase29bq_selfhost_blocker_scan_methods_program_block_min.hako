// selfhost _scan_methods minimal: loop(cond) with program blocks + nested loops
// Expected: stdout=OK, RC=0
static box Main {
  main() {
    local s = "method foo() {}"
    local methods = new ArrayBox()
    local n = s.length()
    local i = 0

    print("OK")

    loop(i < n) {
      local k = -1
      {
        local pat = "method "
        local m = pat.length()
        local j = i
        loop(j + m <= n) {
          if s.substring(j, j + m) == pat { k = j  break }
          j = j + 1
        }
      }
      if k < 0 { break }
      i = k + 7

      local name_start = i
      local name_end = -1
      {
        local j = i
        loop(j < n) {
          local ch = s.substring(j, j + 1)
          if ch == "(" { name_end = j  break }
          j = j + 1
        }
      }
      if name_end < 0 { break }
      local method_name = s.substring(name_start, name_end)

      if method_name == "main" { i = name_end  continue }

      local lparen = name_end
      local rparen = -1
      {
        local j = lparen + 1
        local in_str = 0
        loop(j < n) {
          local ch = s.substring(j, j + 1)
          if in_str == 1 {
            if ch == "\"" { in_str = 0  j = j + 1  continue }
            j = j + 1
            continue
          }
          if ch == "\"" { in_str = 1  j = j + 1  continue }
          if ch == ")" { rparen = j  break }
          j = j + 1
        }
      }
      if rparen < 0 { break }

      local lbrace = -1
      {
        local j = rparen + 1
        loop(j < n) {
          local ch = s.substring(j, j + 1)
          if ch == "{" { lbrace = j  break }
          j = j + 1
        }
      }
      if lbrace < 0 { break }

      local rbrace = -1
      {
        local depth = 0
        local j = lbrace
        loop(j < n) {
          local ch = s.substring(j, j + 1)
          if ch == "{" { depth = depth + 1  j = j + 1  continue }
          if ch == "}" {
            depth = depth - 1
            j = j + 1
            if depth == 0 { rbrace = j - 1  break }
            continue
          }
          j = j + 1
        }
      }
      if rbrace < 0 { break }

      i = rbrace
      methods.push(method_name)
    }

    return 0
  }
}
