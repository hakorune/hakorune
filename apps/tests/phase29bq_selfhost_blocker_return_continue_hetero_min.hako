// Minimal fixture for heterogeneous exit if-else pattern
// Source shape: JsonScanBox.seek_obj_end/2 in selfhost compiler
// Pattern: loop(cond) with continue + if-else where then has no exit, else has return
//
// Note: Under NYASH_DISABLE_PLUGINS=1, StringBox method behavior may differ.
// This fixture is pinned by shape; output is stabilized via print(...) + return 0.
//
// Gate convention:
// - stdout is pinned via print(...)
// - return code is pinned to 0

static box Main {
    main() {
        local text = new StringBox("{}}}")
        local n = text.length()
        local depth = 0
        local i = 0
        local in_str = 0

        loop(i < n) {
            local ch = text.substring(i, i + 1)

            // Continue-if patterns (to trigger loop_cond_continue_only)
            if in_str == 1 {
                if ch == "\\" {
                    i = i + 2
                    continue
                }
                if ch == "\"" {
                    in_str = 0
                    i = i + 1
                    continue
                }
                i = i + 1
                continue
            }

            // This if-else has heterogeneous exit types:
            // then: depth++ (no exit)
            // else: depth--; if (depth == 0) { return } (has return)
            if ch == "\"" {
                // start string
                in_str = 1
            } else {
                if ch == "{" {
                    depth = depth + 1
                } else {
                    if ch == "}" {
                        depth = depth - 1
                        if depth == 0 {
                            print(i)
                            return 0
                        }
                    }
                }
            }

            i = i + 1
        }

        print(-1)
        return 0
    }
}
