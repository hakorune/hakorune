// Phase 29bq parser handoff Tier-2: local init with null comparisons under unary ! + && + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local n = null
      local s = "ok"
      local t = null

      local cond1 = !(n == null) && (s != null)
      if cond1 {
        out = out + 10
      } else {
        out = out + 1
      }

      local cond2 = !(s == null) && (n == null)
      if cond2 {
        out = out + 17
      } else {
        out = out + 2
      }

      local cond3 = !(t != null) && (s != null)
      if cond3 {
        out = out + 170
      } else {
        out = out + 3
      }
    } cleanup {
      out = out + 1700
    }
    print(out)
    return 0
  }
}
