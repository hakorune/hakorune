// Phase 29x X9: break cleanup minimal fixture
// Contract:
// - Contains a loop(cond) with explicit break path and continue path.
// - Runtime behavior must stay stable (exit 0).
// - break-path cleanup correctness is pinned by rc_insertion_selfcheck in smoke.

static box Main {
    main() {
        local i = 0
        local sum = 0
        loop(i < 3) {
            if i >= 2 { break }
            local t = i
            sum = sum + t
            i = i + 1
        }
        print(sum)
        return 0
    }
}
