// Minimal fixture for "phi missing step join cursor" class regressions.
// Gate convention: stdout pinned, rc=0.
//
// Shape: loop(cond) with multiple continue paths and a break exit.
static box Main {
    main() {
        local i = 0
        local n = 10

        loop(i < n) {
            if i == 0 {
                i = i + 1
                continue
            }
            if i == 1 {
                i = i + 1
                continue
            }
            if i == 2 {
                print(0)
                break
            }
            i = i + 1
        }

        return 0
    }
}
