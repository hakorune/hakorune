// Phase 286 P2.3: Pattern9 → Frag PoC minimal fixture
// Expected: return 3 (sum = 0 + 1 + 1 + 1 = 3)
// Design: Pattern1 + carrier1本 + const加算の最小固定

static box Main {
    main() {
        local i
        local sum
        i = 0
        sum = 0
        loop(i < 3) {
            sum = sum + 1
            i = i + 1
        }
        return sum
    }
}
