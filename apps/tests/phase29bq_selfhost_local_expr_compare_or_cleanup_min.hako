// Phase 29bq parser handoff Tier-2: local init with comparison chain (==/!= + ||) + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local a = 3
      local b = 3
      local c = 4

      local cond1 = (a != b) || (b == c)
      if cond1 {
        out = out + 1
      } else {
        out = out + 12
      }

      local cond2 = ((a + 1) != c) || ((c - 1) == b)
      if cond2 {
        out = out + 2
      } else {
        out = out + 120
      }
    } cleanup {
      out = out + 1200
    }
    print(out)
    return 0
  }
}
