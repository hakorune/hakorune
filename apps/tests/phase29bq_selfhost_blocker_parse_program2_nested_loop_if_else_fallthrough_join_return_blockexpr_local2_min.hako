// parse_program2 nested loop + inner if-else fallthrough join return-blockexpr-local2 shape (return exits func)
// Expected: stdout="", RC=0
static box Main {
  main() {
    local i = 0
    loop(i < 1) {
      local j = 1
      loop(j < 2) {
        if j == 0 {
          local t = 0
          return {
            local u = t
            local w = u
            w
          }
        } else {
          // fallthrough
        }
        j = j + 1
      }
      i = i + 1
    }
    return 0
  }
}
