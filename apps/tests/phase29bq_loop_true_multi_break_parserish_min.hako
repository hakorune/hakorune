// Phase 29bq: loop(true) with multi-break (parser-ish shape)
// Expected output: 1
//
// Shape:
// - loop(true)
// - multiple `if (cond) { break }`
// - assignments + method calls in body

static box Main {
    main() {
        local s = "ab"
        local i = 0
        local acc = 0

        loop(true) {
            if i >= s.length() { break }

            local ch = s.substring(i, i + 1)
            if ch == "b" { break }

            acc = acc + 1
            i = i + 1
        }

        print(acc)
        return "OK"
    }
}
