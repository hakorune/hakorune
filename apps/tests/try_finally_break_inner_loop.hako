static box Main {
  main(args) {
    local i = 0
    local fin = 0
    loop(i < 3) {
      try {
        local j = 0
        loop(j < 5) {
          if (j == 2) { break }
          j = j + 1
        }
      } cleanup {
        // inner の break に関わらず finally は 1 回実行
        fin = fin + 1
      }
      i = i + 1
    }
    // outer 反復回数 = 3
    return fin
  }
}
