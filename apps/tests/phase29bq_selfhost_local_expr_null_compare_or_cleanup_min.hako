// Phase 29bq parser handoff Tier-2: local init with null comparisons (== null, != null) + || + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local n = null
      local s = "ok"

      local cond1 = (n == null) || (s == null)
      if cond1 {
        out = out + 15
      } else {
        out = out + 1
      }

      local cond2 = (n != null) || (s != null)
      if cond2 {
        out = out + 2
      } else {
        out = out + 20
      }
    } cleanup {
      out = out + 1500
    }
    print(out)
    return 0
  }
}
