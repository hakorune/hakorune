using "apps/lib/json_native/utils/string.hako" as StringUtils

local digits = "0123456789"
local d4 = "4"
local d2 = "2"

print("-42".length())
print("-42".substring(0,1))
print("-42".substring(1,2))
print("-42".substring(2,3))
print("-42".substring(1,2) == "4")
print(StringUtils.is_integer("-42"))
print(digits.length())
print(digits.substring(4,5))
print(digits.substring(4,5) == d4)
print(StringUtils.index_of(digits, d4))
print(StringUtils.index_of(digits, d2))
print(StringUtils.parse_integer("-42"))
