// Phase 29bq parser handoff Tier-2: local init with comparison chain (==/!= + &&) + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local a = 3
      local b = 3
      local c = 4

      local cond1 = (a == b) && (b != c)
      if cond1 {
        out = out + 11
      } else {
        out = out + 1
      }

      local cond2 = ((a + 1) == c) && ((c - 1) != b)
      if cond2 {
        out = out + 110
      } else {
        out = out + 2
      }
    } cleanup {
      out = out + 1100
    }
    print(out)
    return 0
  }
}
