// parse_program2 nested loop + inner if-else fallthrough join return-blockexpr-var shape (return exits func)
// Expected: stdout="", RC=0
static box Main {
  main() {
    local v = 0
    local i = 0
    loop(i < 1) {
      local j = 0
      loop(j < 2) {
        if j == 0 {
          return {
            local t = v
            t
          }
        } else {
          // fallthrough
        }
        j = j + 1
      }
      i = i + 1
    }
    return 0
  }
}
