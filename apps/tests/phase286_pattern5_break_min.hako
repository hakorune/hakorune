// Phase 286 P3.2: Pattern5 infinite loop with break
// Tests: loop(true) with if (i == 3) { break } and carrier update
// Expected: 3 (sum = 0 + 1 + 1 + 1 = 3 for i = 0, 1, 2)

static box Main {
  main() {
    local i = 0
    local sum = 0
    loop(true) {
      if (i == 3) { break }
      sum = sum + 1
      i = i + 1
    }
    return sum
  }
}
