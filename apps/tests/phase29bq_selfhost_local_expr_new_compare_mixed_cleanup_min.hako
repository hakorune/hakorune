// Phase 29bq parser handoff Tier-2: new object method return + compare + &&/|| + postfix cleanup.
box Calc {
  f(v) {
    return v + 1
  }

  g(v) {
    return v * 2
  }
}

static box Main {
  main() {
    local out = 0
    {
      local calc = new Calc()

      local cond1 = (calc.f(1) == 2) && ((calc.g(2) == 4) || (calc.g(1) == 9))
      if cond1 {
        out = out + 43
      } else {
        out = out + 1
      }

      local cond2 = (calc.f(0) == 0) || ((calc.g(2) == 4) && (calc.f(3) == 4))
      if cond2 {
        out = out + 47
      } else {
        out = out + 2
      }

      local cond3 = ((calc.f(5) == 6) && (calc.g(3) == 7)) || (calc.f(2) == 0)
      if cond3 {
        out = out + 53
      } else {
        out = out + 3
      }
    } cleanup {
      out = out + 2300
    }
    print(out)
    return 0
  }
}
