// Phase 29bq: ScanWhilePredicate shape minimal fixture
// Expected: stdout=abc, RC=0
// Body: [local_decl, method_call, method_call, step]

static box CharChecker {
  is_alpha(ch) {
    if (ch >= "a" && ch <= "z") { return 1 }
    if (ch >= "A" && ch <= "Z") { return 1 }
    return 0
  }
}

static box Main {
  main() {
    local s = "abc123"
    local n = s.length()
    local pos = 0
    local result = new MapBox()
    result.set("value", "")
    loop (pos < n && CharChecker.is_alpha(s.substring(pos, pos + 1)) == 1) {
      local ch = s.substring(pos, pos + 1)
      result.set("value", "" + result.get("value") + ch)
      result.set("end", pos + 1)
      pos = pos + 1
    }
    print(result.get("value"))
    return 0
  }
}
