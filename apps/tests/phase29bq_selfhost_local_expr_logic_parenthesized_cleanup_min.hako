// Phase 29bq parser handoff Tier-2: local init with parenthesized logical expr (explicit precedence) + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local cond1 = ((1 < 2) && (2 < 3)) || ((3 < 2) && (4 < 5))
      if cond1 {
        out = out + 9
      } else {
        out = out + 1
      }

      local cond2 = !((1 < 0) || ((2 < 1) && (3 < 2)))
      if cond2 {
        out = out + 90
      } else {
        out = out + 2
      }
    } cleanup {
      out = out + 900
    }
    print(out)
    return 0
  }
}
