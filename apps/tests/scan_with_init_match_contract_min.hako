// Phase 29ad P0: Pattern6 match scan contract violation
// Expect: JoinIR freeze (step update missing)

static box Main {
    find_missing_step(s, ch) {
        local i = 0
        loop(i < s.length()) {
            if s.substring(i, i + 1) == ch {
                return i
            }
        }
        return -1
    }

    main() {
        return Main.find_missing_step("abc", "b")
    }
}
