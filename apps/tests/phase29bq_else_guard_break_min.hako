// Minimal else-guard-break pattern from FuncScannerBox._scan_methods
static box Main {
    main() {
        local n = 5
        local i = 0
        local k = -1
        local name_start = -1

        loop(i < n) {
            if k >= 0 {
                name_start = k + 7
            } else {
                local j = i + 1
                if j >= n { break }
                if j < 0 { break }
                name_start = j
            }

            if name_start < 0 { break }
            i = name_start + 1
        }

        print(name_start)
        return name_start
    }
}
// Expected: stdout=3, RC=3
