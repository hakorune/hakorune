// parse_program2 nested loop + inner if-else-return-local shape (return exits func)
// Expected: stdout="", RC=0
static box Main {
  main() {
    local i = 0
    loop(i < 1) {
      local j = 1
      loop(j < 2) {
        if j == 0 {
          return 0
        } else {
          local t = 0
          return t
        }
      }
      i = i + 1
    }
    return 1
  }
}

