// Phase 29bq: EffectStepOnly shape minimal fixture
// Expected: stdout=3, RC=0
// Body: [method_call, step]

static box Main {
  main() {
    local arr = new ArrayBox()
    local src = new ArrayBox()
    src.push(1)
    src.push(2)
    src.push(3)
    local n = src.length()
    local i = 0
    loop (i < n) {
      arr.push(src.get(i))
      i = i + 1
    }
    print(arr.length())
    return 0
  }
}
