// Minimal loop(cond) with empty then branch for cond_lowering no-op
// Expected: stdout=0, RC=0
static box Main {
  main() {
    local i = 0
    local n = 2

    loop(i < n) {
      if i == 0 { }
      else { i = i + 1 }

      if i == 0 { break }
      i = i + 1
    }

    print(i)
    return 0
  }
}
