// parse_program2 nested loop + inner if-else-if return shape (all branches return; exits func)
// Expected: stdout="", RC=0
static box Main {
  main() {
    local i = 0
    loop(i < 1) {
      local j = 2
      loop(j < 3) {
        if j == 0 {
          return 0
        } else {
          if j == 1 {
            return 0
          } else {
            return 0
          }
        }
      }
      i = i + 1
    }
    return 1
  }
}

