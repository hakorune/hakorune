// Phase 29bq: generic_loop_v1 recipe acceptance (nested if, non-LoopCondBreak)
// Goal: loop with a single if (no break/continue/return) that LoopCondBreak rejects
// Expected output: 0
static box Helper {
  make() {
    return fn(x) { return x }
  }
}

static box Main {
  main() {
    local i = 0
    local sum = 0

    loop(i < 3) {
      if i < 0 {
        // NOTE: This call is intentionally unreachable to avoid VM closure execution.
        Helper.make()(i)
        sum = sum + 2
      }
      i = i + 1
    }

    print(sum)
    return 0
  }
}
