// Phase 103 P1: if-only early return regression fixture
// Goal: keep branch-local early-return shapes inside main (no helper-call dependency).
// Expect: two numeric lines "7" then "2".

static box Main {
  main() {
    if 0 == 0 {
      print(7)
    } else {
      return 99
    }

    if 1 == 0 {
      return 98
    } else {
      print(2)
    }

    return 0
  }
}
