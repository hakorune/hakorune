// parse_program2 whitespace OR chain (loop + continue + break)
// Expected: stdout=1, RC=0
static box Main {
  main() {
    local src = " "
    local i = 0
    local n = src.length()

    loop(i < n) {
      local ch = src.substring(i, i + 1)
      if ch == " " || ch == "\n" || ch == "\r" || ch == "\t" {
        i = i + 1
        continue
      }
      break
    }

    print(i)
    return 0
  }
}
