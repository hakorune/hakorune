// Phase 29bq parser handoff Tier-2: local init with relational mix (==/!=/< />) + && + || + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local a = 10
      local b = 4
      local c = 7

      local cond1 = ((a > b) && (c != b)) || (a == 0)
      if cond1 {
        out = out + 41
      } else {
        out = out + 1
      }

      local cond2 = ((a < b) && (c == 7)) || ((a != b) && (b < c))
      if cond2 {
        out = out + 53
      } else {
        out = out + 2
      }

      local cond3 = ((a == b) || (c > a)) && ((b != c) || (a < b))
      if cond3 {
        out = out + 89
      } else {
        out = out + 3
      }
    } cleanup {
      out = out + 2300
    }
    print(out)
    return 0
  }
}
