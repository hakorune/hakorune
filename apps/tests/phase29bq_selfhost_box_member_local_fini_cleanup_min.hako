// Phase 29bq parser handoff Tier-7: box method + local/fini + cleanup cross.
box Counter {
  step(delta) {
    return delta + 1
  }

  cleanup_bonus() {
    return 11
  }
}

static box Main {
  main() {
    local counter = new Counter()
    local out = 0

    {
      local i = 0
      local token = 5 fini {
        out = out + token
      }

      loop(i < 3) {
        i = i + 1

        if i == 2 {
          out = out + counter.step(10)
          continue
        }

        if i == 3 {
          out = out + counter.step(20)
          break
        }

        out = out + counter.step(i)
      }
    } cleanup {
      out = out + counter.cleanup_bonus()
    }

    print(out)
    return 0
  }
}
