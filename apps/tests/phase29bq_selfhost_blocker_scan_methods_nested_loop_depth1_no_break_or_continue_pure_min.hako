// Minimal nested loop (depth1) with no break/continue and no calls
// Expected: stdout=0, RC=0
static box Main {
  main() {
    local n = 3
    local i = 0
    local name_end = -1

    loop(i < n) {
      local j = 0
      loop(j < n) {
        if j == 0 { name_end = j }
        j = j + 1
      }

      if name_end < 0 { break }
      i = i + 1
    }

    print(0)
    return 0
  }
}
