// Phase 29bq: loop_cond_break_continue nested if (minimal)
//
// Note: This fixture is accepted by LoopCondBreak (GeneralIf/conditional_update)
// and is NOT a generic_loop_v1 acceptance test.
// Expected output: 10
static box Main {
  main() {
    local i = 0
    local sum = 0

    loop(i < 5) {
      if i == 2 {
        sum = sum + 10
      }
      i = i + 1
    }

    print(sum)
    return 0
  }
}
