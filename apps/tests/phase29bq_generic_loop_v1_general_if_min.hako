// Phase 29bq: generic_loop_v1 general-if in loop body (dev-only)
//
// Goal: allow general If with local/assign/nested-if in loop body (no rewrite).
//
// Expected output: 4
static box Main {
  main() {
    local i = 0
    local sum = 0

    loop(i < 3) {
      local ch = i
      if i == 1 {
        local tmp = sum + 1
        sum = tmp + 1
      } else {
        if i == 2 {
          sum = sum + 2
        }
      }
      i = i + 1
    }

    print(sum)
    return 0
  }
}
