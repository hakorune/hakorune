// Simple pattern: shallow return (depth 1) + continue
// This fixture tests the v1 box (LoopCondContinueWithReturn) with:
// - continue>0: continue-if statement
// - return>0: shallow return (depth 1) in else chain
// - stdout testing: print(0) for early return, print(-1) for loop completion
static box Main {
    main() {
        local text = new StringBox("{}")
        local n = text.length()
        local depth = 0
        local i = 0
        local in_str = 0

        loop(i < n) {
            local ch = text.substring(i, i + 1)

            // Continue-if (continue>0)
            if in_str == 1 {
                i = i + 1
                continue
            }

            // Hetero-return-if with shallow return (depth 1)
            if ch == "\"" {
                in_str = 1
            } else {
                if ch == "}" {
                    depth = depth - 1
                    if depth == 0 {
                        print(0)  // stdoutでテスト
                        return 0  // 浅いreturn（depth 1）
                    }
                }
            }

            i = i + 1
        }

        print(-1)
        return 0
    }
}
