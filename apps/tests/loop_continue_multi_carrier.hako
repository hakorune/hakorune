// Pattern 4: Loop with Continue - Multiple Carriers
// Expected output: sum=25, count=5 (1+3+5+7+9, count odd numbers)
static box Main {
  main() {
    local i = 0
    local sum = 0
    local count = 0
    loop(i < 10) {
      i = i + 1
      if (i % 2 == 0) {
        continue
      }
      sum = sum + i
      count = count + 1
    }
    print(sum)
    print(count)
    return 0
  }
}
