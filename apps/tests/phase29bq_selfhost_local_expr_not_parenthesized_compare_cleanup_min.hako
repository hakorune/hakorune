// Phase 29bq parser handoff Tier-2: local init with !(cmp || cmp) && cmp + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local a = 9
      local b = 4
      local c = 7

      local cond1 = !((a == b) || (c < b)) && (a > c)
      if cond1 {
        out = out + 67
      } else {
        out = out + 1
      }

      local cond2 = !((a > b) || (c == 7)) && (b < c)
      if cond2 {
        out = out + 71
      } else {
        out = out + 2
      }

      local cond3 = !((a != b) || (c > a)) && (b == 4)
      if cond3 {
        out = out + 73
      } else {
        out = out + 3
      }
    } cleanup {
      out = out + 2300
    }
    print(out)
    return 0
  }
}
