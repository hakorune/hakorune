// Minimal fixture for deeply nested return (depth 3) in else chain
// This fixture tests the v2 box (LoopCondContinueWithReturnNested3) with:
// - continue>0: multiple continue-if patterns
// - return>0: deeply nested return (depth 3) in else chain
// - stdout testing: print(1) for early return at i=1, print(-1) for loop completion
static box Main {
    main() {
        local text = new StringBox("{}}}")
        local n = text.length()
        local depth = 0
        local i = 0
        local in_str = 0

        loop(i < n) {
            local ch = text.substring(i, i + 1)

            // Continue-if patterns
            if in_str == 1 {
                if ch == "\\" {
                    i = i + 2
                    continue
                }
                if ch == "\"" {
                    in_str = 0
                    i = i + 1
                    continue
                }
                i = i + 1
                continue
            }

            // Hetero-return-if with deeply nested return (depth 3)
            if ch == "\"" {
                in_str = 1
            } else {
                if ch == "{" {
                    depth = depth + 1
                } else {
                    if ch == "}" {
                        depth = depth - 1
                        if depth == 0 {
                            print(1)  // stdoutでテスト
                            return 0  // 深さ3のネストreturn
                        }
                    }
                }
            }

            i = i + 1
        }

        print(-1)
        return 0
    }
}
