// Phase 275 P0: Test C2 - Plus with number-only promotion
// Goal: Int+Float promotion, String+String only

static box Main {
    main() {
        // Number promotion
        local a = 1 + 2.0          // 3.0 (Float)
        local b = 2.5 + 1          // 3.5 (Float)

        // String concat
        local c = "a" + "b"        // "ab"

        if a == 3.0 and b == 3.5 and c == "ab" {
            return 3  // Success
        }

        return 1  // Failure
    }
}
