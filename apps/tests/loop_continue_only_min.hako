// Phase 29ap P8: loop_continue_only minimal fixture (plan routing)
// Expected output: 6

static box Main {
    main() {
        local i, sum
        i = 0
        sum = 0
        loop(i < 4) {
            if (i == 0) { i = i + 1; continue }
            sum = sum + i
            i = i + 1
        }
        print(sum)
        return 0
    }
}
