// Semantic fixture alias for the minimal accum_const_loop frag PoC.
// Expected: return 3 (sum = 0 + 1 + 1 + 1 = 3)

static box Main {
    main() {
        local i
        local sum
        i = 0
        sum = 0
        loop(i < 3) {
            sum = sum + 1
            i = i + 1
        }
        return sum
    }
}
