// Phase 29bq parser handoff Tier-2: local init with logical precedence (! + && + || + comparisons) + postfix cleanup.
static box Main {
  main() {
    local out = 0
    {
      local cond1 = (1 < 2) || (3 < 2) && (0 > 1)
      if cond1 {
        out = out + 8
      } else {
        out = out + 1
      }

      local cond2 = !(1 < 0) || (2 < 1) && (3 < 2)
      if cond2 {
        out = out + 80
      } else {
        out = out + 2
      }
    } cleanup {
      out = out + 800
    }
    print(out)
    return 0
  }
}
