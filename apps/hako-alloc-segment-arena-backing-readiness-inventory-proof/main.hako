// hako-alloc-segment-arena-backing-readiness-inventory-proof
// Purpose: prove MIMAP-236A segment arena backing readiness inventory.

using selfhost.hako_alloc.memory.page_box as HakoAllocPageBox
using selfhost.hako_alloc.memory.segment_map_lookup_guarded_readiness_composition_box as HakoAllocSegmentMapLookupGuardedReadinessComposition
using selfhost.hako_alloc.memory.segment_map_accepted_readiness_modeled_consume_ledger_box as HakoAllocSegmentMapAcceptedReadinessModeledConsumeLedger
using selfhost.hako_alloc.memory.segment_allocation_modeled_released_span_ledger_box as HakoAllocSegmentAllocationModeledReleasedSpanLedger
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_box as HakoAllocSegmentAllocationModeledLocalFreeReuse
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_ledger_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLedger
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_ledger_release_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLedgerRelease
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_token_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleToken
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_token_observer_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenObserver
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_token_release_key_precondition_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenReleaseKeyPrecondition
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_keyed_release_ledger_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleKeyedReleaseLedger
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_keyed_release_apply_recycle_diagnostic_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleKeyedReleaseApplyRecycleDiagnostic
using selfhost.hako_alloc.memory.segment_arena_backing_readiness_inventory_box as HakoAllocSegmentArenaBackingReadinessInventory

static box Main {
    seedFullPage(page): i64 {
        local p0 = page.acquire(8)
        local p1 = page.acquire(8)
        local p2 = page.acquire(8)
        local p3 = page.acquire(8)
        local p4 = page.acquire(8)
        local p5 = page.acquire(8)
        local p6 = page.acquire(8)
        local p7 = page.acquire(8)
        return p7
    }

    nextReleasedSpan(route, released_spans, readiness): HakoAllocSegmentAllocationModeledReleasedSpanLedgerReport {
        local consumed = route.consumeAcceptedReadiness(readiness, 0)
        local released = route.releaseConsumedToken(consumed.modeled_allocation_token, 0)
        return released_spans.recordReleasedSpan(released, 0)
    }

    nextReuseReport(composition, route, released_spans, reuse_route): HakoAllocSegmentAllocationModeledLocalFreeReuseReport {
        local readiness = composition.composeLookupReadiness(70, 7, 3, 16, 1, composition.stateActive(), 2, 8, 3, 0)
        local page = new HakoAllocPageModel(7, 16, 8, 8)
        local p7 = Main.seedFullPage(page)
        local span = Main.nextReleasedSpan(route, released_spans, readiness)
        return reuse_route.integrateAndReuseLocalFree(span, page, 8, 0, 0, 0)
    }

    main(args) {
        local composition = new HakoAllocSegmentMapLookupGuardedReadinessComposition()
        local route = new HakoAllocSegmentMapAcceptedReadinessModeledConsumeLedger()
        local released_spans = new HakoAllocSegmentAllocationModeledReleasedSpanLedger()
        local reuse_route = new HakoAllocSegmentAllocationModeledLocalFreeReuse()
        local reuse_ledger = new HakoAllocSegmentAllocationModeledLocalFreeReuseLedger()
        local old_release_ledger = new HakoAllocSegmentAllocationModeledLocalFreeReuseLedgerRelease()
        local lifecycle_owner = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleToken()
        local observer = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenObserver()
        local precondition = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenReleaseKeyPrecondition()
        local migrated_release_ledger = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleKeyedReleaseLedger()
        local continuation_diag = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleKeyedReleaseApplyRecycleDiagnostic()
        local arena_inventory = new HakoAllocSegmentArenaBackingReadinessInventory()

        local empty_continuation = continuation_diag.observeApplyRecycleDiagnostics(reuse_ledger, 0)

        local reuse = Main.nextReuseReport(composition, route, released_spans, reuse_route)
        local first = reuse_ledger.recordLocalFreeReuse(reuse, 0)
        local old_release = old_release_ledger.recordReuseLedgerRelease(first, 0)
        local old_apply = reuse_ledger.applyReuseLedgerRelease(old_release, 0)
        local recycled = reuse_ledger.recordLocalFreeReuse(reuse, 0)
        local old_second_release = old_release_ledger.recordReuseLedgerRelease(recycled, 0)

        local first_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 1, 0)
        local second_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 2, 0)
        local duplicate_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 2, 0)
        local invalid_lifecycle = lifecycle_owner.recordLifecycleToken(-1, 3, 0)
        local unsupported_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 4, 1)

        local observed = observer.observeLifecycleBoundary(lifecycle_owner, old_second_release, 0)
        local ready = precondition.classify(observed, 0)
        local migrated = migrated_release_ledger.recordLifecycleKeyedRelease(ready, second_lifecycle, 0)

        local lifecycle_apply = reuse_ledger.applyReuseLedgerLifecycleKeyedRelease(migrated, 0)
        local missing_live_apply = reuse_ledger.applyReuseLedgerLifecycleKeyedRelease(migrated, 0)
        local continued = reuse_ledger.recordLocalFreeReuse(reuse, 0)
        local live_duplicate = reuse_ledger.recordLocalFreeReuse(reuse, 0)
        local unsupported_apply = reuse_ledger.applyReuseLedgerLifecycleKeyedRelease(migrated, 1)

        local continuation_summary = continuation_diag.observeApplyRecycleDiagnostics(reuse_ledger, 0)
        local accepted = arena_inventory.classifyReadiness(continuation_summary, 70, 7, 16, 8, 8, 8, 4096, 0, 0, 0, 0, 0, 0)
        local missing = arena_inventory.classifyReadiness(empty_continuation, 70, 7, 16, 8, 8, 8, 4096, 0, 0, 0, 0, 0, 0)
        local invalid = arena_inventory.classifyReadiness(continuation_summary, -1, 7, 16, 8, 8, 8, 4096, 0, 0, 0, 0, 0, 0)
        local arena_blocked = arena_inventory.classifyReadiness(continuation_summary, 70, 7, 16, 8, 8, 8, 4096, 1, 0, 0, 0, 0, 0)
        local raw_blocked = arena_inventory.classifyReadiness(continuation_summary, 70, 7, 16, 8, 8, 8, 4096, 0, 1, 0, 0, 0, 0)
        local segment_map_blocked = arena_inventory.classifyReadiness(continuation_summary, 70, 7, 16, 8, 8, 8, 4096, 0, 0, 1, 0, 0, 0)
        local atomic_blocked = arena_inventory.classifyReadiness(continuation_summary, 70, 7, 16, 8, 8, 8, 4096, 0, 0, 0, 1, 0, 0)
        local osvm_blocked = arena_inventory.classifyReadiness(continuation_summary, 70, 7, 16, 8, 8, 8, 4096, 0, 0, 0, 0, 1, 0)
        local provider_blocked = arena_inventory.classifyReadiness(continuation_summary, 70, 7, 16, 8, 8, 8, 4096, 0, 0, 0, 0, 0, 1)

        local ok = check "mimap236a segment arena backing readiness inventory" {
            "continuation observed": continuation_summary.observed == 1
            "continuation apply seen": continuation_summary.lifecycle_keyed_apply_seen == 1
            "accepted": accepted.accepted == 1
            "accepted reason": accepted.reason == 0
            "accepted segment": accepted.segment_id == 70
            "accepted arena": accepted.arena_id == 7
            "accepted slices": accepted.slice_count == 16
            "accepted committed": accepted.committed_slices == 8
            "accepted free": accepted.free_slices == 8
            "accepted alignment": accepted.required_alignment == 8
            "accepted page size": accepted.page_size == 4096
            "accepted continuation observed": accepted.lifecycle_continuation_observed == 1
            "accepted apply seen": accepted.lifecycle_keyed_apply_seen == 1
            "accepted readiness present": accepted.arena_backing_readiness_present == 1
            "accepted scalar model": accepted.scalar_arena_backing_model == 1
            "missing rejected": missing.accepted == 0
            "missing reason": missing.reason == 1
            "invalid rejected": invalid.accepted == 0
            "invalid reason": invalid.reason == 2
            "arena blocked": arena_blocked.reason == 3
            "raw blocked": raw_blocked.reason == 4
            "segment map blocked": segment_map_blocked.reason == 5
            "atomic blocked": atomic_blocked.reason == 6
            "osvm blocked": osvm_blocked.reason == 7
            "provider blocked": provider_blocked.reason == 8
            "classify count": arena_inventory.classify_count == 9
            "accepted count": arena_inventory.accepted_count == 1
            "reject count": arena_inventory.reject_count == 8
            "missing count": arena_inventory.missing_continuation_reject_count == 1
            "invalid count": arena_inventory.invalid_shape_reject_count == 1
            "arena count": arena_inventory.arena_allocation_reject_count == 1
            "raw count": arena_inventory.raw_pointer_reject_count == 1
            "segment map count": arena_inventory.segment_map_reject_count == 1
            "atomic count": arena_inventory.atomic_bitmap_reject_count == 1
            "osvm count": arena_inventory.osvm_reject_count == 1
            "provider count": arena_inventory.provider_reject_count == 1
            "inactive arena allocation": accepted.would_allocate_arena_backing == 0
            "inactive raw": accepted.would_use_raw_pointer == 0
            "inactive segment map": accepted.would_use_segment_map == 0
            "inactive atomic": accepted.would_execute_atomic_bitmap == 0
            "inactive osvm": accepted.would_call_osvm == 0
            "inactive thread": accepted.would_run_thread == 0
            "inactive provider": accepted.would_activate_provider == 0
            "inactive matcher": accepted.would_add_backend_matcher == 0
        }

        print("hako-alloc-segment-arena-backing-readiness-inventory-proof")
        print("base=" + recycled.modeled_reuse_token + "," + migrated.reuse_lifecycle_token + "," + continuation_summary.lifecycle_keyed_apply_seen)
        print("readiness=" + accepted.accepted + "," + accepted.reason + "," + accepted.segment_id + "," + accepted.arena_id + "," + accepted.slice_count + "," + accepted.committed_slices + "," + accepted.free_slices + "," + accepted.required_alignment + "," + accepted.page_size + "," + accepted.lifecycle_continuation_observed)
        print("rejects=" + missing.reason + "," + invalid.reason + "," + arena_blocked.reason + "," + raw_blocked.reason + "," + segment_map_blocked.reason + "," + atomic_blocked.reason + "," + osvm_blocked.reason + "," + provider_blocked.reason)
        print("counts=" + arena_inventory.classify_count + "," + arena_inventory.accepted_count + "," + arena_inventory.reject_count + "," + arena_inventory.missing_continuation_reject_count + "," + arena_inventory.invalid_shape_reject_count + "," + arena_inventory.arena_allocation_reject_count + "," + arena_inventory.raw_pointer_reject_count + "," + arena_inventory.segment_map_reject_count + "," + arena_inventory.atomic_bitmap_reject_count + "," + arena_inventory.osvm_reject_count + "," + arena_inventory.provider_reject_count)
        print("inactive=" + accepted.would_allocate_arena_backing + "," + accepted.would_use_raw_pointer + "," + accepted.would_use_segment_map + "," + accepted.would_execute_atomic_bitmap + "," + accepted.would_call_osvm + "," + accepted.would_run_thread + "," + accepted.would_activate_provider + "," + accepted.would_add_backend_matcher)
        print("check=" + ok)

        if ok == 1 {
            print("summary=ok")
            return 0
        }

        print("summary=fail")
        return 1
    }
}
