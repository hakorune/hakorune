// hako-alloc-osvm-fast-path-reuse-route-proof
// Purpose: prove MIMAP-043A OSVM-backed fast-path recommit/reuse route.

using selfhost.hako_alloc.memory.osvm_fast_path_reuse_route_box as HakoAllocOsVmFastPathReuseRouteBox

static box Main {
    main(args) {
        local route = new HakoAllocOsVmFastPathReuseRoute(0, 16, 2, 64, 64)

        local handle0 = route.allocate(8)
        local handle0_ok = 0
        if handle0 != null {
            handle0_ok = 1
        }

        local release0 = route.release(handle0)
        local purge0 = route.purgeOne(1)

        local pre_reuse = route.allocate(8)
        local pre_reuse_ok = 0
        if pre_reuse != null {
            pre_reuse_ok = 1
        }

        local reuse0 = route.recommitAndAllocate(purge0.selected_page_id, 8)

        local ok = check "mimap043a osvm fast path reuse route" {
            "initial handle": handle0_ok == 1
            "release ok": release0 == 1
            "purge status": purge0.status == 0
            "purge selected": purge0.selected_page_id == 0
            "purge source": purge0.source_executed == 1
            "pre reuse rejected": pre_reuse_ok == 0
            "recommit status": reuse0.recommit_status == 0
            "recommit executed": reuse0.recommit_executed == 1
            "marker recommitted": reuse0.marker_recommitted == 1
            "page reactivated": reuse0.page_reactivated == 1
            "reuse allowed": reuse0.reuse_allowed_after == 1
            "post handle ok": reuse0.handle_ok == 1
            "post page": reuse0.handle_page_id == purge0.selected_page_id
            "marker clear": reuse0.marker_marked_after == 0
            "route success": route.success_count == 1
            "route rejects": route.reject_count == 0
            "source once": route.sourceExecutionCount() == 1
            "recommit success": route.recommit.success_count == 1
            "heap one page": route.purge_route.heap.page_create_count == 1
            "heap allocations": route.purge_route.heap.alloc_count == 2
            "heap releases": route.purge_route.heap.release_count == 1
            "heap direct decommit untouched": route.purge_route.heap.decommit_count == 0
        }

        print("hako-alloc-osvm-fast-path-reuse-route-proof")
        print("initial=" + handle0_ok + "," + release0 + "," + route.purge_route.allocate_count + "," + route.purge_route.release_count)
        print("purge=" + purge0.status + "," + purge0.stop_reason + "," + purge0.selected_page_id + "," + purge0.source_executed + "," + purge0.marker_marked)
        print("pre=" + pre_reuse_ok + "," + route.purge_route.reject_count)
        print("reuse=" + reuse0.status + "," + reuse0.recommit_status + "," + reuse0.recommit_executed + "," + reuse0.marker_recommitted + "," + reuse0.page_reactivated + "," + reuse0.reuse_allowed_after + "," + reuse0.handle_ok + "," + reuse0.handle_page_id + "," + reuse0.handle_block_id + "," + reuse0.marker_marked_after)
        print("route=" + route.reuse_attempt_count + "," + route.success_count + "," + route.reject_count + "," + route.last_status + "," + route.last_handle_page_id + "," + route.last_marker_marked_after)
        print("recommit=" + route.recommit.attempt_count + "," + route.recommit.success_count + "," + route.recommit.blocked_count + "," + route.recommit.marker_transition_count + "," + route.recommit.page_reactivate_count)
        print("marker=" + route.purge_route.decommit_guard.marker.marked_count + "," + route.purge_route.decommit_guard.marker.recommitted_count + "," + route.markerIsMarked(purge0.selected_page_id))
        print("heap=" + route.purge_route.heap.alloc_count + "," + route.purge_route.heap.release_count + "," + route.purge_route.heap.page_create_count + "," + route.purge_route.heap.reserve_count + "," + route.purge_route.heap.commit_count + "," + route.purge_route.heap.decommit_count)
        print("check=" + ok)

        if ok == 1 {
            print("summary=ok")
            return 0
        }

        print("summary=fail")
        return 1
    }
}
