// hako-alloc-segment-map-local-free-reuse-ledger-lifecycle-keyed-release-shadow-proof
// Purpose: prove MIMAP-224A lifecycle-keyed release shadow ledger.

using selfhost.hako_alloc.memory.page_box as HakoAllocPageBox
using selfhost.hako_alloc.memory.segment_map_lookup_guarded_readiness_composition_box as HakoAllocSegmentMapLookupGuardedReadinessComposition
using selfhost.hako_alloc.memory.segment_map_accepted_readiness_modeled_consume_ledger_box as HakoAllocSegmentMapAcceptedReadinessModeledConsumeLedger
using selfhost.hako_alloc.memory.segment_allocation_modeled_released_span_ledger_box as HakoAllocSegmentAllocationModeledReleasedSpanLedger
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_box as HakoAllocSegmentAllocationModeledLocalFreeReuse
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_ledger_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLedger
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_ledger_release_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLedgerRelease
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_token_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleToken
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_token_observer_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenObserver
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_token_release_key_precondition_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenReleaseKeyPrecondition
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_keyed_release_shadow_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleKeyedReleaseShadow

static box Main {
    seedFullPage(page): i64 {
        local p0 = page.acquire(8)
        local p1 = page.acquire(8)
        local p2 = page.acquire(8)
        local p3 = page.acquire(8)
        local p4 = page.acquire(8)
        local p5 = page.acquire(8)
        local p6 = page.acquire(8)
        local p7 = page.acquire(8)
        return p7
    }

    nextReleasedSpan(route, released_spans, readiness): HakoAllocSegmentAllocationModeledReleasedSpanLedgerReport {
        local consumed = route.consumeAcceptedReadiness(readiness, 0)
        local released = route.releaseConsumedToken(consumed.modeled_allocation_token, 0)
        return released_spans.recordReleasedSpan(released, 0)
    }

    nextReuseReport(composition, route, released_spans, reuse_route): HakoAllocSegmentAllocationModeledLocalFreeReuseReport {
        local readiness = composition.composeLookupReadiness(70, 7, 3, 16, 1, composition.stateActive(), 2, 8, 3, 0)
        local page = new HakoAllocPageModel(7, 16, 8, 8)
        local p7 = Main.seedFullPage(page)
        local span = Main.nextReleasedSpan(route, released_spans, readiness)
        return reuse_route.integrateAndReuseLocalFree(span, page, 8, 0, 0, 0)
    }

    main(args) {
        local composition = new HakoAllocSegmentMapLookupGuardedReadinessComposition()
        local route = new HakoAllocSegmentMapAcceptedReadinessModeledConsumeLedger()
        local released_spans = new HakoAllocSegmentAllocationModeledReleasedSpanLedger()
        local reuse_route = new HakoAllocSegmentAllocationModeledLocalFreeReuse()
        local reuse_ledger = new HakoAllocSegmentAllocationModeledLocalFreeReuseLedger()
        local release_ledger = new HakoAllocSegmentAllocationModeledLocalFreeReuseLedgerRelease()
        local lifecycle_owner = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleToken()
        local observer = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenObserver()
        local precondition = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenReleaseKeyPrecondition()
        local shadow = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleKeyedReleaseShadow()

        local reuse = Main.nextReuseReport(composition, route, released_spans, reuse_route)
        local first = reuse_ledger.recordLocalFreeReuse(reuse, 0)
        local release = release_ledger.recordReuseLedgerRelease(first, 0)
        local apply = reuse_ledger.applyReuseLedgerRelease(release, 0)
        local recycled = reuse_ledger.recordLocalFreeReuse(reuse, 0)
        local second_release = release_ledger.recordReuseLedgerRelease(recycled, 0)

        local first_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 1, 0)
        local second_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 2, 0)
        local duplicate_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 2, 0)
        local invalid_lifecycle = lifecycle_owner.recordLifecycleToken(-1, 3, 0)
        local unsupported_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 4, 1)

        local observed = observer.observeLifecycleBoundary(lifecycle_owner, second_release, 0)
        local empty_lifecycle_owner = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleToken()
        local missing_observer = observer.observeLifecycleBoundary(empty_lifecycle_owner, second_release, 0)
        local ready = precondition.classify(observed, 0)
        local missing_precondition = precondition.classify(missing_observer, 0)

        local other_lifecycle_owner = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleToken()
        local mismatch_lifecycle = other_lifecycle_owner.recordLifecycleToken(1234, 1, 0)

        local accepted = shadow.recordLifecycleKeyedRelease(ready, second_lifecycle, 0)
        local duplicate = shadow.recordLifecycleKeyedRelease(ready, second_lifecycle, 0)
        local precondition_reject = shadow.recordLifecycleKeyedRelease(missing_precondition, second_lifecycle, 0)
        local lifecycle_reject = shadow.recordLifecycleKeyedRelease(ready, invalid_lifecycle, 0)
        local mismatch = shadow.recordLifecycleKeyedRelease(ready, mismatch_lifecycle, 0)
        local unsupported = shadow.recordLifecycleKeyedRelease(ready, second_lifecycle, 1)

        local ok = check "mimap224a segment map local free reuse ledger lifecycle-keyed release shadow" {
            "recycled accepted": recycled.accepted == 1
            "second release duplicate": second_release.did_release == 0
            "precondition ready": ready.ready == 1
            "precondition migration inactive": ready.would_migrate_release_ledger_key == 0
            "accepted": accepted.accepted == 1
            "accepted reason": accepted.reason == 0
            "accepted row": accepted.row_index == 0
            "accepted token": accepted.modeled_reuse_token == 70007004
            "accepted lifecycle id": accepted.lifecycle_id == 2
            "accepted lifecycle token": accepted.reuse_lifecycle_token == 70007004002
            "accepted release duplicate seen": accepted.release_duplicate_seen == 1
            "accepted source release key retained": accepted.release_key_still_modeled_reuse_token == 1
            "accepted migration inactive": accepted.would_migrate_release_ledger_key == 0
            "duplicate rejected": duplicate.accepted == 0
            "duplicate reason": duplicate.reason == 4
            "duplicate existing": duplicate.existing_index == 0
            "precondition rejected": precondition_reject.accepted == 0
            "precondition reason": precondition_reject.reason == 1
            "lifecycle rejected": lifecycle_reject.accepted == 0
            "lifecycle reason": lifecycle_reject.reason == 2
            "mismatch rejected": mismatch.accepted == 0
            "mismatch reason": mismatch.reason == 3
            "unsupported rejected": unsupported.accepted == 0
            "unsupported reason": unsupported.reason == 5
            "attempt count": shadow.attempt_count == 6
            "accepted count": shadow.accepted_count == 1
            "reject count": shadow.reject_count == 5
            "precondition reject count": shadow.precondition_reject_count == 1
            "lifecycle reject count": shadow.lifecycle_report_reject_count == 1
            "mismatch reject count": shadow.token_mismatch_reject_count == 1
            "duplicate reject count": shadow.duplicate_reject_count == 1
            "unsupported reject count": shadow.unsupported_requirement_reject_count == 1
            "inactive real allocation": accepted.would_execute_real_segment_allocation == 0
            "inactive real free": accepted.would_execute_real_segment_free == 0
            "inactive direct page arrays": accepted.would_directly_mutate_page_arrays == 0
            "inactive raw": accepted.would_use_raw_pointer == 0
            "inactive segment map": accepted.would_use_segment_map == 0
            "inactive arena": accepted.would_allocate_arena_backing == 0
            "inactive atomic": accepted.would_execute_atomic_bitmap == 0
            "inactive osvm": accepted.would_call_osvm == 0
            "inactive thread": accepted.would_run_thread == 0
            "inactive provider": accepted.would_activate_provider == 0
            "inactive matcher": accepted.would_add_backend_matcher == 0
        }

        print("hako-alloc-segment-map-local-free-reuse-ledger-lifecycle-keyed-release-shadow-proof")
        print("base=" + recycled.modeled_reuse_token + "," + second_lifecycle.reuse_lifecycle_token + "," + ready.would_migrate_release_ledger_key)
        print("shadow=" + accepted.accepted + "," + accepted.reason + "," + accepted.row_index + "," + accepted.modeled_reuse_token + "," + accepted.lifecycle_id + "," + accepted.reuse_lifecycle_token + "," + accepted.release_duplicate_seen + "," + accepted.would_migrate_release_ledger_key)
        print("rejects=" + precondition_reject.accepted + "," + precondition_reject.reason + "," + lifecycle_reject.accepted + "," + lifecycle_reject.reason + "," + mismatch.accepted + "," + mismatch.reason + "," + duplicate.accepted + "," + duplicate.reason + "," + unsupported.accepted + "," + unsupported.reason)
        print("counts=" + shadow.attempt_count + "," + shadow.accepted_count + "," + shadow.reject_count + "," + shadow.precondition_reject_count + "," + shadow.lifecycle_report_reject_count + "," + shadow.token_mismatch_reject_count + "," + shadow.duplicate_reject_count + "," + shadow.unsupported_requirement_reject_count)
        print("inactive=" + accepted.would_execute_real_segment_allocation + "," + accepted.would_execute_real_segment_free + "," + accepted.would_directly_mutate_page_arrays + "," + accepted.would_use_raw_pointer + "," + accepted.would_use_segment_map + "," + accepted.would_allocate_arena_backing + "," + accepted.would_execute_atomic_bitmap + "," + accepted.would_call_osvm + "," + accepted.would_run_thread + "," + accepted.would_activate_provider + "," + accepted.would_add_backend_matcher)
        print("check=" + ok)

        if ok == 1 {
            print("summary=ok")
            return 0
        }

        print("summary=fail")
        return 1
    }
}
