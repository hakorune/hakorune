// hako-alloc-segment-map-local-free-reuse-ledger-lifecycle-keyed-release-ledger-diagnostics-proof
// Purpose: prove MIMAP-229A source lifecycle-keyed release ledger diagnostics.

using selfhost.hako_alloc.memory.page_box as HakoAllocPageBox
using selfhost.hako_alloc.memory.segment_map_lookup_guarded_readiness_composition_box as HakoAllocSegmentMapLookupGuardedReadinessComposition
using selfhost.hako_alloc.memory.segment_map_accepted_readiness_modeled_consume_ledger_box as HakoAllocSegmentMapAcceptedReadinessModeledConsumeLedger
using selfhost.hako_alloc.memory.segment_allocation_modeled_released_span_ledger_box as HakoAllocSegmentAllocationModeledReleasedSpanLedger
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_box as HakoAllocSegmentAllocationModeledLocalFreeReuse
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_ledger_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLedger
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_ledger_release_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLedgerRelease
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_token_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleToken
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_token_observer_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenObserver
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_token_release_key_precondition_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenReleaseKeyPrecondition
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_keyed_release_ledger_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleKeyedReleaseLedger
using selfhost.hako_alloc.memory.segment_allocation_modeled_local_free_reuse_lifecycle_keyed_release_ledger_diagnostic_box as HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleKeyedReleaseLedgerDiagnostic

static box Main {
    seedFullPage(page): i64 {
        local p0 = page.acquire(8)
        local p1 = page.acquire(8)
        local p2 = page.acquire(8)
        local p3 = page.acquire(8)
        local p4 = page.acquire(8)
        local p5 = page.acquire(8)
        local p6 = page.acquire(8)
        local p7 = page.acquire(8)
        return p7
    }

    nextReleasedSpan(route, released_spans, readiness): HakoAllocSegmentAllocationModeledReleasedSpanLedgerReport {
        local consumed = route.consumeAcceptedReadiness(readiness, 0)
        local released = route.releaseConsumedToken(consumed.modeled_allocation_token, 0)
        return released_spans.recordReleasedSpan(released, 0)
    }

    nextReuseReport(composition, route, released_spans, reuse_route): HakoAllocSegmentAllocationModeledLocalFreeReuseReport {
        local readiness = composition.composeLookupReadiness(70, 7, 3, 16, 1, composition.stateActive(), 2, 8, 3, 0)
        local page = new HakoAllocPageModel(7, 16, 8, 8)
        local p7 = Main.seedFullPage(page)
        local span = Main.nextReleasedSpan(route, released_spans, readiness)
        return reuse_route.integrateAndReuseLocalFree(span, page, 8, 0, 0, 0)
    }

    main(args) {
        local composition = new HakoAllocSegmentMapLookupGuardedReadinessComposition()
        local route = new HakoAllocSegmentMapAcceptedReadinessModeledConsumeLedger()
        local released_spans = new HakoAllocSegmentAllocationModeledReleasedSpanLedger()
        local reuse_route = new HakoAllocSegmentAllocationModeledLocalFreeReuse()
        local reuse_ledger = new HakoAllocSegmentAllocationModeledLocalFreeReuseLedger()
        local old_release_ledger = new HakoAllocSegmentAllocationModeledLocalFreeReuseLedgerRelease()
        local lifecycle_owner = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleToken()
        local observer = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenObserver()
        local precondition = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleTokenReleaseKeyPrecondition()
        local migrated_release_ledger = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleKeyedReleaseLedger()
        local diagnostic = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleKeyedReleaseLedgerDiagnostic()

        local reuse = Main.nextReuseReport(composition, route, released_spans, reuse_route)
        local first = reuse_ledger.recordLocalFreeReuse(reuse, 0)
        local old_release = old_release_ledger.recordReuseLedgerRelease(first, 0)
        local apply = reuse_ledger.applyReuseLedgerRelease(old_release, 0)
        local recycled = reuse_ledger.recordLocalFreeReuse(reuse, 0)
        local old_second_release = old_release_ledger.recordReuseLedgerRelease(recycled, 0)

        local first_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 1, 0)
        local second_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 2, 0)
        local duplicate_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 2, 0)
        local invalid_lifecycle = lifecycle_owner.recordLifecycleToken(-1, 3, 0)
        local unsupported_lifecycle = lifecycle_owner.recordLifecycleToken(recycled.modeled_reuse_token, 4, 1)

        local observed = observer.observeLifecycleBoundary(lifecycle_owner, old_second_release, 0)
        local empty_lifecycle_owner = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleToken()
        local missing_observer = observer.observeLifecycleBoundary(empty_lifecycle_owner, old_second_release, 0)
        local ready = precondition.classify(observed, 0)
        local missing_precondition = precondition.classify(missing_observer, 0)

        local other_lifecycle_owner = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleToken()
        local mismatch_lifecycle = other_lifecycle_owner.recordLifecycleToken(1234, 1, 0)

        local migrated = migrated_release_ledger.recordLifecycleKeyedRelease(ready, second_lifecycle, 0)
        local duplicate = migrated_release_ledger.recordLifecycleKeyedRelease(ready, second_lifecycle, 0)
        local precondition_reject = migrated_release_ledger.recordLifecycleKeyedRelease(missing_precondition, second_lifecycle, 0)
        local lifecycle_reject = migrated_release_ledger.recordLifecycleKeyedRelease(ready, invalid_lifecycle, 0)
        local mismatch = migrated_release_ledger.recordLifecycleKeyedRelease(ready, mismatch_lifecycle, 0)
        local unsupported = migrated_release_ledger.recordLifecycleKeyedRelease(ready, second_lifecycle, 1)

        local summary = diagnostic.observeReleaseLedgerDiagnostics(migrated_release_ledger, 0)
        local empty_ledger = new HakoAllocSegmentAllocationModeledLocalFreeReuseLifecycleKeyedReleaseLedger()
        local missing = diagnostic.observeReleaseLedgerDiagnostics(empty_ledger, 0)
        local unsupported_diag = diagnostic.observeReleaseLedgerDiagnostics(migrated_release_ledger, 1)

        local ok = check "mimap229a source lifecycle-keyed release ledger diagnostics" {
            "migrated accepted": migrated.did_release == 1
            "duplicate rejected": duplicate.did_release == 0
            "duplicate reason": duplicate.reason == 4
            "precondition rejected": precondition_reject.did_release == 0
            "precondition reason": precondition_reject.reason == 1
            "lifecycle rejected": lifecycle_reject.did_release == 0
            "lifecycle reason": lifecycle_reject.reason == 2
            "mismatch rejected": mismatch.did_release == 0
            "mismatch reason": mismatch.reason == 3
            "unsupported rejected": unsupported.did_release == 0
            "unsupported reason": unsupported.reason == 5
            "summary observed": summary.observed == 1
            "summary reason": summary.reason == 0
            "summary attempts": summary.attempt_count == 6
            "summary ledger count": summary.ledger_count == 1
            "summary accepted": summary.accepted_count == 1
            "summary rejects": summary.reject_count == 5
            "summary precondition": summary.precondition_reject_seen == 1
            "summary lifecycle": summary.lifecycle_report_reject_seen == 1
            "summary mismatch": summary.token_mismatch_reject_seen == 1
            "summary duplicate": summary.duplicate_lifecycle_key_seen == 1
            "summary unsupported": summary.unsupported_requirement_reject_seen == 1
            "summary key kind": summary.source_release_ledger_key_kind == 1
            "summary migrated flag": summary.release_key_migrated == 1
            "summary present": summary.reject_summary_present == 1
            "summary last reason": summary.last_reason == 5
            "summary last token": summary.last_reuse_lifecycle_token == 70007004002
            "missing rejected": missing.observed == 0
            "missing reason": missing.reason == 1
            "unsupported diag rejected": unsupported_diag.observed == 0
            "unsupported diag reason": unsupported_diag.reason == 2
            "diagnostic attempts": diagnostic.observe_count == 3
            "diagnostic accepted": diagnostic.accepted_count == 1
            "diagnostic rejects": diagnostic.reject_count == 2
            "diagnostic missing": diagnostic.missing_ledger_reject_count == 1
            "diagnostic unsupported": diagnostic.unsupported_requirement_reject_count == 1
            "inactive real allocation": summary.would_execute_real_segment_allocation == 0
            "inactive real free": summary.would_execute_real_segment_free == 0
            "inactive direct page arrays": summary.would_directly_mutate_page_arrays == 0
            "inactive raw": summary.would_use_raw_pointer == 0
            "inactive segment map": summary.would_use_segment_map == 0
            "inactive arena": summary.would_allocate_arena_backing == 0
            "inactive atomic": summary.would_execute_atomic_bitmap == 0
            "inactive osvm": summary.would_call_osvm == 0
            "inactive thread": summary.would_run_thread == 0
            "inactive provider": summary.would_activate_provider == 0
            "inactive matcher": summary.would_add_backend_matcher == 0
        }

        print("hako-alloc-segment-map-local-free-reuse-ledger-lifecycle-keyed-release-ledger-diagnostics-proof")
        print("base=" + recycled.modeled_reuse_token + "," + second_lifecycle.reuse_lifecycle_token + "," + migrated_release_ledger.attempt_count)
        print("summary=" + summary.observed + "," + summary.reason + "," + summary.attempt_count + "," + summary.ledger_count + "," + summary.accepted_count + "," + summary.reject_count + "," + summary.precondition_reject_seen + "," + summary.lifecycle_report_reject_seen + "," + summary.token_mismatch_reject_seen + "," + summary.duplicate_lifecycle_key_seen + "," + summary.unsupported_requirement_reject_seen + "," + summary.last_reason + "," + summary.last_reuse_lifecycle_token)
        print("rejects=" + missing.observed + "," + missing.reason + "," + unsupported_diag.observed + "," + unsupported_diag.reason)
        print("counts=" + diagnostic.observe_count + "," + diagnostic.accepted_count + "," + diagnostic.reject_count + "," + diagnostic.missing_ledger_reject_count + "," + diagnostic.unsupported_requirement_reject_count)
        print("inactive=" + summary.would_execute_real_segment_allocation + "," + summary.would_execute_real_segment_free + "," + summary.would_directly_mutate_page_arrays + "," + summary.would_use_raw_pointer + "," + summary.would_use_segment_map + "," + summary.would_allocate_arena_backing + "," + summary.would_execute_atomic_bitmap + "," + summary.would_call_osvm + "," + summary.would_run_thread + "," + summary.would_activate_provider + "," + summary.would_add_backend_matcher)
        print("check=" + ok)

        if ok == 1 {
            print("summary=ok")
            return 0
        }

        print("summary=fail")
        return 1
    }
}
