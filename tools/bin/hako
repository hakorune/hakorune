#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
BIN_HAKORUNE="$ROOT_DIR/target/release/hakorune"
BIN_NYASH="$ROOT_DIR/target/release/nyash"

if [[ -x "$BIN_HAKORUNE" ]]; then
  BIN="$BIN_HAKORUNE"
else
  BIN="$BIN_NYASH"
fi

if [[ ! -x "$BIN" ]]; then
  echo "[info] building (release) ..." >&2
  cargo build --release -q
fi

exec "$BIN" "$@"
