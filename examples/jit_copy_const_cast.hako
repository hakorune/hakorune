// Copy/Const/Cast coverage demo
// Use with: NYASH_JIT_THRESHOLD=1 NYASH_JIT_DUMP=1

static box Main {
  main() {
    local a, b, f
    a = 42
    b = a // Copy
    f = 100.0
    // Mixed compare (int vs float) to exercise promote/cast path in optimizer
    if (b < f) {
      // Return boolean directly
      return b < f
    } else {
      return false
    }
  }
}

